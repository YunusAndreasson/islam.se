---
import { Font } from "astro:assets";
import { ClientRouter } from "astro:transitions";
import FloatingPlayer from "../components/FloatingPlayer.astro";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import SearchOverlay from "../components/SearchOverlay.astro";
import { APP_STORE_ID } from "../lib/app";
import { ORG_ID, breadcrumbList, organization, webSite } from "../lib/jsonld";
import "../styles/tokens.css";
import "../styles/reset.css";
import "../styles/typography.css";
import "../styles/layout.css";
import "../styles/quran-verse.css";

interface Props {
	title: string;
	description?: string;
	ogImage?: string;
	/** Alt text for the OG/Twitter image. Defaults to the page title on essays and
	 *  a site descriptor elsewhere; pass an explicit value when the share card shows
	 *  page-specific content (e.g. a city's prayer-time card). */
	ogImageAlt?: string;
	/** Single-URL LCP preload (non-responsive images). */
	preloadImage?: string;
	/** Responsive LCP preload — the exact `srcset`/`sizes` the page's `<Image>`
	 *  emits, so the browser preloads the same candidate it will paint. */
	preloadImageSrcset?: string;
	preloadImageSizes?: string;
	/** MIME type of the preloaded candidate (e.g. "image/avif"), so the preload
	 *  matches the right `<source>` in the painted `<picture>`. */
	preloadImageType?: string;
	/** Preload Amiri Quran on pages that always paint Arabic (homepage daily
	 *  verse, essays) — kills the font-swap restyle of the verses. ~45 kB once,
	 *  cached site-wide. */
	preloadArabicFont?: boolean;
	articleMeta?: {
		publishedAt: string;
		/** Genuine later revision only — emits dateModified (freshness signal). */
		updatedAt?: string;
		wordCount: number;
		description: string;
		slug: string;
		/** Sources cited by the essay (derived from Quran footnotes) → schema citation. */
		citations?: { name: string; url: string }[];
	};
	jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}

const {
	title,
	description = "Essäer om islamisk intellektuell tradition och svenskt kulturarv.",
	ogImage,
	ogImageAlt,
	preloadImage,
	preloadImageSrcset,
	preloadImageSizes,
	preloadImageType,
	preloadArabicFont = false,
	articleMeta,
	jsonLd,
} = Astro.props;
const canonicalUrl = new URL(Astro.url.pathname, Astro.site);
const ogImageUrl = ogImage
	? new URL(ogImage, Astro.site).href
	: new URL("/og-default.png", Astro.site).href;
const pageTitle = title.replace(/ — islam\.se$/, "").replace(/^islam\.se — /, "");
const resolvedOgImageAlt =
	ogImageAlt ??
	(articleMeta ? pageTitle : "islam.se — essäer om islamisk intellektuell tradition och svenskt kulturarv");

// Every page carries the canonical Organization + WebSite entity nodes; page-
// and article-level blocks reference them by @id so all claims merge onto one
// well-connected entity — the strongest AI-citation signal.
const jsonLdBlocks: Record<string, unknown>[] = [organization(), webSite()];

if (jsonLd) {
	jsonLdBlocks.push(...(Array.isArray(jsonLd) ? jsonLd : [jsonLd]));
}

if (articleMeta) {
	jsonLdBlocks.push({
		"@context": "https://schema.org",
		"@type": "Article",
		headline: title.replace(/ — islam\.se$/, ""),
		description: articleMeta.description,
		datePublished: articleMeta.publishedAt,
		// Falls back to publishedAt so every essay carries a dateModified.
		dateModified: articleMeta.updatedAt ?? articleMeta.publishedAt,
		wordCount: articleMeta.wordCount,
		inLanguage: "sv",
		url: canonicalUrl.href,
		...(ogImage ? { image: new URL(ogImage, Astro.site).href } : {}),
		author: { "@id": ORG_ID },
		publisher: { "@id": ORG_ID },
		...(articleMeta.citations && articleMeta.citations.length > 0
			? {
					citation: articleMeta.citations.map((c) => ({
						"@type": "CreativeWork",
						name: c.name,
						url: c.url,
					})),
				}
			: {}),
	});
	jsonLdBlocks.push(
		breadcrumbList([
			{ name: "Hem", url: "/" },
			{ name: "Essäer", url: "/essaer" },
			{ name: pageTitle, url: canonicalUrl.href },
		]),
	);
}
---

<!doctype html>
<html lang="sv">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover, interactive-widget=resizes-content" />
		<meta name="color-scheme" content="light dark" />
		<meta name="theme-color" content="#faf8f5" media="(prefers-color-scheme: light)" />
		<meta name="theme-color" content="#1a1917" media="(prefers-color-scheme: dark)" />

		<!-- Google Analytics 4 (gtag). Manual page_view on astro:page-load so the
		     View-Transitions (SPA-style) navigations are counted; send_page_view:false
		     prevents a double count on the initial load. -->
		<script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-TTJ71Z0QKS"></script>
		<script is:inline>
			window.dataLayer = window.dataLayer || [];
			function gtag() { dataLayer.push(arguments); }
			gtag("js", new Date());
			gtag("config", "G-TTJ71Z0QKS", { send_page_view: false });
			document.addEventListener("astro:page-load", () => {
				gtag("event", "page_view", {
					page_title: document.title,
					page_location: location.href,
					page_path: location.pathname + location.search,
				});
			});
		</script>

		<link rel="icon" href="/favicon.svg" type="image/svg+xml" />
		<link rel="apple-touch-icon" href="/apple-touch-icon.png" />
		<link rel="manifest" href="/manifest.webmanifest" />
		<meta name="apple-mobile-web-app-capable" content="yes" />
		<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
		{/* Native iOS Smart App Banner — a subtle, dismissible nudge in Safari on every
		    page; the strong in-page promo stays on the prayer surfaces. */}
		<meta name="apple-itunes-app" content={`app-id=${APP_STORE_ID}`} />
		<Font cssVariable="--font-body" preload />
		<Font cssVariable="--font-heading" preload />
		{preloadArabicFont ? <Font cssVariable="--font-arabic" preload /> : <Font cssVariable="--font-arabic" />}
		{preloadImageSrcset ? (
			<link rel="preload" as="image" type={preloadImageType} imagesrcset={preloadImageSrcset} imagesizes={preloadImageSizes} fetchpriority="high" />
		) : preloadImage ? (
			<link rel="preload" as="image" href={preloadImage} fetchpriority="high" />
		) : null}
		<title>{title}</title>
		<meta name="description" content={description} />
		<link rel="canonical" href={canonicalUrl.href} />

		<!-- Open Graph -->
		<meta property="og:type" content={articleMeta ? "article" : "website"} />
		<meta property="og:title" content={pageTitle} />
		<meta property="og:description" content={description} />
		<meta property="og:url" content={canonicalUrl.href} />
		<meta property="og:site_name" content="islam.se" />
		<meta property="og:locale" content="sv_SE" />
		<meta property="og:image" content={ogImageUrl} />
		<meta property="og:image:width" content="1200" />
		<meta property="og:image:height" content="630" />
		<meta property="og:image:alt" content={resolvedOgImageAlt} />
		{articleMeta && <meta property="article:published_time" content={articleMeta.publishedAt} />}
		{articleMeta && <meta property="article:author" content="https://islam.se" />}

		<!-- Twitter -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={pageTitle} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={ogImageUrl} />
		<meta name="twitter:image:alt" content={resolvedOgImageAlt} />

		<!-- RSS -->
		<link rel="alternate" type="application/rss+xml" title="islam.se" href="/rss.xml" />
		<link rel="alternate" type="application/rss+xml" title="islam.se podcast" href="/podcast.xml" />

		<!-- AI / LLM discovery: curated site map + a clean-markdown copy of each essay -->
		<link rel="alternate" type="text/plain" title="llms.txt" href="/llms.txt" />
		{articleMeta && <link rel="alternate" type="text/markdown" title={pageTitle} href={`/${articleMeta.slug}.md`} />}

		<!-- View Transitions -->
		<ClientRouter />

		<!-- JSON-LD -->
		{jsonLdBlocks.map((block) => (
			<script is:inline type="application/ld+json" set:html={JSON.stringify(block)} />
		))}
	</head>
	<body>
		<a href="#main" class="skip-link">Hoppa till innehåll</a>
		{/* Reading progress is an essay metaphor — browse pages get no bar. */}
		{articleMeta && <div class="reading-progress" aria-hidden="true" data-slug={articleMeta.slug} />}
		<Header />
		<slot />
		<Footer />
		<div class="fixed-actions">
			{articleMeta && (
				<button class="share-btn label" type="button" aria-label="Dela essä" data-title={pageTitle} data-url={canonicalUrl.href}>Dela</button>
			)}
			<button class="btn-circle back-to-top" type="button" aria-label="Tillbaka till toppen">
				<svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
					<path d="M5 12.5l5-5 5 5" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round" />
				</svg>
			</button>
		</div>
		<script>
			document.addEventListener("astro:page-load", () => {
				const actions = document.querySelector<HTMLElement>(".fixed-actions");
				const btn = document.querySelector<HTMLButtonElement>(".back-to-top");
				if (!actions || !btn) return;
				const ctrl = new AbortController();
				let shown = false;
				const progressBar = document.querySelector<HTMLElement>(".reading-progress");
				const slug = progressBar?.dataset.slug;
				let lastSave = 0;
				const shareBtn = document.querySelector<HTMLButtonElement>(".share-btn");

				function scrollPct() {
					const scrollable = document.documentElement.scrollHeight - window.innerHeight;
					return scrollable > 0 ? Math.min(1, Math.max(0, window.scrollY / scrollable)) : 0;
				}

				const saveProgress = () => {
					if (!slug) return;
					const pct = scrollPct();
					const prev = +(localStorage.getItem(`rp:${slug}`) || 0);
					if (pct > prev) localStorage.setItem(`rp:${slug}`, pct.toFixed(3));
					// Stamp the last time this essay was actively read, so the homepage
					// can offer the *most recent* part-read essay to resume (rp is a max,
					// not a timeline). Only once the reader is genuinely into the piece.
					if (pct > 0.02) localStorage.setItem(`rt:${slug}`, String(Date.now()));
				};

				window.addEventListener("scroll", () => {
					const shouldShow = window.scrollY > window.innerHeight;
					if (shouldShow !== shown) {
						shown = shouldShow;
						actions.classList.toggle("visible", shown);
					}
					if (progressBar) {
						const pct = scrollPct();
						progressBar.style.width = `${pct * 100}%`;
						if (slug && Date.now() - lastSave > 500) {
							lastSave = Date.now();
							saveProgress();
						}
					}
				}, { passive: true, signal: ctrl.signal });

				btn.addEventListener("click", () => {
					const reduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
					window.scrollTo({ top: 0, behavior: reduced ? "instant" : "smooth" });
				}, { signal: ctrl.signal });

				if (shareBtn) {
					shareBtn.addEventListener("click", async () => {
						const title = shareBtn.dataset.title || "";
						const url = shareBtn.dataset.url || location.href;
						if (navigator.share) {
							try { await navigator.share({ title, url }); } catch {}
						} else {
							await navigator.clipboard.writeText(url);
							shareBtn.textContent = "Kopierad";
							setTimeout(() => { shareBtn.textContent = "Dela"; }, 2000);
						}
					}, { signal: ctrl.signal });
				}

				document.addEventListener("visibilitychange", () => {
					if (document.visibilityState === "hidden") saveProgress();
				}, { signal: ctrl.signal });

				document.addEventListener("astro:before-swap", () => {
					saveProgress();
					ctrl.abort();
				}, { once: true });
			});
		</script>
		<FloatingPlayer />
		<SearchOverlay />
	</body>
</html>
