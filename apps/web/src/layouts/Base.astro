---
import { ClientRouter } from "astro:transitions";
import Header from "../components/Header.astro";
import "../styles/tokens.css";
import "../styles/reset.css";
import "../styles/typography.css";
import "../styles/layout.css";

interface Props {
	title: string;
	description?: string;
	hero?: boolean;
	ogImage?: string;
	articleMeta?: {
		publishedAt: string;
		wordCount: number;
		description: string;
		slug: string;
	};
	jsonLd?: Record<string, unknown>;
}

const {
	title,
	description = "Essäer om islamisk intellektuell tradition och svenskt kulturarv.",
	hero = false,
	ogImage,
	articleMeta,
	jsonLd,
} = Astro.props;
const canonicalUrl = new URL(Astro.url.pathname, Astro.site);
const ogImageUrl = ogImage
	? new URL(ogImage, Astro.site).href
	: new URL("/og-default.png", Astro.site).href;

const jsonLdBlocks: Record<string, unknown>[] = [];

if (jsonLd) {
	jsonLdBlocks.push(jsonLd);
}

if (articleMeta) {
	jsonLdBlocks.push({
		"@context": "https://schema.org",
		"@type": "Article",
		headline: title.replace(/ — islam\.se$/, ""),
		description: articleMeta.description,
		datePublished: articleMeta.publishedAt,
		wordCount: articleMeta.wordCount,
		inLanguage: "sv",
		url: canonicalUrl.href,
		author: {
			"@type": "Organization",
			name: "islam.se",
			url: "https://islam.se",
		},
		publisher: {
			"@type": "Organization",
			name: "islam.se",
			url: "https://islam.se",
		},
	});
	jsonLdBlocks.push({
		"@context": "https://schema.org",
		"@type": "BreadcrumbList",
		itemListElement: [
			{
				"@type": "ListItem",
				position: 1,
				name: "Hem",
				item: "https://islam.se",
			},
			{
				"@type": "ListItem",
				position: 2,
				name: "Essäer",
				item: "https://islam.se/essaer",
			},
			{
				"@type": "ListItem",
				position: 3,
				name: title.replace(/ — islam\.se$/, ""),
				item: canonicalUrl.href,
			},
		],
	});
}
---

<!doctype html>
<html lang="sv">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover, interactive-widget=resizes-content" />
		<meta name="color-scheme" content="light dark" />
		<meta name="theme-color" content="#faf8f5" media="(prefers-color-scheme: light)" />
		<meta name="theme-color" content="#1a1917" media="(prefers-color-scheme: dark)" />
		<link rel="icon" href="/favicon.svg" type="image/svg+xml" />
		<link rel="manifest" href="/manifest.webmanifest" />
		<meta name="apple-mobile-web-app-capable" content="yes" />
		<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
		<link rel="preload" href="/fonts/literata-roman.woff2" as="font" type="font/woff2" crossorigin />
		<link rel="prefetch" href="/fonts/literata-italic.woff2" as="font" type="font/woff2" crossorigin />
		<title>{title}</title>
		<meta name="description" content={description} />
		<link rel="canonical" href={canonicalUrl.href} />

		<!-- Open Graph -->
		<meta property="og:type" content={articleMeta ? "article" : "website"} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:url" content={canonicalUrl.href} />
		<meta property="og:site_name" content="islam.se" />
		<meta property="og:locale" content="sv_SE" />
		<meta property="og:image" content={ogImageUrl} />
		{articleMeta && <meta property="article:published_time" content={articleMeta.publishedAt} />}
		{articleMeta && <meta property="article:author" content="https://islam.se" />}

		<!-- Twitter -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={ogImageUrl} />

		<!-- RSS -->
		<link rel="alternate" type="application/rss+xml" title="islam.se" href="/rss.xml" />

		<!-- View Transitions -->
		<ClientRouter />

		<!-- JSON-LD -->
		{jsonLdBlocks.map((block) => (
			<script type="application/ld+json" set:html={JSON.stringify(block)} />
		))}
	</head>
	<body>
		<Header hero={hero} />
		<slot />
	</body>
</html>
