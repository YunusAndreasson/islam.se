---
import { getImage, Picture } from "astro:assets";
import type { Article } from "../lib/articles";

interface Props {
	article: Article;
	widths?: number[];
	sizes?: string;
	loading?: "eager" | "lazy";
	fetchpriority?: "high" | "low" | "auto";
	class?: string;
}

const {
	article,
	widths = [400, 800, 1200],
	sizes = "(max-width: 768px) 100vw, 50vw",
	loading = "lazy",
	fetchpriority = "auto",
	class: className,
} = Astro.props;

const hero = article.heroImage;
// Only use a mobile-specific crop when it is landscape-ish. Every card layout
// (feature 3:2, recent 16:9, ämne lead 3:2) renders into a landscape box with
// object-fit: cover; some -mobile assets are authored as 2:3 portrait, and a
// portrait source forced into a landscape box shows a thin, zoomed middle slice
// (reads as a wrong/distorted crop on phones). A portrait crop is dropped so the
// image falls back to the landscape hero, which cover-crops cleanly to any box.
const mobileCandidate = article.mobileHeroImage;
const mobile =
	mobileCandidate && mobileCandidate.width >= mobileCandidate.height ? mobileCandidate : undefined;

// AVIF in production (~⅓ the bytes of webp on the LCP hero); webp-only in dev,
// because Astro's dev image endpoint serves AVIF with a `image/heif` content-type
// that Firefox refuses to decode (Chromium sniffs the bytes and copes). Production
// builds emit real `.avif` files with the correct type, so the win lands where it
// matters and local previews stay un-broken in every browser. webp is the universal
// fallback in both.
const FORMATS = import.meta.env.DEV ? (["webp"] as const) : (["avif", "webp"] as const);
const MIME: Record<string, string> = { avif: "image/avif", webp: "image/webp" };
const MOBILE_WIDTHS = [360, 540, 720, 1080];

// The rare art-directed path (a few essays ship a landscape -mobile crop) hand-rolls
// one <source> per format for both the portrait-phone crop and the desktop hero.
const mobileSrcs: { type: string; srcset: string }[] = [];
const desktopSrcs: { type: string; srcset: string }[] = [];
let fallbackSrc = "";
if (mobile && hero) {
	for (const f of FORMATS) {
		mobileSrcs.push({
			type: MIME[f],
			srcset: (await getImage({ src: mobile, widths: MOBILE_WIDTHS, sizes: "100vw", format: f })).srcSet.attribute,
		});
		desktopSrcs.push({
			type: MIME[f],
			srcset: (await getImage({ src: hero, widths, sizes, format: f })).srcSet.attribute,
		});
	}
	fallbackSrc = (await getImage({ src: hero, widths, sizes, format: "webp" })).src;
}
---

{hero && (
	mobile ? (
		<picture>
			{mobileSrcs.map((s) => (
				<source media="(max-width: 768px) and (orientation: portrait)" type={s.type} srcset={s.srcset} sizes="100vw" />
			))}
			{desktopSrcs.map((s) => <source type={s.type} srcset={s.srcset} sizes={sizes} />)}
			<img
				src={fallbackSrc}
				width={hero.width}
				height={hero.height}
				alt={article.title}
				loading={loading}
				fetchpriority={fetchpriority}
				decoding="async"
				class={className}
			/>
		</picture>
	) : (
		<Picture
			src={hero}
			formats={[...FORMATS]}
			fallbackFormat="webp"
			alt={article.title}
			widths={widths}
			sizes={sizes}
			loading={loading}
			fetchpriority={fetchpriority}
			decoding="async"
			class={className}
		/>
	)
)}

<style>
	/* Base tonal wash — site-wide art direction for every essay photo.
	   The source files span very different colour temperatures; this pulls them
	   all toward the warm 4-colour palette so the page reads as one curated set,
	   not a gallery of stock rectangles. Source images are untouched (CSS only).

	   This is scoped to the <img> EssayImage itself renders, so it travels to
	   every usage (feature / recent / ämnen) and does NOT collide with the
	   wrappers' :global(img) sizing rules. Wrappers ease the filter back toward
	   full colour on hover (the bloom). Tuned against the live render. */
	img {
		filter: saturate(0.72) contrast(1.04) brightness(0.98) sepia(0.12);
		transition:
			filter 0.6s cubic-bezier(0.2, 0, 0.1, 1),
			scale 0.6s cubic-bezier(0.2, 0, 0.1, 1);
	}

	@media (prefers-reduced-motion: reduce) {
		img {
			/* Deliberate survivor: a filter cross-fade is not motion. !important
			   beats the global kill-switch in typography.css. */
			transition: filter 0.6s ease;
			transition-duration: 0.6s !important;
		}
	}
</style>
