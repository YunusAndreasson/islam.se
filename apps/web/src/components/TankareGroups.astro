---
import { type Tankare, getTankare } from "../lib/tankare";
import HomeHead from "./HomeHead.astro";

// `limit` turns the full directory into a balanced homepage glimpse: the most-
// present voices on each side, capped to equal-length columns so the facing
// composition reads evenly (§7.8). The /tankare index renders it unbounded.
interface Props {
	limit?: number;
}
const { limit } = Astro.props;

const thinkers = await getTankare();
const sunni = thinkers.filter((t) => t.tradition === "sunni");
const western = thinkers.filter((t) => t.tradition === "western");

let groups = [
	{ label: "Den klassiska islamiska traditionen", items: sunni },
	{ label: "Svenska och västerländska röster", items: western },
];

if (limit) {
	// Cap to the shortest column so the two sides stay equal, and lead with the
	// voices the essays return to most. Leaves the unbounded directory untouched.
	const cap = Math.min(limit, ...groups.map((g) => g.items.length));
	const byEssays = (a: Tankare, b: Tankare) => b.essays.length - a.essays.length;
	groups = groups.map((g) => ({ ...g, items: [...g.items].sort(byEssays).slice(0, cap) }));
}
---

<!-- On the homepage (limit set) this owns its movement: a head-row with the
	 kicker + an "Alla tänkare" link, matching Trådar. On the /tankare index
	 (no limit) it renders just the bare columns the page frames with its own h1. -->
<section class:list={["tankare-home", { "home-movement": limit }]} aria-labelledby={limit ? "tankare-home-kicker" : null}>
	{limit && <HomeHead label="Tänkare" id="tankare-home-kicker" href="/tankare" linkLabel="Alla tänkare" />}
	<div class="tankare-groups">
		{groups.map((group) => (
			<div class="tankare-group">
				<p class="label tankare-group-label">{group.label}</p>
				<ul class="tankare-list">
					{group.items.map((t) => (
						<li class="tankare-row">
							<a href={`/tankare/${t.slug}`} data-astro-prefetch="viewport">
								<span class="tankare-name">{t.name}</span>
								<span class="tankare-count" aria-label={`${t.essays.length} essäer`}>{t.essays.length}</span>
							</a>
						</li>
					))}
				</ul>
			</div>
		))}
	</div>
</section>

<style>
	/* Two facing columns — the composition itself shows the dialogue that
	   defines the site, without declaring it (§7.8). A hairline marks the axis. */
	.tankare-groups {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: clamp(2rem, 6vw, 5rem);
		margin-top: var(--space-unit);
		position: relative;
	}

	@media (width > 600px) {
		.tankare-groups::before {
			content: "";
			position: absolute;
			top: 0;
			bottom: 0;
			left: 50%;
			width: 1px;
			background: var(--color-divider);
		}
	}

	.tankare-group-label {
		margin-bottom: var(--space-half);
	}

	.tankare-list {
		margin: 0;
		padding: 0;
		list-style: none;
	}

	/* No per-row rules — the vertical axis divider + row spacing carry the list;
	   the count on the right gives each row its own anchor. */
	.tankare-row a {
		display: flex;
		align-items: baseline;
		justify-content: space-between;
		gap: 0.75rem;
		padding-block: 0.5rem;
		text-decoration: none;
		color: inherit;

		&:hover .tankare-name {
			text-decoration: underline;
			text-underline-offset: 0.12em;
		}

		&:focus-visible {
			outline: 2px solid var(--color-accent);
			outline-offset: 2px;
		}
	}

	.tankare-name {
		font-family: var(--font-heading);
		font-size: 1.0625rem;
		font-weight: 500;
		color: var(--color-accent);
		letter-spacing: 0;
	}

	.tankare-count {
		font-family: var(--font-heading);
		font-variant-numeric: lining-nums tabular-nums;
		font-size: 0.8rem;
		color: var(--color-muted);
		flex-shrink: 0;
	}

	/* Keep the two facing columns + axis hairline through tablet widths; only fold
	   to a single column on phones (≤600px), matching the trådar grid below. */
	@media (width <= 600px) {
		.tankare-groups {
			grid-template-columns: 1fr;
			gap: var(--space-unit);
		}
	}
</style>
