---
import { getCollection } from "astro:content";

// `limit` turns the full directory into a balanced homepage glimpse: the most-
// present voices on each side, capped to equal-length columns so the facing
// composition reads evenly (§7.8). The /tankare index renders it unbounded.
interface Props {
	limit?: number;
}
const { limit } = Astro.props;

const thinkers = await getCollection("tankare");
const sunni = thinkers.filter((t) => t.data.tradition === "sunni");
const western = thinkers.filter((t) => t.data.tradition === "western");

let groups = [
	{ label: "Den klassiska islamiska traditionen", items: sunni },
	{ label: "Svenska och västerländska röster", items: western },
];

if (limit) {
	// Cap to the shortest column so the two sides stay equal, and lead with the
	// voices the essays return to most. Leaves the unbounded directory untouched.
	const cap = Math.min(limit, ...groups.map((g) => g.items.length));
	const byEssays = (a: (typeof sunni)[number], b: (typeof sunni)[number]) =>
		b.data.essays.length - a.data.essays.length;
	groups = groups.map((g) => ({ ...g, items: [...g.items].sort(byEssays).slice(0, cap) }));
}
---

<div class="tankare-groups">
	{groups.map((group) => (
		<div class="tankare-group">
			<p class="label tankare-group-label">{group.label}</p>
			<ul class="tankare-list">
				{group.items.map((t) => (
					<li class="tankare-row">
						<a href={`/tankare/${t.data.slug}`} data-astro-prefetch="viewport">
							<span class="tankare-name">{t.data.name}</span>
							<span class="tankare-count" aria-label={`${t.data.essays.length} essäer`}>{t.data.essays.length}</span>
						</a>
					</li>
				))}
			</ul>
		</div>
	))}
</div>

<style>
	/* Two facing columns — the composition itself shows the dialogue that
	   defines the site, without declaring it (§7.8). A hairline marks the axis. */
	.tankare-groups {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: clamp(2rem, 6vw, 5rem);
		margin-top: var(--space-unit);
		position: relative;
	}

	@media (width > 768px) {
		.tankare-groups::before {
			content: "";
			position: absolute;
			top: 0;
			bottom: 0;
			left: 50%;
			width: 1px;
			background: var(--color-divider);
		}
	}

	.tankare-group-label {
		margin-bottom: var(--space-half);
	}

	.tankare-list {
		margin: 0;
		padding: 0;
		list-style: none;
	}

	/* No per-row rules — the vertical axis divider + row spacing carry the list;
	   the count on the right gives each row its own anchor. */
	.tankare-row a {
		display: flex;
		align-items: baseline;
		justify-content: space-between;
		gap: 0.75rem;
		padding-block: 0.5rem;
		text-decoration: none;
		color: inherit;

		&:hover .tankare-name {
			text-decoration: underline;
			text-underline-offset: 0.12em;
		}

		&:focus-visible {
			outline: 2px solid var(--color-accent);
			outline-offset: 2px;
		}
	}

	.tankare-name {
		font-family: var(--font-heading);
		font-size: 1.0625rem;
		font-weight: 500;
		color: var(--color-accent);
		letter-spacing: -0.005em;
	}

	.tankare-count {
		font-family: var(--font-heading);
		font-variant-numeric: lining-nums tabular-nums;
		font-size: 0.8rem;
		color: var(--color-muted);
		flex-shrink: 0;
	}

	@media (width <= 768px) {
		.tankare-groups {
			grid-template-columns: 1fr;
			gap: var(--space-unit);
		}
	}
</style>
