---
interface Props {
	src: string;
	title?: string;
	artwork?: string;
}

const { src, title, artwork } = Astro.props;
---

<button
	class="audio-trigger"
	type="button"
	data-audio-src={src}
	data-audio-title={title}
	data-audio-artwork={artwork}
	aria-label={`Lyssna på ${title || 'essän'}`}
>
	<svg class="audio-trigger-icon-play" width="14" height="14" viewBox="0 0 18 18" fill="currentColor" aria-hidden="true">
		<path d="M4 2.5v13l11-6.5z" />
	</svg>
	<svg class="audio-trigger-icon-pause" width="14" height="14" viewBox="0 0 18 18" fill="currentColor" aria-hidden="true" style="display:none">
		<rect x="4" y="2" width="3.5" height="14" rx="0.5" />
		<rect x="10.5" y="2" width="3.5" height="14" rx="0.5" />
	</svg>
	Lyssna
</button>

<style>
	.audio-trigger {
		display: inline-flex;
		align-items: center;
		gap: 0.4em;
		padding: 0.4rem 0.875rem;
		border: 1px solid var(--color-divider);
		border-radius: 1.25rem;
		background: transparent;
		color: var(--color-accent);
		cursor: pointer;
		font-family: var(--font-heading);
		font-size: 0.862rem;
		font-weight: 500;
		letter-spacing: 0.06em;
		text-transform: uppercase;
		font-feature-settings: "case";
		transition: border-color 0.15s;
		margin-bottom: var(--space-unit);
	}

	.audio-trigger:hover {
		border-color: var(--color-accent);
	}

	.audio-trigger[data-playing] {
		border-color: var(--color-accent);
	}

	.audio-trigger[data-playing] .audio-trigger-icon-play {
		display: none;
	}

	.audio-trigger[data-playing] .audio-trigger-icon-pause {
		display: inline;
	}
</style>

<script>
	document.addEventListener("astro:page-load", () => {
		for (const btn of document.querySelectorAll<HTMLButtonElement>(".audio-trigger")) {
			btn.addEventListener("click", () => {
				document.dispatchEvent(new CustomEvent("floating-player:play", {
					detail: {
						src: btn.dataset.audioSrc,
						title: btn.dataset.audioTitle,
						artwork: btn.dataset.audioArtwork,
					}
				}));
			});
		}
	});
</script>
