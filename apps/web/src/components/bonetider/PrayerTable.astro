---
import {
	computePrayerTimes,
	dateForStockholmDay,
	formatTime,
	PRAYER_LABELS,
	PRAYER_ORDER,
	stockholmDateParts,
	TIME_ZONE,
} from "../../lib/bonetider/prayer-times";
import { DEFAULT_SETTINGS } from "../../lib/bonetider/settings";

interface Props {
	location: { name: string; latitude: number; longitude: number };
}
const { location } = Astro.props;

// The whole current month, computed at build time with the default (MWL) method – real,
// indexable prayer-time content, correct for the explicit dates shown. The interactive
// field above reflects the visitor's own settings; this table is the SEO/no-JS baseline.
const now = new Date();
const { year, month, day: todayD } = stockholmDateParts(now);
const fmt = (opts: Intl.DateTimeFormatOptions, d: Date) =>
	new Intl.DateTimeFormat("sv-SE", { timeZone: TIME_ZONE, ...opts }).format(d);
const monthLabel = `${fmt({ month: "long" }, new Date(Date.UTC(year, month, 15, 12)))} ${year}`;
const daysInMonth = new Date(year, month + 1, 0).getDate();

const rows = Array.from({ length: daysInMonth }, (_, i) => {
	const d = i + 1;
	const date = dateForStockholmDay(year, month, d);
	const t = computePrayerTimes(location, date, DEFAULT_SETTINGS);
	return {
		d,
		weekday: fmt({ weekday: "short" }, date),
		iso: `${year}-${String(month + 1).padStart(2, "0")}-${String(d).padStart(2, "0")}`,
		times: PRAYER_ORDER.map((k) => formatTime(t[k])),
	};
});
---

<figure
	class="bt-table-wrap"
	data-name={location.name}
	data-lat={location.latitude}
	data-lon={location.longitude}
>
	<figcaption class="bt-table-cap" data-bt-table-caption>
		Bönetider i {location.name} – {monthLabel}
	</figcaption>
	<div class="bt-scroll">
		<table class="bt-table">
			<thead>
				<tr>
					<th scope="col">Dag</th>
					{PRAYER_ORDER.map((k) => <th scope="col">{PRAYER_LABELS[k]}</th>)}
				</tr>
			</thead>
			<tbody data-bt-table-body>
				{rows.map((r) => (
					<tr data-day={r.d} class:list={{ "is-today": r.d === todayD }}>
						<th scope="row">
							<time datetime={r.iso}>{r.weekday} {r.d}</time>
						</th>
						{r.times.map((time) => <td>{time}</td>)}
					</tr>
				))}
			</tbody>
		</table>
	</div>
	<p class="bt-table-note">
		Tiderna beräknas med Muslim World League (Fajr 18°, Isha 17°) i tidszonen Europe/Stockholm.
		Ändra metod och madhab i inställningarna ovan – kartan och dagens tider uppdateras direkt.
	</p>
</figure>

<style>
	.bt-table-wrap {
		margin: var(--space-unit) 0 0;
	}

	.bt-table-cap {
		font-family: var(--font-heading);
		font-weight: 600;
		font-size: 1.0625rem;
		color: var(--color-accent);
		margin-bottom: var(--space-half);
	}

	.bt-scroll {
		overflow-x: auto;
		border: 1px solid var(--color-divider);
		border-radius: 10px;
	}

	.bt-table {
		width: 100%;
		border-collapse: collapse;
		font-family: var(--font-body);
		font-variant-numeric: lining-nums tabular-nums;
		font-size: 0.875rem;
	}

	.bt-table th,
	.bt-table td {
		padding: 0.4rem 0.6rem;
		text-align: end;
		white-space: nowrap;
	}

	.bt-table thead th {
		position: sticky;
		top: 0;
		background: var(--color-bg);
		color: var(--color-muted);
		font-weight: 600;
		font-size: 0.8125rem;
		border-bottom: 1px solid var(--color-divider);
	}

	.bt-table tbody th[scope="row"] {
		text-align: start;
		font-weight: 500;
		color: var(--color-text);
		text-transform: capitalize;
	}

	.bt-table tbody td {
		color: var(--color-text);
	}

	.bt-table tbody tr:not(:last-child) th,
	.bt-table tbody tr:not(:last-child) td {
		border-bottom: 1px solid color-mix(in srgb, var(--color-divider), transparent 40%);
	}

	.bt-table tbody tr.is-today th,
	.bt-table tbody tr.is-today td {
		background: color-mix(in srgb, var(--color-warm), transparent 82%);
		color: var(--color-accent);
	}

	.bt-table-note {
		font-family: var(--font-body);
		font-size: 0.8125rem;
		line-height: 1.5;
		color: var(--color-muted);
		margin: var(--space-half) 0 0;
		max-width: 38rem;
	}
</style>

<script>
	import {
		computePrayerTimes,
		dateForStockholmDay,
		formatTime,
		PRAYER_ORDER,
		stockholmDateParts,
		TIME_ZONE,
	} from "../../lib/bonetider/prayer-times";
	import { DEFAULT_SETTINGS } from "../../lib/bonetider/settings";

	const fmt = (opts: Intl.DateTimeFormatOptions, d: Date): string =>
		new Intl.DateTimeFormat("sv-SE", { timeZone: TIME_ZONE, ...opts }).format(d);

	let renderedMonthKey = "";
	let refreshTimer: number | undefined;

	function renderTable(fig: HTMLElement): void {
		const tbody = fig.querySelector<HTMLElement>("[data-bt-table-body]");
		if (!tbody) return;
		const name = fig.dataset.name ?? "";
		const latitude = Number(fig.dataset.lat);
		const longitude = Number(fig.dataset.lon);
		if (!Number.isFinite(latitude) || !Number.isFinite(longitude)) return;

		const { year, month, day: todayD } = stockholmDateParts(new Date());
		const daysInMonth = new Date(year, month + 1, 0).getDate();
		const caption = fig.querySelector<HTMLElement>("[data-bt-table-caption]");
		if (caption) {
			const monthLabel = `${fmt({ month: "long" }, new Date(Date.UTC(year, month, 15, 12)))} ${year}`;
			caption.textContent = `Bönetider i ${name} – ${monthLabel}`;
		}

		tbody.replaceChildren(
			...Array.from({ length: daysInMonth }, (_, i) => {
				const d = i + 1;
				const date = dateForStockholmDay(year, month, d);
				const times = computePrayerTimes({ latitude, longitude }, date, DEFAULT_SETTINGS);
				const tr = document.createElement("tr");
				tr.dataset.day = String(d);
				tr.classList.toggle("is-today", d === todayD);

				const th = document.createElement("th");
				th.scope = "row";
				const time = document.createElement("time");
				time.dateTime = `${year}-${String(month + 1).padStart(2, "0")}-${String(d).padStart(2, "0")}`;
				time.textContent = `${fmt({ weekday: "short" }, new Date(Date.UTC(year, month, d, 12)))} ${d}`;
				th.append(time);
				tr.append(th);

				for (const key of PRAYER_ORDER) {
					const td = document.createElement("td");
					td.textContent = formatTime(times[key]);
					tr.append(td);
				}
				return tr;
			}),
		);
	}

	function renderAllTables(): void {
		const { year, month, day } = stockholmDateParts(new Date());
		const monthKey = `${year}-${month}-${day}`;
		if (monthKey === renderedMonthKey) return;
		renderedMonthKey = monthKey;
		for (const fig of document.querySelectorAll<HTMLElement>(".bt-table-wrap")) {
			renderTable(fig);
		}
	}

	document.addEventListener("astro:page-load", () => {
		renderedMonthKey = "";
		renderAllTables();
		if (refreshTimer === undefined) refreshTimer = window.setInterval(renderAllTables, 60000);
	});
</script>
