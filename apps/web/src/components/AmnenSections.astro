---
import { formatDate, getArticles, inlineMarkdown } from "../lib/articles";
import { amnenWithEssays } from "../lib/amnen";
import EssayImage from "./EssayImage.astro";

interface Props {
	/** Slugs whose hero image already appears higher on the page (the feature +
	    "Nyligen publicerat" rows). A topic never leads with one of these, so the
	    same picture never shows twice on the home page. */
	usedImageSlugs?: Set<string>;
}

const { usedImageSlugs = new Set<string>() } = Astro.props;

const articles = await getArticles();
const groups = amnenWithEssays(articles);

// How many essays each ämne shows on the home page. The full set lives on the
// topic page (/amnen/slug); a topic with more than this gets an "Alla N essäer"
// link. Seven balances the image-led layout: one featured essay + a clean two-row
// 3-column grid of the rest (1 + 6), with no ragged trailing row.
const PER_AMNE = 7;

// A topic leads with a picture whenever it has a hero essay whose image hasn't
// already been spent higher on the page. That essay floats to the front as the
// large lead; the rest follow as a quiet titles grid (including any essay whose
// image already appeared above — it shows as a title here, never a second copy
// of the same picture). A topic with no un-shown hero falls back to a plain
// titles grid rather than repeat an image.
type Treatment = "lead" | "text";

const sections = groups.map(({ amne, essays }) => {
	const lead = essays.find((e) => e.heroImage && !usedImageSlugs.has(e.slug));
	const treatment: Treatment = lead ? "lead" : "text";
	const picks = lead
		? [lead, ...essays.filter((e) => e.slug !== lead.slug)].slice(0, PER_AMNE)
		: essays.slice(0, PER_AMNE);
	return { amne, treatment, picks, total: essays.length };
});
---

<section class="amnen home-movement" aria-labelledby="amnen-kicker">
	<p class="label home-kicker" id="amnen-kicker">Ämnen</p>

	{sections.map(({ amne, treatment, picks, total }) => (
		<section class:list={["amne", `amne--${treatment}`]} aria-labelledby={`amne-${amne.slug}`}>
			<header class="amne-head">
				<div class="amne-head-row">
					<h3 class="amne-title" id={`amne-${amne.slug}`}>
						<a href={`/amnen/${amne.slug}`}>{amne.name}</a>
					</h3>
					{total > picks.length && (
						<a class="label amne-all arrow-link" href={`/amnen/${amne.slug}`}>Alla {total} essäer</a>
					)}
				</div>
				<p class="amne-framing">{amne.framing}</p>
			</header>

			{treatment === "lead" ? (
				<div class="amne-lead-block">
					<a class="amne-lead" href={`/${picks[0].slug}`} data-astro-prefetch="viewport">
						{picks[0].heroImage && (
							<div class="amne-lead-media media-frame">
								<EssayImage article={picks[0]} widths={[320, 480, 640]} sizes="(max-width: 768px) 100vw, 18rem" />
							</div>
						)}
						<div class="amne-lead-text">
							<h4 class="amne-essay-title amne-lead-title">{picks[0].title}</h4>
							{picks[0].description && (
								<p class="amne-lead-desc" set:html={inlineMarkdown(picks[0].description)} />
							)}
							<p class="label amne-essay-meta"><time datetime={picks[0].publishedAt}>{formatDate(picks[0].publishedAt)}</time></p>
						</div>
					</a>
					{picks.length > 1 && (
						<ul class="amne-more">
							{picks.slice(1).map((e) => (
								<li>
									<a href={`/${e.slug}`} data-astro-prefetch="viewport">
										<span class="amne-essay-title">{e.title}</span>
										<p class="label amne-essay-meta"><time datetime={e.publishedAt}>{formatDate(e.publishedAt)}</time></p>
									</a>
								</li>
							))}
						</ul>
					)}
				</div>
			) : (
				<ul class="amne-text-list">
					{picks.map((e) => (
						<li>
							<a href={`/${e.slug}`} data-astro-prefetch="viewport">
								<span class="amne-essay-title">{e.title}</span>
								<p class="label amne-essay-meta"><time datetime={e.publishedAt}>{formatDate(e.publishedAt)}</time></p>
							</a>
						</li>
					))}
				</ul>
			)}
		</section>
	))}
</section>

<style>
	/* Each topic is a bounded block: a full-width hairline with generous space on
	   both sides marks where one ämne ends and the next begins, so the seven topics
	   never run together. The rule is reserved for these between-topic boundaries —
	   inside a topic only whitespace separates the feature from its list — so the
	   boundary always reads stronger than anything within it. */
	.amne {
		margin-top: var(--space-phi2);
		padding-top: var(--space-phi);
		border-top: 1px solid var(--color-divider);
	}

	.amne:first-of-type {
		margin-top: var(--space-unit);
		padding-top: 0;
		border-top: none;
	}

	/* The topic header: name + an "Alla N essäer" overflow link on one baseline,
	   the framing line beneath. The name is one register below a feed essay title
	   (--step-1, not --step-2) so it reads as a topic doorway, not as another
	   essay competing in the river of headings. */
	.amne-head {
		margin-bottom: var(--space-unit);
	}

	.amne-head-row {
		display: flex;
		justify-content: space-between;
		align-items: baseline;
		gap: 1rem;
	}

	.amne-title {
		font-family: var(--font-heading);
		font-size: var(--step-1);
		font-weight: 600;
		letter-spacing: -0.015em;
		line-height: 1.2;
		margin: 0;
	}

	.amne-title a {
		color: var(--color-text);
		text-decoration: none;

		&:hover {
			text-decoration: underline;
			text-underline-offset: 0.15em;
		}
	}

	/* Quiet count + path into the full topic, shown only when more essays exist
	   than the home page lists. Mirrors the arrow convention of the Tänkare /
	   archive links. */
	.amne-all {
		flex-shrink: 0;
		text-decoration: none;
		white-space: nowrap;
		transition: color 0.15s ease;
		/* WCAG 2.5.8: this small-caps label is ~22px tall, which both undersizes it and
		   trips the spacing check against the adjacent (32px) topic-title link. Pad it
		   past 24px; the negative margin keeps the baseline head-row height unchanged. */
		display: inline-flex;
		align-items: center;
		padding-block: 0.3rem;
		margin-block: -0.3rem;
	}

	.amne-all:hover {
		color: var(--color-accent);
	}

	.amne-framing {
		font-family: var(--font-body);
		font-size: 1rem;
		line-height: 1.5;
		color: var(--color-muted);
		margin: 0.4rem 0 0;
		max-width: 40rem;
	}

	.amne-essay-title {
		display: block;
		font-family: var(--font-heading);
		font-weight: 600;
		line-height: 1.22;
		letter-spacing: -0.01em;
		color: var(--color-accent);
		text-wrap: balance;
	}

	.amne-essay-meta {
		margin: 0.3rem 0 0;
		font-size: 0.78rem;
		/* Plain --color-muted lands at ~4.24:1 here (just under AA) on this small date
		   label. Nudged toward --color-text — darker in light mode, lighter in dark — so
		   it clears 4.5:1 in both schemes while staying a quiet meta line. */
		color: color-mix(in srgb, var(--color-muted), var(--color-text) 22%);
	}

	.amnen a {
		text-decoration: none;
		color: inherit;

		&:focus-visible {
			outline: 2px solid var(--color-accent);
			outline-offset: 0.4rem;
			border-radius: 2px;
		}
	}

	.amnen a:hover .amne-essay-title,
	.amnen a:focus-visible .amne-essay-title {
		text-decoration: underline;
		text-underline-offset: 0.12em;
	}

	/* ---- lead: one featured essay as an image + its OWN title/excerpt side by
	   side (the picture is unmistakably paired with that one essay, never with the
	   list — this is the proven RecentEssays pairing), then the rest of the topic
	   as a separated titles grid below. ---- */
	.amne-lead {
		display: grid;
		grid-template-columns: 18rem 1fr;
		align-items: center;
		gap: clamp(1.5rem, 4vw, 3rem);
	}

	.amne-lead-media :global(img) {
		aspect-ratio: 3 / 2;
	}

	/* One step under the topic name so the lead essay sits inside the topic, not
	   alongside it. */
	.amne-lead-title {
		font-size: 1.3rem;
	}

	.amne-lead-desc {
		font-family: var(--font-body);
		font-size: 1rem;
		line-height: 1.5;
		color: color-mix(in srgb, var(--color-text) 72%, var(--color-muted));
		margin: 0.5rem 0 0;
		max-width: 34rem;
	}

	.amne-lead .amne-essay-meta {
		margin-top: 0.5rem;
	}

	/* The rest of the topic — a quiet titles grid (only the lead essay carries an
	   image), divided off below the feature so it never reads as a caption list
	   that drives the picture. */
	.amne-more {
		margin: var(--space-phi) 0 0;
		padding: 0;
		list-style: none;
		display: grid;
		/* auto-fit fills the row with as many ~16rem columns as fit: 3 on the 64rem
		   home canvas, 2 on a tablet, 1 on a phone — no breakpoint needed. The
		   min(100%, …) guard keeps the track from outgrowing a sub-16rem phone and
		   forcing a horizontal scroll. */
		grid-template-columns: repeat(auto-fit, minmax(min(100%, 16rem), 1fr));
		gap: var(--space-unit) clamp(1.25rem, 3vw, 2.5rem);
	}

	.amne-more .amne-essay-title {
		font-size: 1.0625rem;
	}

	/* ---- text: quiet titles, three columns flowing to two rows on desktop, two on
	   a tablet, one on a phone (see .amne-more for the auto-fit rationale) ---- */
	.amne-text-list {
		margin: 0;
		padding: 0;
		list-style: none;
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(min(100%, 16rem), 1fr));
		gap: var(--space-unit) clamp(1.25rem, 3vw, 2.5rem);
	}

	.amne-text-list .amne-essay-title {
		font-size: 1.125rem;
	}

	@media (width <= 768px) {
		/* The titles grids handle their own collapse via auto-fit; only the
		   image + text lead needs stacking, since its 18rem picture column can't
		   share a phone's width with the copy. */
		.amne-lead {
			grid-template-columns: 1fr;
			gap: var(--space-half);
		}
	}
</style>
