---
import { buildPaletteIndex } from "../lib/palette";

// The command palette is the site's only navigation surface. The full index
// (pages + ämnen + trådar + tänkare + essays) is built once and embedded as a
// JSON island — the corpus is small enough that no search infrastructure is
// warranted. Empty input shows a browse menu; typing filters and ranks.
const index = await buildPaletteIndex();
---

<div
	class="palette"
	id="search-overlay"
	hidden
	role="dialog"
	aria-modal="true"
	aria-label="Sök och bläddra"
	transition:persist
>
	<button class="palette-close" type="button" aria-label="Stäng">
		<svg width="18" height="18" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.25" stroke-linecap="round"><path d="M2 2l10 10M12 2 2 12" /></svg>
	</button>
	<div class="palette-inner">
		<div class="palette-field">
			<svg class="palette-field-icon" width="20" height="20" viewBox="0 0 18 18" fill="none" aria-hidden="true">
				<circle cx="8" cy="8" r="5.25" stroke="currentColor" stroke-width="1.25" />
				<path d="M12 12l4 4" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" />
			</svg>
			<input
				class="palette-input"
				type="search"
				role="combobox"
				aria-expanded="true"
				aria-controls="palette-results"
				aria-autocomplete="list"
				placeholder="Sök eller hoppa till …"
				aria-label="Sök eller hoppa till en sida, ämne, tråd, tänkare eller essä"
				autocomplete="off"
				autocapitalize="off"
				spellcheck="false"
				enterkeyhint="go"
			/>
		</div>
		<p class="palette-hint label" aria-live="polite"></p>
		<div class="palette-results" id="palette-results" role="listbox" aria-label="Resultat"></div>
	</div>
	<script is:inline type="application/json" id="search-index" set:html={JSON.stringify(index)} />
</div>

<!-- Global, not scoped: the groups/rows/chips are built at runtime via innerHTML,
     so they never get Astro's scoped-style attribute. All selectors are
     .palette*-namespaced (plus html.palette-open), so there is no collision risk. -->
<style is:global>
	.palette {
		position: fixed;
		inset: 0;
		z-index: 70;
		background: color-mix(in srgb, var(--color-bg) 92%, transparent);
		backdrop-filter: blur(12px) saturate(1.1);
		-webkit-backdrop-filter: blur(12px) saturate(1.1);
		opacity: 0;
		transition: opacity 0.18s ease;
		overflow-y: auto;
		overscroll-behavior: contain;
	}

	.palette[hidden] { display: none; }
	.palette[data-visible] { opacity: 1; }

	@media (prefers-reduced-motion: reduce) {
		.palette { transition: none; }
	}

	/* Lock the page behind the open palette. */
	html.palette-open { overflow: hidden; }

	.palette-close {
		position: absolute;
		top: var(--safe-top);
		right: var(--safe-right);
		display: flex;
		padding: 0.75rem;
		border: none;
		background: transparent;
		color: var(--color-muted);
		cursor: pointer;

		&:hover { color: var(--color-accent); }
		&:focus-visible { outline: 2px solid var(--color-accent); outline-offset: 2px; border-radius: 4px; }
	}

	.palette-inner {
		max-width: var(--content-width);
		margin-inline: auto;
		padding: clamp(3rem, 11vh, 6rem) var(--padding-inline) var(--space-phi2);
	}

	/* Search field — magnifier + the large editorial input, on a single rule. */
	.palette-field {
		display: flex;
		align-items: center;
		gap: 0.6rem;
		border-bottom: 1px solid var(--color-divider);
		transition: border-color 0.15s;

		&:focus-within { border-bottom-color: var(--color-warm); }
	}

	.palette-field-icon {
		flex-shrink: 0;
		color: var(--color-muted);
	}

	.palette-input {
		flex: 1;
		min-width: 0;
		font-family: var(--font-heading);
		font-size: clamp(1.5rem, 4.5vw, 2.2rem);
		font-weight: 400;
		letter-spacing: -0.01em;
		color: var(--color-text);
		background: transparent;
		border: none;
		padding: 0 0 0.7rem;
		outline: none;

		&::placeholder { color: var(--color-muted); }
	}

	.palette-input::-webkit-search-cancel-button { -webkit-appearance: none; }

	.palette-hint {
		margin: var(--space-half) 0 0;
		min-height: 1.2em;
	}

	.palette-results { margin-top: var(--space-unit); }

	.palette-group { margin-bottom: var(--space-unit); }

	.palette-group-head {
		margin: 0 0 0.7rem;
		color: var(--color-muted);
	}

	/* Browse view — compact, tappable chips of label-only links. */
	.palette-chips {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
	}

	.palette-chip {
		display: inline-flex;
		align-items: center;
		padding: 0.4rem 0.8rem;
		font-family: var(--font-heading);
		font-size: 0.95rem;
		font-weight: 500;
		letter-spacing: 0.01em;
		color: var(--color-text);
		text-decoration: none;
		border: 1px solid var(--color-divider);
		border-radius: 1.4rem;
		transition: color 0.15s, border-color 0.15s, background-color 0.15s;
	}

	.palette-chip:hover,
	.palette-chip.is-active {
		color: var(--color-accent);
		border-color: color-mix(in srgb, var(--color-warm) 60%, var(--color-divider));
		background: color-mix(in srgb, var(--color-warm) 8%, transparent);
	}

	/* Search view — full-width rows: title + lead, with a type tag. */
	.palette-rows { display: flex; flex-direction: column; }

	.palette-row {
		display: flex;
		align-items: baseline;
		justify-content: space-between;
		gap: 1rem;
		padding: 0.7rem 0.6rem;
		margin-inline: -0.6rem;
		border-radius: 8px;
		text-decoration: none;
		color: inherit;
		transition: background-color 0.12s;
	}

	.palette-row.is-active,
	.palette-row:hover {
		background: color-mix(in srgb, var(--color-warm) 10%, transparent);
	}

	.palette-row-main { min-width: 0; }

	.palette-row-label {
		display: block;
		font-family: var(--font-heading);
		font-size: 1.15rem;
		font-weight: 600;
		line-height: 1.25;
		color: var(--color-accent);
	}

	.palette-row-sub {
		display: -webkit-box;
		-webkit-line-clamp: 1;
		-webkit-box-orient: vertical;
		overflow: hidden;
		font-family: var(--font-body);
		font-size: 0.9rem;
		line-height: 1.4;
		color: var(--color-muted);
		margin-top: 0.15rem;
	}

	.palette-row-type {
		flex-shrink: 0;
		font-size: 0.7rem;
		color: var(--color-muted);
	}

	.palette-empty {
		font-family: var(--font-body);
		font-size: 1.05rem;
		color: var(--color-muted);
		margin: var(--space-unit) 0 0;
	}

	@media (width <= 768px) {
		.palette-row-type { display: none; }
	}

	/* Touch: the palette is the whole site menu here, so the browse chips must be
	   comfortably tappable. The 0.4rem padding leaves a ~30px target; raise it to
	   the 44px minimum on coarse pointers. */
	@media (hover: none), (pointer: coarse) {
		.palette-chip {
			min-height: 2.75rem;
			padding-inline: 0.95rem;
		}
	}

	@media print { .palette { display: none !important; } }
</style>

<script>
	import { navigate } from "astro:transitions/client";

	type PType = "Sida" | "Ämne" | "Tråd" | "Tänkare" | "Essä";
	interface Entry { type: PType; label: string; sub: string; href: string; group?: "sunni" | "western"; }

	// Results render in sections, not raw types: Tänkare splits into its two
	// traditions so the classical Islamic scholars never interleave with the
	// Swedish/Western voices (the same division the /tankare directory draws).
	// Each section is one heading + the entries it claims.
	type SectionKey = "Sida" | "Ämne" | "Tråd" | "Sunni" | "Western" | "Essä";
	const SECTION: Record<SectionKey, { heading: string; match: (e: Entry) => boolean }> = {
		Sida:    { heading: "Sidor",  match: (e) => e.type === "Sida" },
		Ämne:    { heading: "Ämnen",  match: (e) => e.type === "Ämne" },
		Tråd:    { heading: "Trådar", match: (e) => e.type === "Tråd" },
		Sunni:   { heading: "Den klassiska islamiska traditionen", match: (e) => e.type === "Tänkare" && e.group === "sunni" },
		Western: { heading: "Svenska och västerländska röster",    match: (e) => e.type === "Tänkare" && e.group === "western" },
		Essä:    { heading: "Essäer", match: (e) => e.type === "Essä" },
	};
	// Search ranks structure above essays; browse mirrors the homepage axes (pages
	// last) and omits essays.
	const SEARCH_ORDER: SectionKey[] = ["Sida", "Ämne", "Tråd", "Sunni", "Western", "Essä"];
	const BROWSE_ORDER: SectionKey[] = ["Ämne", "Tråd", "Sunni", "Western", "Sida"];
	// Pages worth surfacing as browse chips (the rest are reachable by typing).
	const BROWSE_PAGES = ["Essäer", "Om", "AI"];
	const ESSAY_CAP = 8;
	// Small tiebreak so structure edges out an essay at equal textual score.
	const TYPE_BONUS: Record<PType, number> = { Sida: 4, Ämne: 3, Tråd: 2, Tänkare: 1, Essä: 0 };

	function fold(s: string): string {
		return s.toLowerCase().normalize("NFD").replace(/[̀-ͯ]/g, "");
	}
	function esc(s: string): string {
		return s.replace(/[&<>"]/g, (c) => ({ "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;" })[c] || c);
	}

	function score(e: Entry, q: string): number {
		const label = fold(e.label);
		let base = 0;
		if (label === q) base = 1000;
		else if (label.startsWith(q)) base = 700;
		else if (label.includes(` ${q}`)) base = 500; // start of a later word
		else if (label.includes(q)) base = 300;
		else if (fold(e.sub).includes(q)) base = 120;
		return base ? base + TYPE_BONUS[e.type] : 0;
	}

	let bound = false;

	function initPalette() {
		// The overlay persists across view transitions (transition:persist), so
		// listeners are bound exactly once against the module-scope element.
		const overlay = document.getElementById("search-overlay")!;
		const input = overlay.querySelector<HTMLInputElement>(".palette-input")!;
		const hint = overlay.querySelector<HTMLElement>(".palette-hint")!;
		const results = overlay.querySelector<HTMLElement>(".palette-results")!;
		const closeBtn = overlay.querySelector<HTMLButtonElement>(".palette-close")!;

		let entries: Entry[] = [];
		function getEntries(): Entry[] {
			if (entries.length) return entries;
			const el = document.getElementById("search-index");
			try { entries = el ? JSON.parse(el.textContent || "[]") : []; } catch { entries = []; }
			return entries;
		}

		let opts: HTMLAnchorElement[] = [];
		let active = -1;
		// The control that opened the palette, so focus can return there on close
		// (keyboard users keep their place instead of being dropped on <body>).
		let lastFocused: HTMLElement | null = null;

		const isOpen = () => !overlay.hidden;

		// While the modal is open, mark the rest of the page inert so assistive tech
		// and Tab can't reach the now-covered content behind it. The overlay is the
		// last body child, so every sibling is background chrome.
		function setBackgroundInert(on: boolean): void {
			for (const child of Array.from(document.body.children)) {
				if (child === overlay) continue;
				if (on) child.setAttribute("inert", "");
				else child.removeAttribute("inert");
			}
		}

		function setActive(idx: number) {
			const prev = opts[active];
			if (prev) { prev.classList.remove("is-active"); prev.removeAttribute("aria-selected"); }
			active = idx;
			const cur = opts[idx];
			if (cur) {
				cur.classList.add("is-active");
				cur.setAttribute("aria-selected", "true");
				input.setAttribute("aria-activedescendant", cur.id);
				cur.scrollIntoView({ block: "nearest" });
			} else {
				input.removeAttribute("aria-activedescendant");
			}
		}

		function move(delta: number) {
			if (!opts.length) return;
			let idx = (active < 0 ? (delta > 0 ? -1 : 0) : active) + delta;
			if (idx < 0) idx = opts.length - 1;
			if (idx >= opts.length) idx = 0;
			setActive(idx);
		}

		// --- rendering -----------------------------------------------------
		let n = 0;
		function chip(e: Entry): string {
			const i = n++;
			return `<a class="palette-opt palette-chip" role="option" id="palette-opt-${i}" data-i="${i}" href="${e.href}" data-astro-prefetch="hover">${esc(e.label)}</a>`;
		}
		function row(e: Entry): string {
			const i = n++;
			return `<a class="palette-opt palette-row" role="option" id="palette-opt-${i}" data-i="${i}" href="${e.href}" data-astro-prefetch="hover"><span class="palette-row-main"><span class="palette-row-label">${esc(e.label)}</span><span class="palette-row-sub">${esc(e.sub)}</span></span><span class="palette-row-type label">${esc(e.type)}</span></a>`;
		}

		function renderBrowse(): string {
			let out = "";
			for (const key of BROWSE_ORDER) {
				const sec = SECTION[key];
				let list = getEntries().filter(sec.match);
				if (key === "Sida") list = list.filter((e) => BROWSE_PAGES.includes(e.label));
				if (!list.length) continue;
				out += `<section class="palette-group"><p class="palette-group-head label">${sec.heading}</p><div class="palette-chips">${list.map(chip).join("")}</div></section>`;
			}
			return out;
		}

		function renderSearch(q: string): { html: string; count: number } {
			const hits = getEntries()
				.map((e) => ({ e, s: score(e, q) }))
				.filter((h) => h.s > 0)
				.sort((a, b) => b.s - a.s);
			let out = "";
			let count = 0;
			for (const key of SEARCH_ORDER) {
				const sec = SECTION[key];
				let list = hits.filter((h) => sec.match(h.e)).map((h) => h.e);
				if (key === "Essä") list = list.slice(0, ESSAY_CAP);
				if (!list.length) continue;
				out += `<section class="palette-group"><p class="palette-group-head label">${sec.heading}</p><div class="palette-rows">${list.map(row).join("")}</div></section>`;
				count += list.length;
			}
			return { html: out, count };
		}

		function render() {
			const q = fold(input.value.trim());
			n = 0;
			if (!q) {
				results.innerHTML = renderBrowse();
				hint.textContent = "";
			} else {
				const { html, count } = renderSearch(q);
				results.innerHTML = html || `<p class="palette-empty">Inga träffar för ”${esc(input.value.trim())}”.</p>`;
				hint.textContent = count ? `${count} ${count === 1 ? "träff" : "träffar"}` : "Inga träffar";
			}
			opts = Array.from(results.querySelectorAll<HTMLAnchorElement>(".palette-opt"));
			setActive(q && opts.length ? 0 : -1);
		}

		// --- open / close --------------------------------------------------
		function open() {
			if (isOpen()) return;
			lastFocused = document.activeElement instanceof HTMLElement ? document.activeElement : null;
			overlay.hidden = false;
			document.documentElement.classList.add("palette-open");
			setBackgroundInert(true);
			render();
			requestAnimationFrame(() => overlay.setAttribute("data-visible", ""));
			setTimeout(() => input.focus(), 50);
		}
		// restoreFocus returns the caret to the opener — wanted when the user dismisses
		// the palette in place (Escape / close button), not when an option navigates away.
		function reset(restoreFocus = false) {
			overlay.hidden = true;
			overlay.removeAttribute("data-visible");
			document.documentElement.classList.remove("palette-open");
			setBackgroundInert(false);
			input.value = "";
			if (restoreFocus && lastFocused?.isConnected) lastFocused.focus();
			lastFocused = null;
		}
		function close() {
			if (!isOpen()) return;
			overlay.removeAttribute("data-visible");
			document.documentElement.classList.remove("palette-open");
			const done = () => reset(true);
			overlay.addEventListener("transitionend", done, { once: true });
			setTimeout(done, 250);
		}
		function go(target: HTMLAnchorElement | undefined) {
			if (!target) return;
			const href = target.getAttribute("href") || "/";
			reset();
			navigate(href);
		}

		// --- wiring (once) -------------------------------------------------
		input.addEventListener("input", render);
		results.addEventListener("mouseover", (e) => {
			const o = (e.target as HTMLElement).closest<HTMLElement>(".palette-opt");
			if (o?.dataset.i) setActive(+o.dataset.i);
		});
		// Clicks on options: let the router navigate the <a>; just tidy up state.
		results.addEventListener("click", (e) => {
			if ((e.target as HTMLElement).closest(".palette-opt")) reset();
		});
		closeBtn.addEventListener("click", close);

		// Keys while open: arrows move, Enter follows, Escape closes. Handled on
		// the overlay and stopped from propagating so the essay-page Escape→/essaer
		// binding and footnote popovers never also fire.
		overlay.addEventListener("keydown", (e) => {
			if (e.key === "Escape") { e.preventDefault(); e.stopPropagation(); close(); }
			else if (e.key === "ArrowDown") { e.preventDefault(); move(1); }
			else if (e.key === "ArrowUp") { e.preventDefault(); move(-1); }
			else if (e.key === "Enter") { e.preventDefault(); go(opts[active] ?? opts[0]); }
			else if (e.key === "Home") { e.preventDefault(); if (opts.length) setActive(0); }
			else if (e.key === "End") { e.preventDefault(); if (opts.length) setActive(opts.length - 1); }
			else if (e.key === "Tab") { e.preventDefault(); (document.activeElement === input ? closeBtn : input).focus(); }
		});

		// Global open shortcuts and the mast trigger (delegated, bound once).
		document.addEventListener("keydown", (e) => {
			if ((e.key === "k" || e.key === "K") && (e.metaKey || e.ctrlKey)) {
				e.preventDefault();
				isOpen() ? close() : open();
				return;
			}
			const t = e.target as HTMLElement | null;
			const inField = !!t && t.matches("input, textarea, select, [contenteditable=true]");
			if (e.key === "/" && !inField && !isOpen()) { e.preventDefault(); open(); }
		});
		document.addEventListener("click", (e) => {
			if ((e.target as HTMLElement).closest(".search-trigger")) { e.preventDefault(); open(); }
		});
	}

	document.addEventListener("astro:page-load", () => {
		// Land every navigation with the palette closed and scroll unlocked.
		const overlay = document.getElementById("search-overlay");
		if (overlay && !overlay.hidden) {
			overlay.hidden = true;
			overlay.removeAttribute("data-visible");
		}
		document.documentElement.classList.remove("palette-open");
		// Defensive: never let a stale inert (from an interrupted open) survive a nav.
		for (const child of Array.from(document.body.children)) {
			if (child !== overlay) child.removeAttribute("inert");
		}
		const input = overlay?.querySelector<HTMLInputElement>(".palette-input");
		if (input) input.value = "";

		if (bound) return;
		bound = true;
		initPalette();
	});
</script>
