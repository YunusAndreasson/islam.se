---
import { getArticles } from "../lib/articles";

// Client-side index over titles and leads — the corpus is small enough that no
// search infrastructure is warranted (§8, §11). Embedded as a JSON island.
const articles = await getArticles();
const index = articles.map((a) => ({ s: a.slug, t: a.title, d: a.description }));
---

<div class="search-overlay" id="search-overlay" hidden role="dialog" aria-modal="true" aria-label="Sök" transition:persist>
	<button class="search-close" type="button" aria-label="Stäng sök">
		<svg width="18" height="18" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.25" stroke-linecap="round"><path d="M2 2l10 10M12 2 2 12" /></svg>
	</button>
	<div class="search-inner">
		<input
			class="search-input"
			type="search"
			placeholder="Sök bland essäerna"
			aria-label="Sök bland essäerna"
			autocomplete="off"
			spellcheck="false"
		/>
		<p class="search-hint label" aria-live="polite"></p>
		<ul class="search-results" role="listbox"></ul>
	</div>
	<script is:inline type="application/json" id="search-index" set:html={JSON.stringify(index)} />
</div>

<style>
	.search-overlay {
		position: fixed;
		inset: 0;
		z-index: 70;
		background: color-mix(in srgb, var(--color-bg) 97%, transparent);
		backdrop-filter: blur(10px);
		-webkit-backdrop-filter: blur(10px);
		opacity: 0;
		transition: opacity 0.2s ease;
		overflow-y: auto;
	}

	.search-overlay[hidden] {
		display: none;
	}

	.search-overlay[data-visible] {
		opacity: 1;
	}

	.search-close {
		position: absolute;
		top: var(--safe-top);
		right: var(--safe-right);
		display: flex;
		padding: 0.75rem;
		border: none;
		background: transparent;
		color: var(--color-muted);
		cursor: pointer;

		&:hover { color: var(--color-accent); }
		&:focus-visible { outline: 2px solid var(--color-accent); outline-offset: 2px; }
	}

	.search-inner {
		max-width: var(--content-width);
		margin-inline: auto;
		padding: clamp(3.5rem, 12vh, 7rem) var(--padding-inline) var(--space-phi2);
	}

	.search-input {
		width: 100%;
		font-family: var(--font-heading);
		font-size: clamp(1.6rem, 5vw, 2.4rem);
		font-weight: 400;
		letter-spacing: -0.01em;
		color: var(--color-text);
		background: transparent;
		border: none;
		border-bottom: 1px solid var(--color-divider);
		padding: 0 0 0.75rem;
		outline: none;

		&::placeholder { color: var(--color-muted); }
		&:focus { border-bottom-color: var(--color-warm); }
	}

	.search-input::-webkit-search-cancel-button { -webkit-appearance: none; }

	.search-hint {
		margin: var(--space-half) 0 0;
		min-height: 1.2em;
		color: var(--color-muted);
	}

	.search-results {
		list-style: none;
		margin: var(--space-unit) 0 0;
		padding: 0;
	}

	.search-results li {
		border-top: 1px solid var(--color-divider);
	}

	.search-results a {
		display: block;
		padding-block: var(--space-half);
		text-decoration: none;
		color: inherit;

		&:hover .search-result-title,
		&:focus-visible .search-result-title { text-decoration: underline; text-underline-offset: 0.12em; }
		&:focus-visible { outline: 2px solid var(--color-accent); outline-offset: 2px; }
	}

	.search-result-title {
		font-family: var(--font-heading);
		font-size: 1.25rem;
		font-weight: 600;
		color: var(--color-accent);
	}

	.search-result-desc {
		font-family: var(--font-body);
		font-size: 0.9375rem;
		line-height: 1.45;
		color: var(--color-muted);
		margin: 0.25rem 0 0;
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	@media print { .search-overlay { display: none !important; } }
</style>

<script>
	interface Entry { s: string; t: string; d: string; }

	function fold(s: string): string {
		return s.toLowerCase().normalize("NFD").replace(/[̀-ͯ]/g, "");
	}

	let entries: Entry[] = [];

	function getEntries(): Entry[] {
		if (entries.length) return entries;
		const el = document.getElementById("search-index");
		try { entries = el ? JSON.parse(el.textContent || "[]") : []; } catch { entries = []; }
		return entries;
	}

	let bound = false;

	function initSearch() {
		if (bound) return;
		// Rendered by Base on every page; assert non-null so the closures below
		// keep the type (TS drops flow-narrowing across function boundaries).
		const overlay = document.getElementById("search-overlay")!;
		bound = true; // module-scope element persists across navigation (transition:persist)

		const input = overlay.querySelector<HTMLInputElement>(".search-input")!;
		const hint = overlay.querySelector<HTMLElement>(".search-hint")!;
		const results = overlay.querySelector<HTMLUListElement>(".search-results")!;

		function open() {
			overlay.hidden = false;
			requestAnimationFrame(() => overlay.setAttribute("data-visible", ""));
			setTimeout(() => input.focus(), 60);
		}
		function close() {
			overlay.removeAttribute("data-visible");
			const done = () => { overlay.hidden = true; };
			overlay.addEventListener("transitionend", done, { once: true });
			setTimeout(done, 250);
		}

		function render() {
			const q = fold(input.value.trim());
			if (!q) { results.innerHTML = ""; hint.textContent = ""; return; }
			const hits = getEntries()
				.filter((e) => fold(`${e.t} ${e.d}`).includes(q))
				.slice(0, 12);
			hint.textContent = hits.length
				? `${hits.length} ${hits.length === 1 ? "träff" : "träffar"}`
				: "Inga träffar";
			results.innerHTML = hits
				.map((e) => `<li><a href="/${e.s}"><span class="search-result-title">${esc(e.t)}</span><p class="search-result-desc">${esc(e.d)}</p></a></li>`)
				.join("");
		}

		function esc(s: string): string {
			return s.replace(/[&<>"]/g, (c) => ({ "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;" })[c] || c);
		}

		input.addEventListener("input", render);
		overlay.querySelector(".search-close")?.addEventListener("click", close);
		document.addEventListener("keydown", (e) => {
			if (e.key === "Escape" && !overlay.hidden) close();
		});
		// Magnifier in the mast (delegated; the trigger lives in Header).
		document.addEventListener("click", (e) => {
			if ((e.target as HTMLElement).closest(".search-trigger")) { e.preventDefault(); open(); }
		});
	}

	document.addEventListener("astro:page-load", initSearch);
</script>
