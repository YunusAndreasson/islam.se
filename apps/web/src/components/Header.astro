---
const path = Astro.url.pathname;
const isHome = path === "/";
---

<header class="site-header" transition:persist>
	<nav class="site-nav" aria-label="Huvudnavigering">
		<a href="/" aria-current={isHome ? "page" : undefined}><svg class="nav-rub" aria-hidden="true" viewBox="0 0 20 20" fill="none"><rect x="3.5" y="3.5" width="13" height="13" stroke="currentColor" stroke-width="1"/><rect x="3.5" y="3.5" width="13" height="13" stroke="currentColor" stroke-width="1" transform="rotate(45 10 10)"/><circle cx="10" cy="10" r="2.85" stroke="currentColor" stroke-width="0.8"/></svg><span class="site-wordmark">islam<span class="site-tld">.se</span></span></a>
		<button class="search-trigger" type="button" aria-label="Sök och bläddra" aria-keyshortcuts="Meta+K Control+K">
			<svg class="search-trigger-icon" width="16" height="16" viewBox="0 0 18 18" fill="none" aria-hidden="true">
				<circle cx="8" cy="8" r="5.25" stroke="currentColor" stroke-width="1.25" />
				<path d="M12 12l4 4" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" />
			</svg>
			<span class="search-trigger-label">Sök</span>
			<kbd class="search-trigger-kbd" aria-hidden="true"><span class="search-trigger-cmd">⌘</span>K</kbd>
		</button>
	</nav>
</header>

<script>
	// The mast is wordmark + a single palette trigger now (navigation lives in
	// the command palette). The only behaviour kept here is the auto-hide: the
	// mast slides away on scroll-down, returns on scroll-up.
	let scrollCtrl: AbortController | null = null;

	function bindHeader() {
		const header = document.querySelector(".site-header");
		if (!header) return;

		scrollCtrl?.abort();
		scrollCtrl = new AbortController();

		let lastY = window.scrollY;
		const threshold = 10;
		window.addEventListener(
			"scroll",
			() => {
				const y = window.scrollY;
				if (y < threshold) header.classList.remove("header-hidden");
				else if (y > lastY) header.classList.add("header-hidden");
				else if (lastY - y > threshold) header.classList.remove("header-hidden");
				lastY = y;
			},
			{ passive: true, signal: scrollCtrl.signal },
		);
	}

	document.addEventListener("astro:page-load", bindHeader);
</script>
