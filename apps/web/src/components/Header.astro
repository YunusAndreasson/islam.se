---
interface Props {
	hero?: boolean;
}

const { hero = false } = Astro.props;
const path = Astro.url.pathname;
const isHome = path === "/";
const isOm = path === "/om" || path === "/om/";
const isEssaerPage = path === "/essaer" || path === "/essaer/";
const isEssaerSection = !isHome && !isOm && !isEssaerPage;
---

<header class:list={["site-header", { "site-header--hero": hero }]} transition:persist>
	<nav class="site-nav" aria-label="Huvudnavigering">
		<a href="/" aria-current={isHome ? "page" : undefined}><svg class="nav-rub" aria-hidden="true" viewBox="0 0 20 20" fill="none"><rect x="3.5" y="3.5" width="13" height="13" stroke="currentColor" stroke-width="1"/><rect x="3.5" y="3.5" width="13" height="13" stroke="currentColor" stroke-width="1" transform="rotate(45 10 10)"/><circle cx="10" cy="10" r="2.85" stroke="currentColor" stroke-width="0.8"/></svg><span class="site-wordmark">islam<span class="site-tld">.se</span></span></a>
		<div class="site-nav-right">
			<a href="/essaer" aria-current={isEssaerPage ? "page" : isEssaerSection ? "true" : undefined}>Essäer</a>
			<span class="nav-dot" aria-hidden="true">&middot;</span>
			<a href="/om" aria-current={isOm ? "page" : undefined}>Om</a>
		</div>
	</nav>
</header>

<script>
	let scrollCtrl: AbortController | null = null;

	function updateHeader() {
		const header = document.querySelector('.site-header');
		if (!header) return;

		const path = window.location.pathname;
		const isHome = path === '/';
		const isOm = path === '/om' || path === '/om/';
		const isEssaerPage = path === '/essaer' || path === '/essaer/';
		const isEssaerSection = !isHome && !isOm && !isEssaerPage;

		// Update hero/sticky variant
		header.classList.toggle('site-header--hero', isHome);
		header.classList.remove('header-hidden');

		// Update active nav link via aria-current (drives both a11y and styling)
		for (const link of header.querySelectorAll<HTMLAnchorElement>('.site-nav a[href]')) {
			const isExactPage =
				link.pathname === '/' ? isHome :
				link.pathname.startsWith('/om') ? isOm :
				isEssaerPage;
			const isSection = !isExactPage && link.pathname.startsWith('/essaer') && isEssaerSection;
			if (isExactPage) link.setAttribute('aria-current', 'page');
			else if (isSection) link.setAttribute('aria-current', 'true');
			else link.removeAttribute('aria-current');
		}

		// Rebind scroll listener for non-hero pages
		scrollCtrl?.abort();
		scrollCtrl = null;

		if (!isHome) {
			let lastY = 0;
			const threshold = 10;
			scrollCtrl = new AbortController();

			window.addEventListener('scroll', () => {
				const y = window.scrollY;
				if (y < threshold) {
					header.classList.remove('header-hidden');
				} else if (y > lastY) {
					header.classList.add('header-hidden');
				} else if (lastY - y > threshold) {
					header.classList.remove('header-hidden');
				}
				lastY = y;
			}, { passive: true, signal: scrollCtrl.signal });
		}
	}

	document.addEventListener('astro:page-load', updateHeader);
</script>
