---
interface Props {
	count: number;
	variant?: "home" | "about";
}

const { count, variant = "home" } = Astro.props;
const year = new Date().getFullYear();
---

<section class:list={["bookpod", `bookpod--${variant}`]} aria-labelledby="bookpod-heading">
	{variant === "home" && <p class="label home-kicker" id="bookpod-heading">Boken &amp; podden</p>}
	<div class="bookpod-inner">
		<a class="bookpod-cover" href="/samlingsvolym.pdf" download aria-label="Ladda ner Samlade essäer som PDF">
			<span class="bookpod-cover-brand">islam.se</span>
			<span class="bookpod-cover-title">Samlade<br />essäer</span>
			<span class="bookpod-cover-sub">Essäer om islamisk intellektuell tradition och svenskt kulturarv</span>
			<span class="bookpod-cover-ornament" aria-hidden="true"></span>
			<span class="bookpod-cover-year">{year}</span>
		</a>
		<div class="bookpod-text">
			{variant === "about" && <h2 id="bookpod-heading" class="bookpod-about-heading">Boken &amp; podden</h2>}
			<p class="bookpod-lead">
				De {count} essäerna finns samlade i en bok &mdash; och inlästa som podd.
			</p>
			<div class="bookpod-actions">
				<a class="bookpod-action" href="/samlingsvolym.pdf" download>
					<svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
						<path d="M8 2v9m0 0L4.5 7.5M8 11l3.5-3.5M2 13.5h12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
					</svg>
					Ladda ner PDF
				</a>
				<div class="bookpod-listen">
					<a class="bookpod-action" href="https://apple.co/48s9hK6" target="_blank" rel="noopener">
