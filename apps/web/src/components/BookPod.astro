---
interface Props {
	count: number;
	variant?: "home" | "about";
}

const { count, variant = "home" } = Astro.props;
const year = new Date().getFullYear();
---

<section class:list={["bookpod", `bookpod--${variant}`]} aria-labelledby="bookpod-heading">
	{variant === "home" && <p class="label home-kicker" id="bookpod-heading">Boken &amp; podden</p>}
	<div class="bookpod-inner">
		<a class="bookpod-cover" href="/samlingsvolym.pdf" download aria-label="Ladda ner Samlade essäer som PDF">
			<span class="bookpod-cover-brand">islam.se</span>
			<span class="bookpod-cover-title">Samlade<br />essäer</span>
			<span class="bookpod-cover-sub">Essäer om islamisk intellektuell tradition och svenskt kulturarv</span>
			<span class="bookpod-cover-ornament" aria-hidden="true"></span>
			<span class="bookpod-cover-year">{year}</span>
		</a>
		<div class="bookpod-text">
			{variant === "about" && <h2 id="bookpod-heading" class="bookpod-about-heading">Boken &amp; podden</h2>}
			<p class="bookpod-lead">
				De {count} essäerna finns samlade i en bok &mdash; och inlästa som podd.
			</p>
			<div class="bookpod-actions">
				<a class="bookpod-action" href="/samlingsvolym.pdf" download>
					<svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
						<path d="M8 2v9m0 0L4.5 7.5M8 11l3.5-3.5M2 13.5h12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
					</svg>
					Ladda ner PDF
				</a>
				<a class="bookpod-action" href="https://apple.co/48s9hK6" target="_blank" rel="noopener">
					<svg width="14" height="14" viewBox="0 0 32 32" fill="currentColor" aria-hidden="true"><path d="M16 2C8.28 2 2 8.28 2 16s6.28 14 14 14 14-6.28 14-14S23.72 2 16 2zm-.08 7.04a3.36 3.36 0 1 1 0 6.72 3.36 3.36 0 0 1 0-6.72zM18 26.4h-4c-.36 0-.68-.32-.64-.68l.72-5.84c.08-.56.4-1.04.92-1.28a1.6 1.6 0 0 1 1.56 0c.52.24.84.72.92 1.28l.72 5.84c.04.36-.24.68-.6.68h-.6zM16 6.4a7.2 7.2 0 0 0-4.56 12.76c.04-.52.2-1 .48-1.4A5.6 5.6 0 0 1 16 7.84a5.6 5.6 0 0 1 4.08 9.92c.28.4.44.88.48 1.4A7.2 7.2 0 0 0 16 6.4z"/></svg>
					Apple Podcasts
				</a>
				<a class="bookpod-action" href="https://open.spotify.com/show/2WgLxCwy5RFu07sEgHHfI4" target="_blank" rel="noopener">
					<svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 0C5.4 0 0 5.4 0 12s5.4 12 12 12 12-5.4 12-12S18.66 0 12 0zm5.52 17.34c-.24.36-.6.48-.96.24-2.64-1.62-5.96-1.98-9.88-1.08-.36.12-.72-.12-.84-.48-.12-.36.12-.72.48-.84 4.32-1.02 8.04-.6 11.04 1.2.36.12.36.6.16.96zm1.44-3.24c-.24.48-.84.6-1.2.36-3-1.86-7.6-2.4-11.16-1.32-.48.12-.96-.12-1.08-.6-.12-.48.12-.96.6-1.08 4.04-1.2 9.08-.6 12.48 1.5.36.18.48.78.24 1.14h.12zm.12-3.36C15.24 8.4 8.88 8.16 5.16 9.3c-.6.18-1.08-.18-1.26-.72-.18-.6.18-1.08.72-1.26 4.26-1.26 11.34-1.02 15.84 1.5.54.3.72 1.02.42 1.56-.3.42-.96.6-1.5.3l-.3.06z"/></svg>
					Spotify
				</a>
			</div>
		</div>
	</div>
</section>

<style>
	.bookpod-inner {
		display: grid;
		grid-template-columns: auto 1fr;
		align-items: center;
		gap: clamp(2rem, 5vw, 4rem);
	}

	/* ---- The book cover — a typographic rendering of the PDF title page,
	   presented as an object: A-series proportion, hairline edge, soft lift,
	   and a thin spine highlight along the binding edge. ---- */
	.bookpod-cover {
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: flex-start;
		text-align: center;
		text-decoration: none;
		width: clamp(11rem, 22vw, 15rem);
		aspect-ratio: 1 / 1.414;
		padding: 12% 10% 9%;
		color: var(--color-text);
		background: color-mix(in srgb, var(--color-text) 4%, var(--color-bg));
		border: 1px solid var(--color-divider);
		border-radius: 1px 3px 3px 1px;
		box-shadow:
			inset 0.4rem 0 0.6rem -0.55rem rgb(0 0 0 / 0.35),
			0 1.25rem 2.5rem -1rem rgb(0 0 0 / 0.28);
		transition: transform 0.4s cubic-bezier(0.2, 0, 0.1, 1), box-shadow 0.4s ease;

		&:hover {
			transform: translateY(-3px);
			box-shadow:
				inset 0.4rem 0 0.6rem -0.55rem rgb(0 0 0 / 0.35),
				0 1.75rem 3rem -1rem rgb(0 0 0 / 0.34);
		}

		&:focus-visible {
			outline: 2px solid var(--color-accent);
			outline-offset: 4px;
		}
	}

	.bookpod-cover-brand {
		font-family: var(--font-heading);
		font-size: 0.66rem;
		font-weight: 600;
		letter-spacing: 0.22em;
		text-transform: uppercase;
		color: var(--color-muted);
	}

	.bookpod-cover-title {
		font-family: var(--font-heading);
		font-size: clamp(1.3rem, 3vw, 1.85rem);
		font-weight: 300;
		line-height: 1.05;
		letter-spacing: -0.015em;
		margin-top: 1.1em;
	}

	.bookpod-cover-sub {
		font-family: var(--font-body);
		font-style: italic;
		font-size: 0.7rem;
		line-height: 1.4;
		color: var(--color-muted);
		margin-top: 0.9em;
		text-wrap: balance;
	}

	.bookpod-cover-ornament {
		width: 4.5rem;
		height: 0.85rem;
		margin-top: auto;
		margin-bottom: 0.9em;
		background: var(--color-divider);
		-webkit-mask: url("/ornament.svg?v=3") center / 100% 100% no-repeat;
		mask: url("/ornament.svg?v=3") center / 100% 100% no-repeat;
	}

	.bookpod-cover-year {
		font-family: var(--font-heading);
		font-size: 0.7rem;
		letter-spacing: 0.1em;
		color: var(--color-muted);
	}

	/* ---- Text + actions ---- */
	.bookpod-about-heading {
		margin-top: 0;
		margin-bottom: var(--space-half);
	}

	.bookpod-lead {
		font-family: var(--font-body);
		font-size: 1.0625rem;
		line-height: 1.55;
		color: color-mix(in srgb, var(--color-text) 80%, var(--color-muted));
		margin: 0 0 var(--space-unit);
		max-width: 28rem;
	}

	.bookpod-actions {
		display: flex;
		flex-wrap: wrap;
		gap: 0.625rem;
	}

	.bookpod-action {
		display: inline-flex;
		align-items: center;
		gap: 0.45em;
		padding: 0.5rem 1.125rem;
		font-family: var(--font-heading);
		font-size: 0.862rem;
		font-weight: 500;
		letter-spacing: 0.05em;
		text-transform: uppercase;
		font-feature-settings: "case";
		color: var(--color-accent);
		border: 1px solid var(--color-divider);
		border-radius: 1.25rem;
		text-decoration: none;
		transition: border-color 0.2s, color 0.2s;

		&:hover {
			border-color: var(--color-warm);
			color: var(--color-text);
			text-decoration: none;
		}

		&:focus-visible {
			outline: 2px solid var(--color-accent);
			outline-offset: 2px;
		}
	}

	/* Match the homepage inter-movement rhythm (.home-movement). */
	.bookpod--home {
		margin-block: var(--space-phi2);
	}

	/* The about-page variant lives in the 42rem reading column: smaller cover,
	   centred actions, so it mirrors the homepage module without competing. */
	.bookpod--about {
		margin-block: var(--space-phi);
	}

	.bookpod--about .bookpod-cover {
		width: clamp(9rem, 30vw, 11rem);
	}

	@media (width <= 768px) {
		.bookpod-inner {
			grid-template-columns: 1fr;
			justify-items: center;
			gap: var(--space-unit);
			text-align: center;
		}

		.bookpod-lead {
			max-width: none;
		}

		.bookpod-actions {
			justify-content: center;
		}
	}
</style>
