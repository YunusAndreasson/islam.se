						Apple Podcasts
					</a>
					<a class="bookpod-action" href="https://open.spotify.com/show/2WgLxCwy5RFu07sEgHHfI4" target="_blank" rel="noopener">
						<svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 0C5.4 0 0 5.4 0 12s5.4 12 12 12 12-5.4 12-12S18.66 0 12 0zm5.521 17.34c-.24.359-.66.48-1.021.24-2.82-1.74-6.36-2.101-10.561-1.141-.418.122-.779-.179-.899-.539-.12-.421.18-.78.54-.9 4.56-1.021 8.52-.6 11.64 1.32.42.18.479.659.301 1.02zm1.44-3.3c-.301.42-.841.6-1.262.3-3.239-1.98-8.159-2.58-11.939-1.38-.479.12-1.02-.12-1.14-.6-.12-.48.12-1.021.6-1.141C9.6 9.9 15 10.561 18.72 12.84c.361.181.54.78.241 1.2zm.12-3.36C15.24 8.4 8.82 8.16 5.16 9.301c-.6.179-1.2-.181-1.38-.721-.18-.601.18-1.2.72-1.381 4.26-1.26 11.28-1.02 15.721 1.621.539.3.719 1.02.419 1.56-.299.421-1.02.599-1.559.3z"/></svg>
						Spotify
					</a>
				</div>
			</div>
		</div>
	</div>
</section>

<style>
	.bookpod-inner {
		display: grid;
		grid-template-columns: auto 1fr;
		align-items: center;
		gap: clamp(2rem, 5vw, 4rem);
	}

	/* ---- The book cover — a typographic rendering of the PDF title page,
	   presented as an object: A-series proportion, hairline edge, soft lift,
	   and a thin spine highlight along the binding edge. ---- */
	.bookpod-cover {
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: flex-start;
		text-align: center;
		text-decoration: none;
		width: clamp(11rem, 22vw, 15rem);
		aspect-ratio: 1 / 1.414;
		padding: 12% 10% 9%;
		color: var(--color-text);
		background: color-mix(in srgb, var(--color-text) 4%, var(--color-bg));
		border: 1px solid var(--color-divider);
		border-radius: 1px 3px 3px 1px;
		box-shadow:
			inset 0.4rem 0 0.6rem -0.55rem rgb(0 0 0 / 0.35),
			0 1.25rem 2.5rem -1rem rgb(0 0 0 / 0.28);
		transition: transform 0.4s cubic-bezier(0.2, 0, 0.1, 1), box-shadow 0.4s ease;

		&:hover {
			transform: translateY(-3px);
			box-shadow:
				inset 0.4rem 0 0.6rem -0.55rem rgb(0 0 0 / 0.35),
				0 1.75rem 3rem -1rem rgb(0 0 0 / 0.34);
		}

		&:focus-visible {
			outline: 2px solid var(--color-accent);
			outline-offset: 4px;
		}
	}

	.bookpod-cover-brand {
		font-family: var(--font-heading);
		font-size: 0.66rem;
		font-weight: 600;
		letter-spacing: 0.22em;
		text-transform: uppercase;
		color: var(--color-muted);
	}

	.bookpod-cover-title {
		font-family: var(--font-heading);
		font-size: clamp(1.3rem, 3vw, 1.85rem);
		font-weight: 300;
		line-height: 1.05;
		letter-spacing: -0.015em;
		margin-top: 1.1em;
	}

	.bookpod-cover-sub {
		font-family: var(--font-body);
		font-style: italic;
		font-size: 0.7rem;
		line-height: 1.4;
		color: var(--color-muted);
		margin-top: 0.9em;
		text-wrap: balance;
	}

	.bookpod-cover-ornament {
		width: 4.5rem;
		height: 0.85rem;
		margin-top: auto;
		margin-bottom: 0.9em;
		background: var(--color-divider);
		-webkit-mask: url("/ornament.svg?v=3") center / 100% 100% no-repeat;
		mask: url("/ornament.svg?v=3") center / 100% 100% no-repeat;
	}

	.bookpod-cover-year {
		font-family: var(--font-heading);
		font-size: 0.7rem;
		letter-spacing: 0.1em;
		color: var(--color-muted);
	}

	/* ---- Text + actions ---- */
	.bookpod-about-heading {
		margin-top: 0;
		margin-bottom: var(--space-half);
	}

	.bookpod-lead {
		font-family: var(--font-body);
		font-size: 1.0625rem;
		line-height: 1.55;
		color: color-mix(in srgb, var(--color-text) 80%, var(--color-muted));
		margin: 0 0 var(--space-unit);
		max-width: 28rem;
	}

	/* The book action (PDF) sits apart from the two podcast links, which are tucked
	   close together — so the row still reads as two things (book · podcast) by
	   proximity alone, without spelling it out. The larger gap separates the book from
	   the podcast pair; the tight .bookpod-listen gap binds the two platforms. */
	.bookpod-actions {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: clamp(1.25rem, 3.5vw, 2.25rem);
	}

	.bookpod-listen {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
	}

	.bookpod-action {
		display: inline-flex;
		align-items: center;
		gap: 0.45em;
		padding: 0.5rem 1.125rem;
		font-family: var(--font-heading);
		font-size: 0.862rem;
		font-weight: 500;
		letter-spacing: 0.05em;
		text-transform: uppercase;
		font-feature-settings: "case";
		color: var(--color-accent);
		border: 1px solid var(--color-divider);
		border-radius: 1.25rem;
		text-decoration: none;
		transition: border-color 0.2s, color 0.2s;

		&:hover {
			border-color: var(--color-warm);
			color: var(--color-text);
			text-decoration: none;
		}

		&:focus-visible {
			outline: 2px solid var(--color-accent);
			outline-offset: 2px;
		}
	}

	/* Match the homepage inter-movement rhythm (.home-movement). */
	.bookpod--home {
		margin-block: var(--space-phi2);
	}

	/* The about-page variant lives in the 42rem reading column: smaller cover,
	   centred actions, so it mirrors the homepage module without competing. */
	.bookpod--about {
		margin-block: var(--space-phi);
	}

	.bookpod--about .bookpod-cover {
		width: clamp(9rem, 30vw, 11rem);
	}

	@media (width <= 768px) {
		.bookpod-inner {
			grid-template-columns: 1fr;
			justify-items: center;
			gap: var(--space-unit);
			text-align: center;
		}

		.bookpod-lead {
			max-width: none;
		}

		.bookpod-actions {
			justify-content: center;
		}

		.bookpod-listen {
			justify-content: center;
		}
	}
</style>
