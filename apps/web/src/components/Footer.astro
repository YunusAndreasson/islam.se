---
const year = new Date().getFullYear();
const path = Astro.url.pathname;
const here = (p: string) => path === p || path === `${p}/`;

// Standing destinations as real <a> links. With the mast reduced to wordmark +
// palette, this footer is the crawlable navigation every page must carry: from
// these hubs a crawler reaches every ämne (via /essaer), thread, thinker and
// essay. Rendered site-wide from Base.astro; styled globally in layout.css
// (site-wide chrome, like the header — keeps it out of reach of scoped-style
// HMR fragility).
const links = [
	{ href: "/essaer", label: "Essäer" },
	{ href: "/tradar", label: "Trådar" },
	{ href: "/tankare", label: "Tänkare" },
	{ href: "/om", label: "Om" },
	{ href: "/ai", label: "AI" },
];
---

<footer class="site-footer">
	<nav class="site-footer-nav" aria-label="Sidfotsnavigering">
		{links.map((l) => (
			<a href={l.href} aria-current={here(l.href) ? "page" : undefined}>{l.label}</a>
		))}
	</nav>

	<div class="site-footer-colophon">
		<p class="site-footer-names">
			<a href="https://bilal.se">Bilal</a> och <a href="https://andreassonphoto.com">Yunus</a>
		</p>
		<p class="label site-footer-meta">
			<span>Sverige, {year}</span>
			<span class="nav-dot" aria-hidden="true">&middot;</span>
			<a href="https://islam.se">islam.se</a>
			<span class="nav-dot" aria-hidden="true">&middot;</span>
			<a href="/rss.xml">RSS</a>
		</p>
	</div>
</footer>
