---
import { type VerseOfDay, tokenizeArabic } from "../lib/verse";

interface Props {
	verseOfDay: VerseOfDay;
}

const { verseOfDay } = Astro.props;
// `relatedEssays` is every essay that engages this verse (most-recent first).
// They are shown as one labelled list — a single way to link — rather than a
// primary line plus a separate "see also", which doubled the linking gesture.
const { verse, refName, relatedEssays, glosses } = verseOfDay;
// Word tokens carry the 1-based index that lines up with `verse.segments` (so
// the client can light each word as it is recited) and with `glosses` (so each
// word carries its short Swedish meaning). Waqf marks (word === null) are
// rendered but never highlighted or glossed (§7.2).
const tokens = tokenizeArabic(verse.textArabic);
const hasGlosses = glosses.length > 0;
// The verse above is quoted from *Den ädla Koranen* (Kent Asante Wennerström) —
// the translation held in the local Quran DB and used across the project — so the
// book we point readers to is the same volume they are reading here.
const koranBook =
	"https://www.akademibokhandeln.se/bok/den-adla-koranen-med-oversattning-av-dess-versers-innebord-pa-svenska/9789185557493";
---

<section class="vers home-movement" aria-labelledby="vers-kicker">
	{/* The verse as a citable, machine-readable Quotation grounded to its ayah. */}
	<script is:inline type="application/ld+json" set:html={JSON.stringify({
		"@context": "https://schema.org",
		"@type": "Quotation",
		text: verse.textSwedish,
		inLanguage: "sv",
		isBasedOn: {
			"@type": "CreativeWork",
			name: `Koranen ${verse.surah}:${verse.ayah}`,
			url: `https://quran.com/${verse.surah}/${verse.ayah}`,
		},
	})} />
	<h2 class="label home-kicker" id="vers-kicker">Dagens vers</h2>
	<div class="vers-body">
		<p class="vers-sv" lang="sv"><em>{verse.textSwedish}</em></p>

		<p
			class="vers-arabic"
			dir="rtl"
			lang="ar"
			data-segments={JSON.stringify(verse.segments)}
			data-glossed={hasGlosses ? "" : undefined}
		>{tokens.map((t) =>
			t.word !== null ? (
				<span class="vers-w" data-w={t.word} data-sv={glosses[t.word - 1]}>{`${t.text} `}</span>
			) : (
				<span class="vers-waqf">{`${t.text} `}</span>
			),
		)}</p>

		<p class="vers-ref">
			<button
				class="vers-play"
				type="button"
				data-audio={verse.audioFile}
				aria-label={`Lyssna på ${refName} ${verse.surah}:${verse.ayah}, reciterad av ${verse.reciter}`}
			>
				<svg class="vers-icon-play" width="15" height="15" viewBox="0 0 18 18" fill="currentColor" aria-hidden="true"><path d="M4 2.5v13l11-6.5z" /></svg>
				<svg class="vers-icon-pause" width="15" height="15" viewBox="0 0 18 18" fill="currentColor" aria-hidden="true"><rect x="4" y="2" width="3.5" height="14" rx="0.5" /><rect x="10.5" y="2" width="3.5" height="14" rx="0.5" /></svg>
			</button>
			<span class="label vers-cite">Koranen <span class="nav-dot" aria-hidden="true">&middot;</span> {refName} {verse.surah}:{verse.ayah}</span>
		</p>

		<div class="vers-essays">
			<p class="label vers-essays-kicker">
				{relatedEssays.length === 1 ? "Essän som växer ur denna vers" : "Essäer som växer ur denna vers"}
			</p>
			<ul class="vers-essays-list">
				{relatedEssays.map((e) => (
					<li>
						<a class="vers-essay-link" href={`/${e.slug}`} data-astro-prefetch="viewport">{e.title}</a>
					</li>
				))}
			</ul>
		</div>

		<p class="vers-links">
			<a class="vers-book arrow-link" href={koranBook} target="_blank" rel="noopener">Den ädla Koranen hos Akademibokhandeln</a>
		</p>
	</div>
</section>

<style>
	.vers-body {
		/* Meaning first, then the original, in one frame anchored on the left axis.
		   The Swedish translation leads at the top, the Arabic follows right-aligned
		   within the SAME measure (its right edge does NOT push out to the section's
		   full width), and the play control + reference sit beneath the Arabic. */
		max-width: 40rem;
		margin-top: var(--space-half);
		text-align: left;
	}

	/* The original verse, below the translation, on the section's FULL width.
	   Arabic is read right-to-left, so the right edge stays pinned to the frame (level
	   with the Swedish block, never drifting further right). JUSTIFIED so the full
	   lines stretch all the way to the frame's LEFT edge — the same left axis as the
	   Swedish above — instead of leaving a ragged gap there; `text-align-last: right`
	   keeps the short final line on the right where it belongs (not stretched). The two
	   scripts thus share a left line. Sized just above the body register; Amiri Quran
	   reads large for its point size, so it stays commanding. */
	.vers-arabic {
		font-family: var(--font-arabic);
		font-weight: 400;
		/* Amiri Quran ships a single weight/style — never let the engine fake-bold
		   or slant a mushaf naskh. */
		font-synthesis: none;
		font-size: 2.125rem;
		line-height: 1.85;
		letter-spacing: 0;
		color: var(--color-text);
		margin: var(--space-unit) 0 0;
		text-align: justify;
		text-align-last: right;
	}

	/* Word spotlight (§7.2). One mechanism serves both the recitation and manual
	   exploration: when a word is "active" — recited during playback, or hovered
	   (desktop) / tapped (mobile) — the verse settles into a quiet wash and the
	   active word holds full strength, with its short Swedish meaning floating
	   just above it.

	   Dimming changes each word's COLOUR to an opaque mix of text and background —
	   not opacity. Per-word opacity composited twice wherever two words' ink met
	   (Arabic diacritics and final swashes overshoot the advance box, and stacked
	   lines overlap), so seams and stray tashkeel never dimmed to the same level.
	   An opaque colour has no alpha to double up, so the dimming is perfectly even
	   and the letterforms and harakat spacing stay untouched. */
	.vers-w,
	.vers-waqf {
		transition: color 0.3s ease;
	}

	.vers-arabic[data-glossed] .vers-w {
		position: relative;
		cursor: pointer;
	}

	.vers-arabic[data-active] .vers-w,
	.vers-arabic[data-active] .vers-waqf {
		color: color-mix(in srgb, var(--color-text) 32%, var(--color-bg));
	}

	.vers-arabic[data-active] .vers-w.is-active {
		color: var(--color-text);
	}

	/* The Swedish gloss, set above the active word. Swedish is LTR inside the RTL
	   verse, so the bubble resets direction. It may overlap the line above — the
	   solid background and a high z-index keep it legible over the dimmed text. */
	.vers-w.is-active::after {
		content: attr(data-sv);
		position: absolute;
		bottom: 100%;
		left: 50%;
		z-index: 5;
		transform: translateX(-50%);
		margin-bottom: 0.1em;
		padding: 0.1em 0.45em;
		direction: ltr;
		font-family: var(--font-heading);
		font-size: 0.9rem;
		font-weight: 500;
		line-height: 1.25;
		white-space: nowrap;
		color: var(--color-text);
		background: var(--color-bg);
		border-radius: 0.25rem;
		box-shadow: 0 1px 6px color-mix(in srgb, var(--color-text), transparent 88%);
		pointer-events: none;
	}

	@media (prefers-reduced-motion: reduce) {
		.vers-w,
		.vers-waqf {
			transition: none;
		}
	}

	.vers-sv {
		font-family: var(--font-body);
		font-size: 1.25rem;
		line-height: 1.6;
		color: color-mix(in srgb, var(--color-text) 78%, var(--color-muted));
		/* The readable meaning, leading the citation; fills the shared frame, and its
		   left edge sets the axis the Arabic line below runs out to meet. */
		margin: 0;
		text-wrap: pretty;
		/* No hanging indent: the opening quote starts flush on the section's left
		   axis, aligned with the kicker and the play control, rather than pulled into
		   the margin (which read as misaligned). */
		text-indent: 0;
	}

	.vers-sv em {
		font-weight: 500;
	}

	/* A pair of soft curly quotation marks frames the translation as a spoken
	   citation. They take the translation's own colour (inherited) so they read
	   as balanced punctuation rather than a tinted ornament, and stay upright
	   while the prose itself is italic. */
	.vers-sv::before {
		content: "\201C";
	}

	.vers-sv::after {
		content: "\201D";
	}

	.vers-sv::before,
	.vers-sv::after {
		font-style: normal;
		font-weight: 400;
	}

	/* Reference + the lone play glyph, set together in the meta register, on the
	   verse's left axis. */
	.vers-ref {
		display: flex;
		align-items: center;
		justify-content: flex-start;
		gap: 0.6rem;
		margin: var(--space-unit) 0 0;
	}

	.vers-cite {
		color: var(--color-muted);
	}

	.vers-play {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 2.25rem;
		height: 2.25rem;
		flex-shrink: 0;
		border: 1px solid var(--color-divider);
		border-radius: 50%;
		background: transparent;
		color: var(--color-accent);
		cursor: pointer;
		transition: border-color 0.15s, background 0.15s, color 0.15s;
	}

	.vers-play:hover {
		border-color: var(--color-warm);
	}

	.vers-play:focus-visible {
		outline: 2px solid var(--color-accent);
		outline-offset: 2px;
	}

	/* Playing state — a quiet filled look; no scrubber, no timeline. */
	.vers-play[data-playing] {
		background: color-mix(in srgb, var(--color-warm), transparent 82%);
		border-color: var(--color-warm);
	}

	.vers-icon-pause {
		display: none;
	}

	.vers-play[data-playing] .vers-icon-play {
		display: none;
	}

	.vers-play[data-playing] .vers-icon-pause {
		display: inline;
	}

	/* The bridge into the site: the essay(s) that meet this verse, as one labelled
	   list — a single linking gesture. The verse is a doorway (§7.2), so this is
	   the section's primary "read on", set just above the quiet book aside. */
	.vers-essays {
		margin: var(--space-unit) 0 0;
	}

	.vers-essays-kicker {
		margin-bottom: 0.4rem;
		color: var(--color-muted);
	}

	.vers-essays-list {
		margin: 0;
		padding: 0;
		list-style: none;
	}

	.vers-essays-list li + li {
		margin-top: 0.3rem;
	}

	.vers-essay-link {
		font-family: var(--font-heading);
		font-size: 1.0625rem;
		font-weight: 500;
		letter-spacing: 0;
		color: var(--color-accent);
		text-decoration: none;

		&:hover {
			text-decoration: underline;
			text-decoration-thickness: 1px;
			text-underline-offset: 0.15em;
		}

		&:focus-visible {
			outline: 2px solid var(--color-accent);
			outline-offset: 2px;
			border-radius: 2px;
		}
	}

	/* The book — a quiet external aside, muted so it sits clearly below the essay
	   list rather than competing with it for the accent colour. */
	.vers-links {
		margin: var(--space-unit) 0 0;
		font-family: var(--font-heading);
		font-size: 0.9375rem;
	}

	.vers-links a {
		color: var(--color-muted);
		text-decoration: none;
		font-weight: 500;
		transition: color 0.15s ease;

		&:hover {
			color: var(--color-accent);
			text-decoration: underline;
			text-decoration-thickness: 1px;
			text-underline-offset: 0.15em;
		}
	}

	/* The arrow keeps the muted tone of the link itself. */
	.vers-book::after {
		color: var(--color-muted);
	}

	@media (width <= 768px) {
		.vers-arabic {
			font-size: 1.5rem;
			line-height: 1.85;
		}

		.vers-sv {
			font-size: 1.0625rem;
		}
	}

	/* Touch: grow the 2.25rem glyph to the 44px tap minimum. */
	@media (hover: none), (pointer: coarse) {
		.vers-play {
			width: 2.75rem;
			height: 2.75rem;
		}
	}
</style>

<script>
	type Segment = [word: number, start: number, end: number];

	document.addEventListener("astro:page-load", () => {
		const btn = document.querySelector<HTMLButtonElement>(".vers-play");
		const arabic = document.querySelector<HTMLParagraphElement>(".vers-arabic");
		if (!btn || !arabic) return;

		let segments: Segment[] = [];
		try {
			segments = JSON.parse(arabic.dataset.segments || "[]");
		} catch {}

		const glossed = arabic.hasAttribute("data-glossed");
		const ctrl = new AbortController();
		let audio: HTMLAudioElement | null = null;
		let playing = false;
		// The active word (-1 = none): recited during playback, or hovered/tapped.
		// One mechanism dims the verse and floats that word's gloss above it.
		let active = -1;

		const setActive = (word: number) => {
			if (word === active) return;
			if (active >= 0) arabic.querySelector(`.vers-w[data-w="${active}"]`)?.classList.remove("is-active");
			if (word >= 0) {
				arabic.querySelector(`.vers-w[data-w="${word}"]`)?.classList.add("is-active");
				arabic.setAttribute("data-active", "");
			} else {
				arabic.removeAttribute("data-active");
			}
			active = word;
		};

		btn.addEventListener("click", () => {
			// Lazy: no file is fetched until the first press (§7.2).
			if (!audio) {
				audio = new Audio(btn.dataset.audio);
				audio.preload = "none";
				audio.addEventListener("play", () => {
					playing = true;
					btn.setAttribute("data-playing", "");
				});
				audio.addEventListener("pause", () => {
					playing = false;
					btn.removeAttribute("data-playing");
					setActive(-1); // restores the full, readable verse
				});
				audio.addEventListener("ended", () => {
					playing = false;
					btn.removeAttribute("data-playing");
					setActive(-1);
					if (audio) audio.currentTime = 0;
				});
				// Move the spotlight to the word being recited. Segments are ordered
				// by start, so a short linear scan is ample; in the gap between words
				// we simply hold the current word rather than flicker off.
				audio.addEventListener("timeupdate", () => {
					if (!audio || !segments.length) return;
					const t = audio.currentTime * 1000;
					for (const [word, start, end] of segments) {
						if (t >= start && t < end) {
							setActive(word);
							return;
						}
					}
				});
			}
			if (audio.paused) audio.play().catch(() => {});
			else audio.pause();
		}, { signal: ctrl.signal });

		// Hover (desktop) and tap/click (any device) light a word and float its
		// gloss — but not while reciting, where the recitation owns the spotlight.
		const wordAt = (e: Event) =>
			(e.target as HTMLElement)?.closest<HTMLSpanElement>(".vers-w[data-w]");

		if (glossed) {
			arabic.addEventListener("click", (e) => {
				if (playing) return;
				const w = wordAt(e);
				if (!w?.dataset.w) return;
				const word = Number(w.dataset.w);
				setActive(word === active ? -1 : word); // tap again to dismiss (mobile)
			}, { signal: ctrl.signal });

			if (matchMedia("(hover: hover)").matches) {
				arabic.addEventListener("mouseover", (e) => {
					if (playing) return;
					const w = wordAt(e);
					if (w?.dataset.w) setActive(Number(w.dataset.w));
				}, { signal: ctrl.signal });
				arabic.addEventListener("mouseleave", () => {
					if (!playing) setActive(-1);
				}, { signal: ctrl.signal });
			}
		}

		// Stop and release when navigating away (View Transitions).
		document.addEventListener("astro:before-swap", () => {
			if (audio) { audio.pause(); audio.src = ""; }
			ctrl.abort();
		}, { once: true });
	});
</script>
