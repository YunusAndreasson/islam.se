---
import { getMarkesdagar, gregorian } from "../lib/markesdagar";

const events = getMarkesdagar();
const todayISO = new Date().toISOString().slice(0, 10);

// Mark which events are upcoming at build time (the no-JS view); the client
// re-selects against the real Date.now() so the list never goes stale (§7.9).
let buildShown = 0;
const rows = events.map((e) => {
	const endISO = e.endISO ?? e.startISO;
	const upcoming = endISO >= todayISO && buildShown < 5;
	if (upcoming) buildShown++;
	return { ...e, endISO, upcoming, gregorian: gregorian(e.startISO, e.endISO) };
});
---

<section class="markesdagar home-movement" aria-labelledby="markesdagar-kicker">
	<h2 class="label home-kicker" id="markesdagar-kicker">Det islamiska året</h2>

	<ul class="md-list">
		{rows.map((e) => (
			<li class="md-row" data-end={e.endISO} hidden={!e.upcoming}>
				<p class="label md-greg"><time datetime={e.startISO}>{e.gregorian}</time></p>
				<div class="md-body">
					<p class="md-name">{e.name}</p>
					{e.note && <p class="md-note">{e.note}</p>}
				</div>
				<p class="md-hijri">{e.hijriLabel}</p>
			</li>
		))}
	</ul>

	<p class="md-standing">
		Därtill <em>de vita dagarna</em> (Ayyām al-bīḍ) — fasta den 13:e, 14:e och 15:e i varje månmånad.
	</p>
	<p class="md-also">
		I <em>Shaʿbān</em>, månaden före Ramadan, fastade Profeten <span class="honorific honorific--saw">ﷺ</span> fler dagar än under någon annan månad utom Ramadan.
	</p>

	<p class="md-more"><a href="/det-islamiska-aret">Se hela året →</a></p>
</section>

<style>
	/* A quiet two-column rhythm in the editorial register — not a calendar UI.
	   No countdowns, no urgency: events sit in time (§7.9). */
	.md-list {
		margin: var(--space-unit) 0 0;
		padding: 0;
		list-style: none;
	}

	/* No per-row rules — the date column + row spacing carry the agenda; the one
	   standing rule below (.md-standing) is the section's only divider. */
	.md-row {
		display: grid;
		grid-template-columns: 11rem 1fr auto;
		align-items: baseline;
		gap: clamp(1rem, 3vw, 2.5rem);
		padding-block: var(--space-half);
	}

	.md-row[hidden] {
		display: none;
	}

	.md-greg {
		margin: 0;
		color: var(--color-text);
		text-transform: none;
		letter-spacing: 0.02em;
		font-feature-settings: normal;
	}

	.md-body {
		min-width: 0;
	}

	.md-name {
		font-family: var(--font-heading);
		font-size: 1.0625rem;
		font-weight: 500;
		color: var(--color-accent);
		margin: 0;
	}

	.md-note {
		font-family: var(--font-body);
		font-size: 0.875rem;
		line-height: 1.45;
		color: var(--color-muted);
		margin: 0.2rem 0 0;
		max-width: 28rem;
	}

	.md-hijri {
		font-family: var(--font-body);
		font-style: italic;
		font-size: 0.875rem;
		color: var(--color-muted);
		margin: 0;
		white-space: nowrap;
		text-align: end;
	}

	.md-standing {
		font-family: var(--font-body);
		font-size: 0.9375rem;
		color: var(--color-muted);
		margin: var(--space-unit) 0 0;
		padding-top: var(--space-half);
		border-top: 1px solid var(--color-divider);
	}

	.md-also {
		font-family: var(--font-body);
		font-size: 0.9375rem;
		color: var(--color-muted);
		margin: var(--space-half) 0 0;
	}

	.md-more {
		margin: var(--space-half) 0 0;

		a {
			font-family: var(--font-heading);
			font-size: 0.9375rem;
			color: var(--color-accent);
			text-decoration: none;
			/* WCAG 2.5.8 (target size ≥24px): this "Se hela året" link is only ~20px tall.
			   Pad the hit area past 24px; the negative margin reclaims the layout space. */
			display: inline-block;
			padding-block: 0.3rem;
			margin-block: -0.3rem;

			&:hover {
				text-decoration: underline;
				text-underline-offset: 0.12em;
			}

			&:focus-visible {
				outline: 2px solid var(--color-accent);
				outline-offset: 2px;
			}
		}
	}

	@media (width <= 768px) {
		.md-row {
			grid-template-columns: 1fr;
			gap: 0.35rem;
			padding-block: var(--space-unit);
		}

		.md-hijri {
			text-align: start;
			white-space: normal;
		}
	}
</style>

<script>
	document.addEventListener("astro:page-load", () => {
		const list = document.querySelector(".md-list");
		if (!list) return;
		const today = new Date().toISOString().slice(0, 10);
		let shown = 0;
		for (const row of list.querySelectorAll<HTMLElement>("[data-end]")) {
			const end = row.dataset.end ?? "";
			const keep = end >= today && shown < 5;
			row.hidden = !keep;
			if (keep) shown++;
		}
	});
</script>
