---
import type { Article } from "../lib/articles";
import { formatDate, inlineMarkdown } from "../lib/articles";
import EssayImage from "./EssayImage.astro";

interface Props {
	article: Article;
}

const { article } = Astro.props;
---

<section class="feature home-movement" aria-labelledby="feature-title">
	<a class="feature-link" href={`/${article.slug}`} data-astro-prefetch="viewport">
		<div class="feature-media media-frame">
			<EssayImage
				article={article}
				widths={[480, 640, 768, 1024, 1280, 1600, 2048]}
				sizes="(max-width: 1024px) 100vw, 1024px"
				loading="eager"
				fetchpriority="high"
			/>
		</div>
		<div class="feature-text">
			<p class="label home-kicker feature-kicker">Senaste essän</p>
			<h2 id="feature-title" class="feature-title">{article.title}</h2>
			{article.description && (
				<p class="feature-lead" set:html={inlineMarkdown(article.description)} />
			)}
			<p class="label feature-meta">
				<time datetime={article.publishedAt}>{formatDate(article.publishedAt)}</time>
				&middot; {article.readingTime} min läsning
			</p>
		</div>
	</a>
</section>

<style>
	/* The page's lead movement: a wide image carries the focal point, with the
	   title and meta set beneath it in the site serif — no text over photo. */
	.feature-link {
		display: block;
		text-decoration: none;
		color: inherit;

		&:hover,
		&:visited,
		&:active {
			text-decoration: none;
			color: inherit;
		}

		&:focus-visible {
			outline: 2px solid var(--color-accent);
			outline-offset: 0.75rem;
			border-radius: 2px;
		}
	}

	/* Frame, grain + vignette come from the shared .media-frame utility
	   (layout.css). The image is rendered by EssayImage, so the <img> carries
	   EssayImage's style scope, not ours — a scoped rule on the element never
	   matches it (this is why the old `.feature-img` aspect-ratio silently did
	   nothing). Reach it with :global() and pin the ratio on the img itself (not
	   the wrapper), so the hero is a stable 16:9 crop regardless of the source
	   file's dimensions. The base tonal wash + its transition also live on the
	   img in EssayImage; here we only set layout (and relax the wash on hover). */
	/* Cover fit + hover colour-bloom are shared on .media-frame (layout.css); here
	   we set only this hero's crop and a gentler zoom than the default. */
	.feature-media {
		--frame-zoom: 1.02;
	}

	.feature-media :global(img) {
		aspect-ratio: 16 / 9;
	}

	.feature-text {
		margin-top: var(--space-unit);
	}

	/* The hero eyebrow sits beneath the image, naming the lead essay — it is a
	   caption, not a section joint, so it opts out of the movement-threshold rule
	   and accent tick that the other kickers carry. */
	.feature-kicker {
		margin-bottom: var(--space-half);
		padding-top: 0;
		border-top: none;
	}

	.feature-kicker::before {
		content: none;
	}

	/* Larger than --step-4 (2.612rem): a deliberate, contained exception to the
	   type scale, earned by this being the page's lead headline. */
	.feature-title {
		font-size: clamp(2.1rem, 4.5vw, 3rem);
		line-height: 1.08;
		letter-spacing: -0.025em;
		margin: 0;
		max-width: 24ch;
		text-wrap: balance;
		font-feature-settings: "titl" 1, "dlig" 1;
	}

	.feature-link:hover .feature-title {
		text-decoration: underline;
		text-decoration-thickness: 1px;
		text-underline-offset: 0.12em;
	}

	.feature-lead {
		font-family: var(--font-body);
		font-size: 1.0625rem;
		line-height: 1.55;
		color: color-mix(in srgb, var(--color-text) 80%, var(--color-muted));
		margin: var(--space-unit) 0 0;
		max-width: 42rem;
	}

	.feature-meta {
		margin: var(--space-unit) 0 0;
	}

	@media (width <= 768px) {
		/* A 16:9 band reads as a thin letterbox on a phone; 3:2 keeps the image
		   tall enough to hold the eye before the title takes over. */
		.feature-media :global(img) {
			aspect-ratio: 3 / 2;
		}

		.feature-lead {
			font-size: 1rem;
			margin-top: var(--space-half);
		}

		.feature-meta {
			margin-top: var(--space-half);
		}
	}
</style>
