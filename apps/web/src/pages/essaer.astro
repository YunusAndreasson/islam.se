---
import Base from "../layouts/Base.astro";
import { formatDate, getArticles } from "../lib/articles";

const articles = await getArticles();

/** Convert inline markdown (*italic*, **bold**) to HTML */
function inlineMarkdown(text: string): string {
	return text
		.replace(/\*\*(.+?)\*\*/g, "<strong>$1</strong>")
		.replace(/\*(.+?)\*/g, "<em>$1</em>");
}
---

<Base title="Essäer — islam.se" description="Samtliga essäer om islamisk intellektuell tradition och svenskt kulturarv. Al-Ghazālī, Ibn Khaldūn, Strindberg, Lagerlöf och fler.">
	<main id="main" class="content-column">
		<header class="article-header">
			<h1>Essäer</h1>
			<p class="label archive-stats" aria-live="polite"></p>
		</header>

		<ul class="archive-list" id="list-all">
			{articles.map((article) => (
				<li class="archive-item" data-slug={article.slug}>
					<a href={`/${article.slug}`} data-astro-prefetch="viewport">
						<span class="archive-title">{article.title}</span>
						<p class="label archive-meta">
							<time datetime={article.publishedAt}>{formatDate(article.publishedAt)}</time> &middot; {article.readingTime} min läsning
						</p>
						{article.description && <p class="archive-description" set:html={inlineMarkdown(article.description)} />}
					</a>
				</li>
			))}
		</ul>
	</main>
</Base>

<script>
	function splitSections() {
		// Fresh page: items in #list-all. Bfcache restore: items in existing sections.
		const list = document.getElementById("list-all");
		const items = document.querySelectorAll<HTMLElement>(".content-column .archive-item[data-slug]");
		if (!items.length) return;

		const unreadItems: HTMLElement[] = [];
		const readItems: HTMLElement[] = [];

		for (const item of items) {
			const pct = +(localStorage.getItem(`rp:${item.dataset.slug}`) || 0);
			if (pct > 0.85) {
				readItems.push(item);
			} else {
				unreadItems.push(item);
			}
		}

		const stats = document.querySelector<HTMLElement>(".archive-stats");
		if (stats) {
			stats.textContent = `${readItems.length} av ${items.length} lästa`;
			stats.style.setProperty("--progress", String(readItems.length / items.length));
		}

		const makeSection = (heading: string, sectionItems: HTMLElement[]) => {
			const section = document.createElement("section");
			section.className = "archive-section";
			const h2 = document.createElement("h2");
			h2.className = "label archive-section-heading";
			h2.textContent = heading;
			const ul = document.createElement("ul");
			ul.className = "archive-list";
			section.append(h2, ul);
			if (sectionItems.length) ul.append(...sectionItems);
			return section;
		};

		const fragment = document.createDocumentFragment();
		fragment.append(
			makeSection("Att läsa", unreadItems),
			makeSection("Lästa", readItems),
		);

		if (list) {
			list.replaceWith(fragment);
		} else {
			for (const s of document.querySelectorAll(".archive-section")) s.remove();
			document.querySelector(".article-header")?.after(fragment);
		}
	}

	document.addEventListener("astro:page-load", splitSections);
	window.addEventListener("pageshow", (e) => {
		if ((e as PageTransitionEvent).persisted) splitSections();
	});
</script>
