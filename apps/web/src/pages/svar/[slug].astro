---
import { type CollectionEntry, getCollection, render } from "astro:content";
import EssayImage from "../../components/EssayImage.astro";
import Base from "../../layouts/Base.astro";
import { getArticles } from "../../lib/articles";
import { FAKTA_IMAGE_BY_SVAR, FAKTA_SLUGS } from "../../lib/fakta";
import { ORG_ID, WEBSITE_ID, breadcrumbList } from "../../lib/jsonld";

export async function getStaticPaths() {
	const entries = await getCollection("svar");
	const bySlug = new Map(entries.map((e) => [e.id, e]));
	const essayBySlug = new Map((await getArticles()).map((a) => [a.slug, a]));
	return entries.map((entry) => ({
		params: { slug: entry.id },
		props: {
			entry,
			related: (entry.data.related ?? [])
				.map((id) => bySlug.get(id))
				.filter((e): e is NonNullable<typeof e> => Boolean(e)),
			// Curated cross-silo links into the essay corpus. A stale slug fails the
			// build (we never want a dead "Läs vidare" link), the same guarantee the
			// tänkare/tråd derivations give.
			essays: (entry.data.essays ?? []).map((slug) => {
				const essay = essayBySlug.get(slug);
				if (!essay) {
					throw new Error(
						`svar/${entry.id}.md: \`essays\` references unknown essay slug "${slug}". ` +
							"Use a slug from data/articles/ (the filename without .md).",
					);
				}
				return { slug: essay.slug, title: essay.title };
			}),
		},
	}));
}

type SvarEntry = CollectionEntry<"svar">;
interface Props {
	entry: SvarEntry;
	related: SvarEntry[];
	essays: { slug: string; title: string }[];
}

const { entry, related, essays } = Astro.props;
const { data } = entry;
const { Content } = await render(entry);
const url = `https://islam.se/svar/${entry.id}/`;

// Cornerstone answers (the Five Pillars + six Articles of Faith) belong to the
// FAKTA hub: they get a borrowed hero image so the page reads as an article, and
// they breadcrumb / link back to /vad-ar-islam/. Ordinary questions belong to the
// /svar/ index.
const isFakta = FAKTA_SLUGS.has(entry.id);
const heroEssaySlug = FAKTA_IMAGE_BY_SVAR.get(entry.id);
const heroArticle = heroEssaySlug
	? (await getArticles()).find((a) => a.slug === heroEssaySlug)
	: undefined;

const updated =
	data.updatedAt && data.updatedAt.slice(0, 10) !== data.publishedAt.slice(0, 10)
		? data.updatedAt
		: null;

// Article + FAQPage + breadcrumb. The page answers one primary question, so the
// Article carries it as mainEntityOfPage and the FAQ block (when present) earns the
// FAQ rich-result eligibility for the long-tail variants.
const jsonLd: Record<string, unknown>[] = [
	{
		"@context": "https://schema.org",
		"@type": "Article",
		headline: data.title,
		description: data.description,
		inLanguage: "sv",
		url,
		mainEntityOfPage: url,
		isPartOf: { "@id": WEBSITE_ID },
		datePublished: data.publishedAt,
		dateModified: data.updatedAt ?? data.publishedAt,
		author: { "@id": ORG_ID },
		publisher: { "@id": ORG_ID },
		...(data.sources && data.sources.length > 0
			? {
					citation: data.sources.map((s) => ({
						"@type": "CreativeWork",
						name: s.name,
						...(s.url ? { url: s.url } : {}),
					})),
				}
			: {}),
	},
	breadcrumbList([
		{ name: "Hem", url: "/" },
		isFakta
			? { name: "Fakta", url: "/vad-ar-islam/" }
			: { name: "Frågor och svar", url: "/svar/" },
		{ name: data.title, url },
	]),
];
if (data.faq && data.faq.length > 0) {
	jsonLd.push({
		"@context": "https://schema.org",
		"@type": "FAQPage",
		mainEntity: data.faq.map((f) => ({
			"@type": "Question",
			name: f.q,
			acceptedAnswer: { "@type": "Answer", text: f.a },
		})),
	});
}
---

<Base
	title={`${data.title} — islam.se`}
	description={data.description}
	ogImageAlt={data.title}
	jsonLd={jsonLd}
>
	<main id="main" class="svar-page reading">
		<article>
			<header class="svar-header">
				<h1>{data.title}</h1>
				{updated ? (
					<p class="svar-updated">Uppdaterad <time datetime={updated.slice(0, 10)}>{updated.slice(0, 10)}</time></p>
				) : null}
			</header>

			{heroArticle?.heroImage && (
				<div class="svar-hero media-frame">
					<EssayImage
						article={heroArticle}
						alt=""
						widths={[480, 800, 1200]}
						sizes="(max-width: 64rem) 100vw, 64rem"
						loading="eager"
						fetchpriority="high"
					/>
				</div>
			)}

			<div class="article-body prose">
				<Content />
			</div>

			{data.faq && data.faq.length > 0 && (
				<section class="svar-faq" aria-labelledby="svar-faq-rubrik">
					<h2 id="svar-faq-rubrik">Vanliga frågor</h2>
					<dl>
						{data.faq.map((f) => (
							<div class="svar-faq-item">
								<dt>{f.q}</dt>
								<dd>{f.a}</dd>
							</div>
						))}
					</dl>
				</section>
			)}

			{data.sources && data.sources.length > 0 && (
				<section class="svar-sources" aria-labelledby="svar-kallor">
					<h2 id="svar-kallor">Källor och fördjupning</h2>
					<ul>
						{data.sources.map((s) => (
							<li>{s.url ? <a href={s.url} rel="noopener">{s.name}</a> : s.name}</li>
						))}
					</ul>
				</section>
			)}

			{related.length > 0 && (
				<section class="svar-related" aria-labelledby="svar-relaterat">
					<h2 id="svar-relaterat">Relaterade frågor</h2>
					<ul>
						{related.map((r) => (
							<li><a href={`/svar/${r.id}/`}>{r.data.title}</a></li>
						))}
					</ul>
				</section>
			)}

			{essays.length > 0 && (
					<section class="svar-essays" aria-labelledby="svar-essaer">
						<h2 id="svar-essaer">Läs vidare</h2>
						<ul>
							{essays.map((e) => (
								<li><a href={`/${e.slug}`}>{e.title}</a></li>
							))}
						</ul>
					</section>
				)}

				<p class="svar-back">
					{isFakta ? (
						<a href="/vad-ar-islam/">← Tillbaka till Fakta om islam</a>
					) : (
						<a href="/svar/">← Alla frågor och svar</a>
					)}
				</p>
		</article>
	</main>
</Base>

<style>
	.svar-page {
		margin-block: var(--space-phi);
	}

	.svar-header h1 {
		margin: var(--space-half) 0 0;
		text-wrap: balance;
	}

	.svar-updated {
		font-family: var(--font-heading);
		font-size: 0.8125rem;
		color: var(--color-muted);
		margin: var(--space-half) 0 0;
	}

	/* Cornerstone (FAKTA) answers carry a borrowed hero so the page reads as an
	   article. It spans the reading frame, above the body. */
	.svar-hero {
		margin-top: var(--space-unit);
	}
	.svar-hero :global(img) {
		aspect-ratio: 16 / 9;
		width: 100%;
	}

	.svar-faq,
	.svar-sources,
	.svar-related,
	.svar-essays {
		margin-top: var(--space-phi);
		padding-top: var(--space-unit);
		border-top: 1px solid var(--color-divider);
	}

	.svar-faq h2,
	.svar-sources h2,
	.svar-related h2,
	.svar-essays h2 {
		font-size: var(--step-1);
	}

	.svar-faq-item {
		padding: var(--space-half) 0;
		border-bottom: 1px solid var(--color-divider);
	}
	.svar-faq dt {
		font-family: var(--font-heading);
		font-weight: 600;
		color: var(--color-text);
		margin-bottom: 0.3rem;
	}
	.svar-faq dd {
		margin: 0;
		font-family: var(--font-body);
		line-height: 1.6;
		color: color-mix(in srgb, var(--color-text) 85%, var(--color-muted));
	}

	.svar-sources ul,
	.svar-related ul,
	.svar-essays ul {
		font-family: var(--font-body);
		line-height: 1.7;
		color: var(--color-muted);
		margin: var(--space-half) 0 0;
		padding-left: 1.1rem;
	}
	.svar-sources a,
	.svar-related a,
	.svar-essays a {
		color: var(--color-accent);
	}

	.svar-back {
		margin-top: var(--space-phi);
		font-family: var(--font-heading);
		font-size: 0.9375rem;
	}
	.svar-back a {
		color: var(--color-accent);
		text-decoration: none;
	}
</style>
