---
import { getCollection } from "astro:content";
import PageHead from "../../components/PageHead.astro";
import Base from "../../layouts/Base.astro";
import { breadcrumbList, collectionPageJsonLd } from "../../lib/jsonld";
import { groupSvar } from "../../lib/svar";

// FRÅGOR & SVAR — the full, browsable question list. `groupSvar` arranges the
// corpus into themed sections and drops the cornerstone Five Pillars + six Articles
// of Faith (they live in the FAKTA hub at /vad-ar-islam/), so this index and the
// hub never duplicate each other. A sticky category nav lets a reader jump straight
// to a theme.
const entries = await getCollection("svar");
const groups = groupSvar(entries);
const listed = groups.flatMap((g) => g.entries);

const description =
	"Tydliga, källbelagda svar på vanliga frågor om islam – tro, dyrkan, mat, familj, samhälle och historia. Grundade i Koranen och klassisk sunnitisk lärdom.";
---

<Base
	title="Frågor och svar om islam — islam.se"
	description={description}
	ogImageAlt="Frågor och svar om islam — islam.se"
	jsonLd={[
		collectionPageJsonLd({
			name: "Frågor och svar om islam",
			description,
			url: "/svar/",
			essays: listed.map((e) => ({ title: e.data.title, slug: `svar/${e.id}` })),
		}),
		breadcrumbList([
			{ name: "Hem", url: "/" },
			{ name: "Frågor och svar", url: "/svar/" },
		]),
	]}
>
	<main id="main" class="svar-index home">
		<PageHead title="Frågor & svar om islam">
			Korta, tydliga och källbelagda svar på vanliga frågor om islam – från tro och dyrkan till mat,
			familj, samhälle och historia. Vill du i stället ha grunderna förklarade finns
			<a href="/vad-ar-islam/">de fem pelarna och trosartiklarna</a>; för fördjupade rättsliga frågor
			hänvisar vi till <a href="https://al-ibadah.com" rel="noopener">al-ibadah.com</a>.
		</PageHead>

		{groups.length > 0 ? (
			<>
				<nav class="svar-nav" aria-label="Kategorier">
					<ul>
						{groups.map((g) => (
							<li>
								<a href={`#${g.category.slug}`} data-cat={g.category.slug} class="filter-chip label">{g.category.short ?? g.category.name}</a>
							</li>
						))}
					</ul>
				</nav>

				{groups.map((g) => (
					<section class="svar-section" id={g.category.slug} aria-labelledby={`sc-${g.category.slug}`}>
						<h2 id={`sc-${g.category.slug}`}>{g.category.name}</h2>
						{g.category.intro && <p class="svar-section-intro">{g.category.intro}</p>}
						<ul class="svar-list">
							{g.entries.map((e) => (
								<li class="svar-list-item">
									<a href={`/svar/${e.id}/`}>
										<span class="svar-list-title">{e.data.title}</span>
										<span class="svar-list-desc">{e.data.description}</span>
									</a>
								</li>
							))}
						</ul>
					</section>
				))}
			</>
		) : (
			<p>Inga frågor publicerade ännu.</p>
		)}
	</main>
</Base>

<script>
	// Progressive enhancement: highlight the category chip whose section is in view.
	// Plain anchors already work without this (jump + scroll-margin handle landing).
	function bindSvarNav() {
		const sections = Array.from(document.querySelectorAll<HTMLElement>(".svar-section"));
		const chips = new Map(
			Array.from(document.querySelectorAll<HTMLAnchorElement>(".svar-nav a")).map((a) => [
				a.dataset.cat ?? "",
				a,
			]),
		);
		if (!sections.length || !chips.size) return;

		const obs = new IntersectionObserver(
			(items) => {
				for (const it of items) {
					if (!it.isIntersecting) continue;
					const id = (it.target as HTMLElement).id;
					for (const [cat, chip] of chips)
						chip.setAttribute("aria-current", cat === id ? "true" : "false");
				}
			},
			// Trip when a heading reaches the upper third, under the sticky nav.
			{ rootMargin: "-30% 0px -65% 0px" },
		);
		for (const s of sections) obs.observe(s);
	}

	document.addEventListener("astro:page-load", bindSvarNav);
</script>

<style>
	.svar-index {
		margin-block: var(--space-phi);
	}

	/* Category jump-nav: a wrapping pill row (no horizontal scroll), borrowed from
	   Essäer's filter row so the two index pages divide their content the same way. */
	.svar-nav {
		/* Top gap is owned by .page-head's margin-bottom (shared by every section
		   page); the nav only sets its space down to the first category. */
		margin: 0 0 var(--space-unit);
	}
	.svar-nav ul {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
		margin: 0;
		padding: 0;
		list-style: none;
	}
	/* The pill itself is the shared global `.filter-chip` (+ `.label`), identical to
	   Essäer's filter row. */

	.svar-section {
		margin-top: var(--space-phi);
		/* Anchor jumps land below the sticky nav, not under it. */
		scroll-margin-top: 4rem;
	}
	.svar-section h2 {
		font-size: var(--step-1);
		margin: 0;
	}
	.svar-section-intro {
		font-family: var(--font-body);
		font-size: 1.0625rem;
		line-height: 1.6;
		color: var(--color-muted);
		max-width: 42rem;
		margin: 0.4rem 0 0;
		text-wrap: pretty;
	}

	.svar-list {
		list-style: none;
		margin: var(--space-unit) 0 0;
		padding: 0;
	}
	.svar-list-item {
		border-bottom: 1px solid var(--color-divider);
	}
	.svar-list-item a {
		display: block;
		padding: var(--space-unit) 0;
		text-decoration: none;
	}
	.svar-list-title {
		display: block;
		font-family: var(--font-heading);
		font-weight: 600;
		font-size: 1.0625rem;
		color: var(--color-accent);
	}
	.svar-list-desc {
		display: block;
		font-family: var(--font-body);
		font-size: 0.9375rem;
		line-height: 1.55;
		color: var(--color-muted);
		margin-top: 0.25rem;
		text-wrap: pretty;
	}
	.svar-list-item a:hover .svar-list-title {
		text-decoration: underline;
	}
</style>
