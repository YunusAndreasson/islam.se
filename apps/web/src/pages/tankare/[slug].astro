---
import EssayList from "../../components/EssayList.astro";
import Base from "../../layouts/Base.astro";
import { type Article, essayCount } from "../../lib/articles";
import { breadcrumbList, collectionPageJsonLd } from "../../lib/jsonld";
import { type Tradition, getTankare } from "../../lib/tankare";

export async function getStaticPaths() {
	const thinkers = await getTankare();
	return thinkers.map((thinker) => ({
		params: { slug: thinker.slug },
		props: {
			name: thinker.name,
			framing: thinker.framing,
			tradition: thinker.tradition,
			essays: thinker.essays,
		},
	}));
}

interface Props {
	name: string;
	framing: string;
	tradition: Tradition;
	essays: Article[];
}

const { name, framing, tradition, essays } = Astro.props;
const count = essays.length;
const slug = Astro.params.slug;
const traditionLabel =
	tradition === "sunni" ? "Klassisk islamisk tradition" : "Svensk och västerländsk röst";
---

<Base
	title={`${name} — islam.se`}
	description={`${name} i essäerna: ${framing}`}
	ogImage={`/tankare/${slug}/og.png`}
	jsonLd={[
		collectionPageJsonLd({
			name,
			description: framing,
			url: `/tankare/${slug}`,
			essays,
			// Ties the page to the thinker as an entity — both the classical
			// scholars and the Swedish/Western voices the essays return to.
			extra: {
				about: {
					"@type": "Person",
					name,
					description: framing,
				},
			},
		}),
		breadcrumbList([
			{ name: "Hem", url: "/" },
			{ name: "Tänkare", url: "/tankare" },
			{ name, url: `/tankare/${slug}` },
		]),
	]}
>
	<main id="main" class="content-column">
		<header class="article-header">
			<p class="label collection-kicker">{traditionLabel}</p>
			<h1>{name}</h1>
			<p class="collection-lead">{framing}</p>
			<p class="label collection-count">
				Engageras i {essayCount(count)}
			</p>
		</header>

		<EssayList articles={essays} />

		<p class="collection-back"><a href="/tankare">Alla tänkare →</a></p>
	</main>
</Base>
