---
import AppPromo from "../../components/AppPromo.astro";
import PrayerField from "../../components/bonetider/PrayerField.astro";
import PrayerSettings from "../../components/bonetider/PrayerSettings.astro";
import PrayerTable from "../../components/bonetider/PrayerTable.astro";
import Base from "../../layouts/Base.astro";
import { ORG_ID, breadcrumbList, cityPlace } from "../../lib/jsonld";
import { computePrayerTimes, formatTime, PRAYER_LABELS, PRAYER_ORDER, PRAYER_SWEDISH_NAMES } from "../../lib/bonetider/prayer-times";
import { BONETIDER_DATA_DATE, SCB_POP_YEAR, SCB_REF, SCB_SOURCE } from "../../lib/bonetider/meta";
import { placeFacts } from "../../lib/bonetider/place-facts";
import { type IndexedPlace, INDEXED_PLACES, nearbyPlaces, officialPopulation, OG_POPULATION } from "../../lib/bonetider/places-index";
import { DEFAULT_SETTINGS } from "../../lib/bonetider/settings";

export function getStaticPaths() {
	return INDEXED_PLACES.map((place) => ({ params: { stad: place.slug }, props: { place } }));
}

interface Props {
	place: IndexedPlace;
}
const { place } = Astro.props;
const location = { name: place.name, latitude: place.lat, longitude: place.lon };

// Build-time facts (default MWL method) – evergreen prose, not stale clock values.
const now = new Date();
const times = computePrayerTimes(location, now, DEFAULT_SETTINGS);
const rows = PRAYER_ORDER.map((key) => ({
	key,
	label: PRAYER_LABELS[key],
	sv: PRAYER_SWEDISH_NAMES[key],
	time: formatTime(times[key]),
}));

const lat1 = place.lat.toFixed(2).replace(".", ",");
const lon1 = place.lon.toFixed(2).replace(".", ",");
const highNorth = place.lat >= 62;
const nearby = nearbyPlaces(place, 8);

// Official SCB statistics are present only where we matched a tätort. Everything in
// the stat block + the population claims is gated on this, so unmatched places never
// show a figure we can't stand behind.
const hasScb = place.scbPopulation != null;
const pop = officialPopulation(place);
const facts = placeFacts(place.lat, place.lon);

const nf0 = new Intl.NumberFormat("sv-SE", { maximumFractionDigits: 0 });
const nf1 = new Intl.NumberFormat("sv-SE", { maximumFractionDigits: 1 });

// Visible date for the "Dagens bönetider" block. Static build → this is the build
// date; the inline script below refreshes it to the reader's real today on load, and
// a daily rebuild keeps the crawled value current. Stockholm time = the times' zone.
const todayIso = now.toLocaleDateString("sv-SE", { timeZone: "Europe/Stockholm" });
const todayLabel = new Intl.DateTimeFormat("sv-SE", {
	weekday: "long",
	day: "numeric",
	month: "long",
	year: "numeric",
	timeZone: "Europe/Stockholm",
}).format(now);
// Current year (Stockholm tz) for the title/H1 — searchers add it ("bönetider
// <stad> 2026"), and it lifts perceived freshness on the competitive metro queries.
// Build-time value; the daily rebuild rolls it over each January.
const year = new Intl.DateTimeFormat("sv-SE", { year: "numeric", timeZone: "Europe/Stockholm" }).format(now);
const popText = nf0.format(pop);
const depText = nf1.format(facts.summerMidnightDepressionDeg);

// Swedish ordinal: 1:a, 2:a, 3:e … 11:e, 12:e … 21:a (suffix ":a" for forms ending
// in -a – första/andra – else ":e", with the 11/12 exception).
function ordinal(n: number): string {
	const d1 = n % 10;
	const d2 = n % 100;
	const suffix = (d1 === 1 || d1 === 2) && d2 !== 11 && d2 !== 12 ? ":a" : ":e";
	return `${n}${suffix}`;
}

// Where the place sits, without repeating the name (Stockholm tätort = Stockholm
// kommun) and without genitive-form guessing on county names.
const whereParts: string[] = [];
if (place.kommun && place.kommun !== place.name) whereParts.push(`${place.kommun} kommun`);
if (place.county && place.county !== place.name && place.county !== place.kommun) whereParts.push(place.county);
const where = whereParts.length ? ` i ${whereParts.join(", ")}` : "";

// Direct-answer lead (AEO): a concise, true summary up top – no stale clock values.
const popClause = hasScb ? ` Orten har ${popText} invånare (${SCB_SOURCE}).` : "";
const lead = `Bönetider för ${place.name}${where}.${popClause} Tiderna för Fajr, Shurūq, Ẓuhr, ʿAṣr, Maghrib och ʿIshāʾ beräknas efter solens läge och uppdateras automatiskt varje dag.`;

// Per-place daylight prose – what actually makes each page different by latitude.
const daylightPara =
	facts.midnightSun || facts.polarNight
		? `Så här långt norrut råder midnattssol kring midsommar – solen går inte ner alls – och polarnatt kring midvinter. Då går Fajr och ʿIshāʾ inte att beräkna med den vanliga vinkelmetoden, så regeln närmaste lämpliga plats (Aqrab al-Balad) används i stället.`
		: `I ${place.name} är den ljusaste sommardagen omkring ${facts.summerDayText} och den mörkaste vinterdagen ${facts.winterDayText}. Vid sommarsolståndet sjunker solen som mest ${depText}° under horisonten – mindre än de 18° som krävs för astronomisk natt – vilket är varför Fajr och ʿIshāʾ ligger nära varandra i juni och beräknas med regeln för höga latituder.`;

const description = `Bönetider för ${place.name} (${place.county || "Sverige"}) ${year}: exakta tider för Fajr, Shurūq, Ẓuhr, ʿAṣr, Maghrib och ʿIshāʾ varje dag, beräknade efter solens läge. Välj beräkningsmetod och madhhab.`;

const ogImage = place.population >= OG_POPULATION ? `/bonetider/${place.slug}/og.png` : "/bonetider/og.png";

// Machine-readable provenance for the WebPage (isBasedOn) – the same sources as
// the visible footer attribution, so the data origin is legible to crawlers.
// External works the page is based on, expressed as CreativeWork (not Dataset):
// `isBasedOn` accepts the supertype, and typing these as Dataset made Google
// validate each as a standalone Dataset rich result — flooding Search Console
// with "missing description/creator/license" across every city page.
const sources: Record<string, unknown>[] = [
	{ "@type": "CreativeWork", name: "GeoNames", url: "https://www.geonames.org/", license: "https://creativecommons.org/licenses/by/4.0/" },
	{ "@type": "SoftwareSourceCode", name: "adhan", url: "https://github.com/batoulapps/adhan-js" },
];
if (hasScb) {
	sources.unshift({
		"@type": "CreativeWork",
		name: `${SCB_SOURCE} (${SCB_REF})`,
		creator: { "@type": "GovernmentOrganization", name: "Statistiska centralbyrån" },
	});
}

const faq = [
	{
		q: `När börjar Fajr i ${place.name}?`,
		a: `Fajr är dagens första bön och inträder vid gryningen, när det första ljuset visar sig en stund före soluppgången. Den exakta Fajr-tiden för ${place.name} ändras varje dygn och står högst upp under Dagens bönetider, där den räknas om automatiskt.`,
	},
	{
		q: `När är Maghrib i ${place.name}?`,
		a: `Maghrib är bönen direkt efter solnedgången och är den tid då fastan bryts under ramadan. Tiden följer solnedgången och skiftar dag för dag – aktuell Maghrib-tid för ${place.name} visas i listan över dagens bönetider ovan.`,
	},
	{
		q: `Vad kallas bönetiderna på arabiska?`,
		a: `Bönen heter på arabiska ṣalāh (صلاة) och själva tidtabellen awqāt aṣ-ṣalāh; på turkiska och bosniska används ordet namaz. De fem dagliga bönerna i ${place.name} är Fajr, Ẓuhr, ʿAṣr, Maghrib och ʿIshāʾ.`,
	},
	{
		q: `Vilken metod används för bönetiderna i ${place.name}?`,
		a: "Standardmetoden är Muslim World League (Fajr 18°, Isha 17°), som rekommenderas för svenska latituder. Du kan byta till Diyanet, Umm al-Qura, ISNA med flera i inställningarna – kartan och tiderna uppdateras direkt.",
	},
	{
		q: "Hur får jag tiderna att stämma med min moské?",
		a: "Välj samma beräkningsmetod och madhhab som din moské, och justera vid behov enskilda böner med minuter under Avancerat. Inställningarna sparas lokalt i din webbläsare.",
	},
	{
		q: `Varför kan Fajr och ʿIshāʾ vara svåra att beräkna på sommaren i ${place.name}?`,
		a: highNorth
			? "Så här långt norrut blir sommarnatten ofta så ljus att solen aldrig sjunker tillräckligt djupt under horisonten för den vanliga vinkelberäkningen. Då används regeln 'närmaste lämpliga plats' (Aqrab al-Balad) så att tider ändå kan visas."
			: "Vid höga latituder kan natten bli för ljus för den vanliga vinkelberäkningen. Inställningen för höga latituder (automatiskt vald) hanterar detta så att tider ändå kan visas.",
	},
];
if (hasScb) {
	const subject = place.scbName ? `tätorten ${place.scbName}` : place.name;
	const densityClause = place.densityPerKm2
		? `, med en befolkningstäthet på ${nf0.format(place.densityPerKm2)} invånare per kvadratkilometer`
		: "";
	faq.push({
		q: `Hur många invånare har ${place.name}?`,
		a: `Enligt ${SCB_SOURCE} (${SCB_REF}) har ${subject} ${popText} invånare${densityClause}.`,
	});
}
---

<Base
	title={`Bönetider i ${place.name} ${year} — islam.se`}
	description={description}
	ogImage={ogImage}
	ogImageAlt={`Bönetider i ${place.name} — dagens tider för Fajr, Shurūq, Ẓuhr, ʿAṣr, Maghrib och ʿIshāʾ`}
	jsonLd={[
		{
			"@context": "https://schema.org",
			"@type": "WebPage",
			name: `Bönetider i ${place.name}`,
			description,
			url: `https://islam.se/bonetider/${place.slug}/`,
			inLanguage: "sv",
			dateModified: BONETIDER_DATA_DATE,
			about: cityPlace({
				name: place.name,
				county: place.county,
				lat: place.lat,
				lon: place.lon,
				kommun: place.kommun,
				population: hasScb ? pop : undefined,
				populationYear: SCB_POP_YEAR,
			}),
			isBasedOn: sources,
			publisher: { "@id": ORG_ID },
		},
		{
			"@context": "https://schema.org",
			"@type": "FAQPage",
			mainEntity: faq.map((f) => ({
				"@type": "Question",
				name: f.q,
				acceptedAnswer: { "@type": "Answer", text: f.a },
			})),
		},
		breadcrumbList([
			{ name: "Hem", url: "/" },
			{ name: "Bönetider", url: "/bonetider" },
			{ name: place.name, url: `/bonetider/${place.slug}` },
		]),
	]}
>
	<main id="main" class="home bonetider-stad">
		<nav class="bt-crumbs" aria-label="Brödsmulor">
			<a href="/">Hem</a> <span aria-hidden="true">/</span>
			<a href="/bonetider/">Bönetider</a> <span aria-hidden="true">/</span>
			<span aria-current="page">{place.name}</span>
		</nav>

		<header class="bt-stad-header">
			<p class="label">Bönetider</p>
			<h1>Bönetider i {place.name} {year}</h1>
			<p class="bt-stad-sub">
				{place.county ? `${place.county} · ` : ""}{lat1}° N, {lon1}° O
			</p>
			<p class="bt-stad-lead">{lead}</p>
		</header>

		<PrayerField location={location} variant="full" fixed={true} />

		<section class="bt-stad-section" aria-labelledby="bt-stad-idag">
			<h2 id="bt-stad-idag">Dagens bönetider i {place.name}</h2>
			<p class="bt-stad-date">
				I dag · <time datetime={todayIso} class="bt-today-date">{todayLabel}</time>
			</p>
			<p class="bt-stad-note">
				Tiderna nedan beräknas live i din webbläsare. Sveriges ljusa sommarnätter gör att Fajr och
				ʿIshāʾ ligger nära varandra – kartan ovan visar varför: solen sjunker bara en bit under
				horisonten.
			</p>
			<ul
				class="bt-stad-today bonetider-readout"
				data-name={place.name}
				data-lat={place.lat}
				data-lon={place.lon}
				data-fixed="1"
				aria-label={`Bönetider för ${place.name} i dag`}
			>
				{rows.map((r) => (
					<li data-prayer={r.key}>
						<span class="bt-st-name">{r.label}</span>
						<span class="bt-st-sv">{r.sv}</span>
						<span class="bt-st-time bf-t-time">{r.time}</span>
					</li>
				))}
			</ul>
		</section>

		<AppPromo variant="section" />

		{hasScb && (
			<section class="bt-stad-section" aria-labelledby="bt-stad-fakta">
				<h2 id="bt-stad-fakta">Fakta om {place.name}</h2>
				<dl class="bt-facts">
					<div class="bt-fact">
						<dt>Invånare</dt>
						<dd>
							{popText}
							{place.scbName ? <span class="bt-fact-note"> (tätorten {place.scbName})</span> : null}
						</dd>
					</div>
					{place.kommun && (
						<div class="bt-fact">
							<dt>Kommun</dt>
							<dd>{place.kommun}</dd>
						</div>
					)}
					{place.county && (
						<div class="bt-fact">
							<dt>Län</dt>
							<dd>{place.county}</dd>
						</div>
					)}
					{place.landAreaKm2 != null && (
						<div class="bt-fact">
							<dt>Landareal</dt>
							<dd>{nf1.format(place.landAreaKm2)} km²</dd>
						</div>
					)}
					{place.densityPerKm2 != null && (
						<div class="bt-fact">
							<dt>Befolkningstäthet</dt>
							<dd>{nf0.format(place.densityPerKm2)} inv./km²</dd>
						</div>
					)}
					{place.scbRank != null && (
						<div class="bt-fact">
							<dt>Storleksrang</dt>
							<dd>Sveriges {ordinal(place.scbRank)} största tätort</dd>
						</div>
					)}
					<div class="bt-fact">
						<dt>Koordinater</dt>
						<dd>{lat1}° N, {lon1}° O</dd>
					</div>
				</dl>
				<p class="bt-facts-src">Källa: {SCB_SOURCE} ({SCB_REF}).</p>
			</section>
		)}

		<section class="bt-stad-section bt-prose" aria-labelledby="bt-stad-about">
			<h2 id="bt-stad-about">Om bönetiderna i {place.name}</h2>
			<p>
				{place.name} ligger {place.county ? `i ${place.county}, ` : ""}på {lat1}° nordlig bredd.
				Bönetiderna beräknas utifrån solens verkliga läge för just denna position – inte från en
				tabell – så att de stämmer med dygnet på orten.
			</p>
			<p>{daylightPara}</p>
			<p>
				Tiderna gäller tidszonen Europe/Stockholm och växlar automatiskt mellan vinter- och
				sommartid. Vill du finjustera mot din moské kan du byta metod och madhhab nedan, eller läsa
				mer om <a href="/bonetider/metod/">hur tiderna beräknas</a>.
			</p>
		</section>

		<section class="bt-stad-section" aria-labelledby="bt-stad-settings">
			<h2 id="bt-stad-settings">Inställningar</h2>
			<PrayerSettings />
		</section>

		<section class="bt-stad-section" aria-labelledby="bt-stad-month">
			<h2 id="bt-stad-month">Månadens bönetider</h2>
			<PrayerTable location={location} />
		</section>

		<section class="bt-stad-section" aria-labelledby="bt-stad-faq">
			<h2 id="bt-stad-faq">Vanliga frågor</h2>
			<dl class="bt-faq">
				{faq.map((f) => (
					<div class="bt-faq-item">
						<dt>{f.q}</dt>
						<dd>{f.a}</dd>
					</div>
				))}
			</dl>
			<p class="bt-faq-more">
				<a href="/bonetider/metod/">Mer om hur bönetiderna beräknas →</a>
			</p>
		</section>

		{nearby.length > 0 && (
			<section class="bt-stad-section" aria-labelledby="bt-stad-nearby">
				<h2 id="bt-stad-nearby">Bönetider i närliggande orter</h2>
				<ul class="bt-nearby">
					{nearby.map((p) => (
						<li><a href={`/bonetider/${p.slug}/`}>{p.name}</a></li>
					))}
				</ul>
			</section>
		)}

		<p class="bt-attrib">
			Befolkningsstatistik: {SCB_SOURCE} ({SCB_REF}). Ortsdata från GeoNames (CC BY 4.0). Beräkningar
			med <span lang="en">adhan</span> i tidszonen Europe/Stockholm. <a href="/bonetider/metod/">Om beräkningen</a> ·
			<a href="/bonetider/">Alla orter →</a>
		</p>
	</main>
</Base>

<style>
	.bonetider-stad {
		margin-block: var(--space-phi);
		/* Guard against any child overflowing the viewport on mobile (e.g. the
		   today readout's tabular times); clip keeps sticky/position working. */
		overflow-x: clip;
	}

	.bt-crumbs {
		font-family: var(--font-heading);
		font-size: 0.8125rem;
		color: var(--color-muted);
		margin-bottom: var(--space-unit);
	}

	.bt-crumbs a {
		color: var(--color-accent);
		text-decoration: none;
	}

	.bt-crumbs a:hover {
		text-decoration: underline;
	}

	.bt-stad-header h1 {
		margin: var(--space-half) 0 0;
	}

	.bt-stad-sub {
		font-family: var(--font-body);
		color: var(--color-muted);
		font-variant-numeric: lining-nums tabular-nums;
		margin: var(--space-half) 0 0;
	}

	.bt-stad-lead {
		font-family: var(--font-body);
		font-size: 1.0625rem;
		line-height: 1.6;
		color: color-mix(in srgb, var(--color-text) 88%, var(--color-muted));
		max-width: 42rem;
		margin: var(--space-unit) 0 0;
		text-wrap: pretty;
	}

	.bt-stad-section {
		margin-top: var(--space-phi);
	}

	.bt-stad-section h2 {
		font-size: var(--step-1);
	}

	.bt-stad-date {
		font-family: var(--font-heading);
		font-size: 0.875rem;
		color: var(--color-muted);
		margin: var(--space-half) 0 0;
	}

	.bt-stad-date time {
		color: var(--color-text);
		text-transform: capitalize;
	}

	.bt-stad-note {
		font-family: var(--font-body);
		color: var(--color-muted);
		max-width: 40rem;
		margin: var(--space-half) 0 var(--space-unit);
		text-wrap: pretty;
	}

	.bt-stad-today {
		list-style: none;
		margin: 0;
		padding: 0;
		display: grid;
		gap: var(--space-half) clamp(1rem, 4vw, 2.5rem);
		grid-template-columns: repeat(auto-fit, minmax(min(100%, 9rem), 1fr));
	}

	.bt-stad-today li {
		display: grid;
		grid-template-columns: 1fr auto;
		grid-template-areas: "name time" "sv time";
		column-gap: 0.75rem;
		align-items: baseline;
		padding: 0.4rem 0;
		border-bottom: 1px solid var(--color-divider);
	}

	.bt-st-name {
		grid-area: name;
		font-family: var(--font-heading);
		font-weight: 600;
		color: var(--color-text);
	}

	.bt-st-sv {
		grid-area: sv;
		font-family: var(--font-body);
		font-size: 0.8rem;
		color: var(--color-muted);
	}

	.bt-st-time {
		grid-area: time;
		align-self: center;
		font-family: var(--font-body);
		font-variant-numeric: lining-nums tabular-nums;
		font-size: 1.05rem;
		color: var(--color-text);
	}

	/* The live script marks the upcoming prayer with .is-next (same as the field) –
	   give it the same quiet brass accent so the list and the map agree. */
	.bt-stad-today li.is-next .bt-st-name,
	.bt-stad-today li.is-next .bt-st-time {
		color: var(--color-accent);
	}

	/* Official-stats block. Reserved, static layout → no CLS. */
	.bt-facts {
		margin: var(--space-half) 0 0;
		padding: 0;
		display: grid;
		gap: var(--space-half) clamp(1rem, 4vw, 2.5rem);
		grid-template-columns: repeat(auto-fit, minmax(min(100%, 12rem), 1fr));
		max-width: 46rem;
	}

	.bt-fact {
		margin: 0;
		padding: 0.4rem 0;
		border-bottom: 1px solid var(--color-divider);
	}

	.bt-fact dt {
		font-family: var(--font-heading);
		font-size: 0.8125rem;
		color: var(--color-muted);
		margin: 0 0 0.15rem;
	}

	.bt-fact dd {
		margin: 0;
		font-family: var(--font-body);
		font-variant-numeric: lining-nums tabular-nums;
		color: var(--color-text);
	}

	.bt-fact-note {
		font-size: 0.85rem;
		color: var(--color-muted);
		font-variant-numeric: normal;
	}

	.bt-facts-src {
		font-family: var(--font-body);
		font-size: 0.8125rem;
		color: var(--color-muted);
		margin: var(--space-unit) 0 0;
	}

	.bt-prose p {
		font-family: var(--font-body);
		font-size: 1.0625rem;
		line-height: 1.6;
		color: color-mix(in srgb, var(--color-text) 88%, var(--color-muted));
		max-width: 42rem;
		margin: 0 0 var(--space-half);
		text-wrap: pretty;
	}

	.bt-prose a {
		color: var(--color-accent);
	}

	.bt-faq {
		margin: var(--space-unit) 0 0;
		max-width: 42rem;
	}

	.bt-faq-item {
		padding: var(--space-half) 0;
		border-bottom: 1px solid var(--color-divider);
	}

	.bt-faq dt {
		font-family: var(--font-heading);
		font-weight: 600;
		color: var(--color-accent);
		margin-bottom: 0.3rem;
	}

	.bt-faq dd {
		font-family: var(--font-body);
		line-height: 1.55;
		color: var(--color-muted);
		margin: 0;
	}

	.bt-faq-more {
		font-family: var(--font-body);
		font-size: 0.9375rem;
