<script>
	// The page is statically built, so the server-rendered date is the build date.
	// Refresh it to the reader's real today on load (and across view-transition
	// navigations) so "Dagens bönetider" always names the correct day. Times zone =
	// Europe/Stockholm, matching the prayer-time calculation.
	document.addEventListener("astro:page-load", () => {
		const el = document.querySelector<HTMLTimeElement>(".bt-today-date");
		if (!el) return;
		const now = new Date();
		const tz = { timeZone: "Europe/Stockholm" } as const;
		el.setAttribute("datetime", now.toLocaleDateString("sv-SE", tz));
		el.textContent = now.toLocaleDateString("sv-SE", {
			weekday: "long",
			day: "numeric",
			month: "long",
			year: "numeric",
			...tz,
		});
	});
</script>
