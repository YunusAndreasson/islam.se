---
import { render } from "astro:content";
import Base from "../layouts/Base.astro";
import type { Article } from "../lib/articles";
import { formatDate, getArticles } from "../lib/articles";

export async function getStaticPaths() {
	const articles = await getArticles();
	return articles.map((article, index) => ({
		params: { slug: article.slug },
		props: {
			article,
			prev: articles[index - 1] ?? null,
			next: articles[index + 1] ?? null,
		},
	}));
}

interface Props {
	article: Article;
	prev: Article | null;
	next: Article | null;
}

const { article, prev, next } = Astro.props;
const { Content } = await render(article.entry);
---

<Base
	title={`${article.title} — islam.se`}
	description={article.description}
	ogImage={article.heroImage?.src}
	articleMeta={{ publishedAt: article.publishedAt, wordCount: article.wordCount, description: article.description, slug: article.slug }}
>
	<main class="content-column">
		<article>
			<header class="article-header">
				<h1>{article.title}</h1>
				<p class="article-meta">
					<time datetime={article.publishedAt}>{formatDate(article.publishedAt)}</time> &middot; {article.readingTime} min &middot;
					<button class="share-btn" type="button" aria-label="Dela essän">
						<svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
							<path d="M5 6.5L8 3m0 0l3 3.5M8 3v8M3 10v2a1 1 0 001 1h8a1 1 0 001-1v-2" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round" />
						</svg>
						Dela
					</button>
				</p>
			</header>

			<div class="article-body prose">
				<Content />
			</div>
		</article>

		<nav class="article-nav" aria-label="Föregående och nästa essä">
			{prev && (
				<a href={`/${prev.slug}`} rel="prev">
					<span class="nav-label">Föregående</span>
					{prev.title}
				</a>
			)}
			{next && (
				<a href={`/${next.slug}`} rel="next">
					<span class="nav-label">Nästa</span>
					{next.title}
				</a>
			)}
		</nav>
	</main>
</Base>

<script>
	import { navigate } from "astro:transitions/client";

	document.addEventListener("astro:page-load", () => {
		if (!document.querySelector(".article-body")) return;
		const ctrl = new AbortController();
		document.addEventListener("keydown", (e) => {
			if (e.target instanceof HTMLElement && e.target.matches("input, textarea, select")) return;
			if (e.key === "Escape" && !document.querySelector(".fn-popover--visible")) navigate("/essaer");
		}, { signal: ctrl.signal });

		const shareBtn = document.querySelector<HTMLButtonElement>(".share-btn");
		if (shareBtn) {
			shareBtn.addEventListener("click", async () => {
				const title = document.querySelector("h1")?.textContent ?? "";
				const url = window.location.href;
				if (navigator.share) {
					await navigator.share({ title, url }).catch(() => {});
				} else {
					await navigator.clipboard.writeText(url);
					const label = shareBtn.querySelector("svg")?.nextSibling;
					if (label) {
						const orig = label.textContent;
						label.textContent = " Kopierad!";
						setTimeout(() => { label.textContent = orig; }, 2000);
					}
				}
			}, { signal: ctrl.signal });
		}

		// Swipe between articles
		const prevLink = document.querySelector<HTMLAnchorElement>(".article-nav a[rel=prev]");
		const nextLink = document.querySelector<HTMLAnchorElement>(".article-nav a[rel=next]");
		if (prevLink || nextLink) {
			let startX = 0;
			let startY = 0;
			document.addEventListener("touchstart", (e) => {
				startX = e.touches[0].clientX;
				startY = e.touches[0].clientY;
			}, { passive: true, signal: ctrl.signal });
			document.addEventListener("touchend", (e) => {
				const dx = e.changedTouches[0].clientX - startX;
				const dy = e.changedTouches[0].clientY - startY;
				if (Math.abs(dx) > 80 && Math.abs(dx) > Math.abs(dy) * 2) {
					if (dx > 0 && prevLink) navigate(prevLink.href);
					else if (dx < 0 && nextLink) navigate(nextLink.href);
				}
			}, { passive: true, signal: ctrl.signal });
		}

		// Footnote popovers — hover on desktop, click on touch
		const popover = document.createElement("div");
		popover.className = "fn-popover";
		popover.setAttribute("role", "tooltip");
		document.body.appendChild(popover);
		let hideTimer: ReturnType<typeof setTimeout> | null = null;
		let isTouch = false;

		function positionPopover(anchor: Element) {
			const rect = anchor.getBoundingClientRect();
			popover.classList.add("fn-popover--visible");
			const popW = popover.offsetWidth;
			const pad = 12;
			let left = rect.left + window.scrollX + rect.width / 2 - popW / 2;
			left = Math.max(pad, Math.min(left, window.innerWidth - popW - pad));
			popover.style.top = `${rect.bottom + window.scrollY + 8}px`;
			popover.style.left = `${left}px`;
		}

		function showPopover(ref: HTMLAnchorElement) {
			const fnId = ref.getAttribute("href")?.replace("#", "");
			if (!fnId) return;
			const fnLi = document.getElementById(fnId);
			if (!fnLi) return;

			if (hideTimer) { clearTimeout(hideTimer); hideTimer = null; }

			const clone = fnLi.cloneNode(true) as HTMLElement;
			for (const backref of clone.querySelectorAll(".data-footnote-backref")) backref.remove();
			popover.innerHTML = clone.innerHTML;
			popover.setAttribute("data-fn-id", fnId);
			positionPopover(ref.closest("sup") ?? ref);
		}

		function showHonorificPopover(el: HTMLElement) {
			const title = el.getAttribute("title");
			if (!title) return;
			if (hideTimer) { clearTimeout(hideTimer); hideTimer = null; }
			popover.textContent = title;
			popover.setAttribute("data-fn-id", "honorific");
			positionPopover(el);
		}

		function dismissPopover() {
			popover.classList.remove("fn-popover--visible");
			popover.removeAttribute("data-fn-id");
		}

		function scheduleDismiss() {
			hideTimer = setTimeout(dismissPopover, 200);
		}

		// Detect touch devices
		document.addEventListener("touchstart", () => { isTouch = true; }, { once: true, passive: true, signal: ctrl.signal });

		// Hover: show on mouseenter, hide on mouseleave (with grace period)
		document.addEventListener("mouseenter", (e) => {
			if (isTouch) return;
			const target = e.target as HTMLElement;
			const ref = target.closest<HTMLAnchorElement>("a[data-footnote-ref]");
			if (ref) { showPopover(ref); return; }
			const hon = target.closest<HTMLElement>(".honorific");
			if (hon) showHonorificPopover(hon);
		}, { capture: true, signal: ctrl.signal });

		document.addEventListener("mouseleave", (e) => {
			if (isTouch) return;
			const target = e.target as HTMLElement;
			if (target.closest("a[data-footnote-ref]") || target.closest(".honorific")) scheduleDismiss();
		}, { capture: true, signal: ctrl.signal });

		// Keep popover visible while hovering over it
		popover.addEventListener("mouseenter", () => {
			if (hideTimer) { clearTimeout(hideTimer); hideTimer = null; }
		});
		popover.addEventListener("mouseleave", scheduleDismiss);

		// Click: prevent default jump; on touch devices toggle popover
		document.addEventListener("click", (e) => {
			const target = e.target as HTMLElement;
			const ref = target.closest<HTMLAnchorElement>("a[data-footnote-ref]");
			if (ref) {
				e.preventDefault();
				if (isTouch) {
					const fnId = ref.getAttribute("href")?.replace("#", "");
					if (popover.getAttribute("data-fn-id") === fnId && popover.classList.contains("fn-popover--visible")) {
						dismissPopover();
					} else {
						showPopover(ref);
					}
				}
				return;
			}
			const hon = target.closest<HTMLElement>(".honorific");
			if (hon && isTouch) {
				if (popover.getAttribute("data-fn-id") === "honorific" && popover.classList.contains("fn-popover--visible")) {
					dismissPopover();
				} else {
					showHonorificPopover(hon);
				}
				return;
			}
			if (!popover.contains(target)) {
				dismissPopover();
			}
		}, { signal: ctrl.signal });

		document.addEventListener("keydown", (e) => {
			if (e.key === "Escape" && popover.classList.contains("fn-popover--visible")) {
				e.stopPropagation();
				dismissPopover();
			}
		}, { capture: true, signal: ctrl.signal });

		document.addEventListener("astro:before-swap", () => { ctrl.abort(); popover.remove(); }, { once: true });
	});
</script>
