---
import { render } from "astro:content";
import AudioPlayer from "../components/AudioPlayer.astro";
import EssayConnections from "../components/EssayConnections.astro";
import EssayImage from "../components/EssayImage.astro";
import Base from "../layouts/Base.astro";
import { amneByName } from "../lib/amnen";
import type { Article } from "../lib/articles";
import { formatDate, getArticles } from "../lib/articles";

export async function getStaticPaths() {
	const articles = await getArticles();
	return articles.map((article, index) => ({
		params: { slug: article.slug },
		props: {
			article,
			prev: articles[index - 1] ?? null,
			next: articles[index + 1] ?? null,
		},
	}));
}

interface Props {
	article: Article;
	prev: Article | null;
	next: Article | null;
}

const { article, prev, next } = Astro.props;
const { Content } = await render(article.entry);
const amne = article.category ? amneByName.get(article.category) : undefined;
---

<Base
	title={`${article.title} — islam.se`}
	description={article.description}
	ogImage={`/og/${article.slug}.png`}
	articleMeta={{ publishedAt: article.publishedAt, wordCount: article.wordCount, description: article.description, slug: article.slug }}
>
	<main id="main" class="content-column">
		<article>
			<header class="article-header">
				{amne && (
					<p class="label article-kicker"><a href={`/amnen/${amne.slug}`}>{amne.name}</a></p>
				)}
				<h1>{article.title}</h1>
				<p class="label article-meta">
					<time datetime={article.publishedAt}>{formatDate(article.publishedAt)}</time> &middot; {article.readingTime} min läsning
				</p>
			</header>

			{article.heroImage && (
				<figure class="article-hero media-frame" transition:name={`hero-${article.slug}`}>
					<EssayImage
						article={article}
						widths={[640, 960, 1280]}
						sizes="(max-width: 768px) 100vw, 42rem"
						loading="eager"
						fetchpriority="high"
					/>
				</figure>
			)}

			{article.audioFile && <AudioPlayer src={`/audio/${article.audioFile}`} title={article.title} artwork={article.heroImage?.src} />}

			<div class="article-body prose">
				<Content />
			</div>
		</article>

		<EssayConnections slug={article.slug} />

		<nav class="article-nav" aria-label="Nyare och äldre essä">
			{prev && (
				<a href={`/${prev.slug}`} rel="prev">
					<span class="label nav-label">← Nyare</span>
					{prev.title}
				</a>
			)}
			{next && (
				<a href={`/${next.slug}`} rel="next">
					<span class="label nav-label">Äldre →</span>
					{next.title}
				</a>
			)}
		</nav>
	</main>

	<button class="resume-pill label" type="button" hidden>Fortsätt där du slutade</button>
</Base>

<style>
	/* The essay's ämne, set above the title as a quiet small-caps link — the same
	   register the collection pages use as their kicker, so an essay reads as
	   filed under its ämne from the first line. */
	.article-kicker {
		margin-bottom: var(--space-half);
		color: var(--color-muted);
	}

	.article-kicker a {
		color: var(--color-accent);
		text-decoration: none;

		&:hover {
			text-decoration: underline;
			text-underline-offset: 0.15em;
		}

		&:focus-visible {
			outline: 2px solid var(--color-accent);
			outline-offset: 2px;
			border-radius: 2px;
		}
	}

	/* A contained hero at the head of each essay — column-width, seated in the
	   shared media frame (grain + vignette + soft corners from .media-frame). The
	   crop is pinned via :global(img) because the <img> carries EssayImage's own
	   style scope, so a plain scoped rule would never reach it. */
	.article-hero {
		margin: var(--space-unit) 0 var(--space-phi);
	}

	/* Cover fit is shared on .media-frame (layout.css); only the crop is per-page.
	   No hover bloom here — the hero is a <figure>, not a link. */
	.article-hero :global(img) {
		aspect-ratio: 3 / 2;
	}

	@media (width <= 768px) {
		.article-hero {
			margin-bottom: var(--space-unit);
		}
	}

	/* "Continue where you left off" — appears only when this essay was left
	   part-read (saved scroll progress). A quiet pill at the bottom-centre that
	   scrolls to the saved spot, then gets out of the way. Sits clear of the
	   bottom-right fixed actions (share / back-to-top). */
	.resume-pill {
		position: fixed;
		left: 50%;
		bottom: calc(var(--safe-bottom, 0px) + 1.25rem);
		transform: translateX(-50%) translateY(0.5rem);
		z-index: 50;
		padding: 0.6rem 1.1rem;
		border: 1px solid var(--color-divider);
		border-radius: 1.5rem;
		background: var(--color-bg);
		color: var(--color-accent);
		cursor: pointer;
		box-shadow: 0 2px 14px color-mix(in srgb, var(--color-text), transparent 86%);
		opacity: 0;
		transition: opacity 0.25s ease, transform 0.25s ease;
	}

	.resume-pill[data-visible] {
		opacity: 1;
		transform: translateX(-50%) translateY(0);
	}

	.resume-pill:hover {
		border-color: var(--color-warm);
		color: var(--color-text);
	}

	.resume-pill:focus-visible {
		outline: 2px solid var(--color-accent);
		outline-offset: 2px;
	}

	@media (prefers-reduced-motion: reduce) {
		.resume-pill {
			transition: opacity 0.25s ease;
			transform: translateX(-50%);
		}
		.resume-pill[data-visible] {
			transform: translateX(-50%);
		}
	}
</style>

<script>
	import { navigate } from "astro:transitions/client";

	document.addEventListener("astro:page-load", () => {
		if (!document.querySelector(".article-body")) return;
		const ctrl = new AbortController();

		// Resume reading — offer to jump back to the saved scroll position when this
		// essay was left part-read. The pill scrolls there, then bows out; it also
		// retires itself once the reader passes the saved spot on their own.
		const resumeSlug = document.querySelector<HTMLElement>(".reading-progress")?.dataset.slug;
		const pill = document.querySelector<HTMLButtonElement>(".resume-pill");
		if (resumeSlug && pill) {
			const savedPct = +(localStorage.getItem(`rp:${resumeSlug}`) || 0);
			if (savedPct > 0.06 && savedPct < 0.85) {
				const reveal = () => { pill.hidden = false; requestAnimationFrame(() => pill.setAttribute("data-visible", "")); };
				const retire = () => {
					pill.removeAttribute("data-visible");
					setTimeout(() => { pill.hidden = true; }, 280);
				};
				// Hold off a beat so it reads as an offer, not a flash on load.
				setTimeout(reveal, 600);
				pill.addEventListener("click", () => {
					const reduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
					const target = (document.documentElement.scrollHeight - window.innerHeight) * savedPct;
					window.scrollTo({ top: target, behavior: reduced ? "instant" : "smooth" });
					retire();
				}, { signal: ctrl.signal });
				window.addEventListener("scroll", () => {
					const scrollable = document.documentElement.scrollHeight - window.innerHeight;
					if (scrollable > 0 && window.scrollY / scrollable >= savedPct - 0.02) retire();
				}, { passive: true, signal: ctrl.signal });
			}
		}

		// Move footnotes below article-nav for easier access to prev/next
		const footnotes = document.querySelector(".article-body .footnotes");
		const nav = document.querySelector(".article-nav");
		if (footnotes && nav) {
			footnotes.classList.remove("footnotes");
			footnotes.classList.add("footnotes-relocated");
			nav.after(footnotes);
		}
		document.addEventListener("keydown", (e) => {
			if (e.target instanceof HTMLElement && e.target.matches("input, textarea, select")) return;
			if (e.key === "Escape" && !document.querySelector(".fn-popover--visible")) navigate("/essaer");
		}, { signal: ctrl.signal });

		// Swipe between articles
		const prevLink = document.querySelector<HTMLAnchorElement>(".article-nav a[rel=prev]");
		const nextLink = document.querySelector<HTMLAnchorElement>(".article-nav a[rel=next]");
		if (prevLink || nextLink) {
			let startX = 0;
			let startY = 0;
			document.addEventListener("touchstart", (e) => {
				startX = e.touches[0].clientX;
				startY = e.touches[0].clientY;
			}, { passive: true, signal: ctrl.signal });
			document.addEventListener("touchend", (e) => {
				const dx = e.changedTouches[0].clientX - startX;
				const dy = e.changedTouches[0].clientY - startY;
				if (Math.abs(dx) > 80 && Math.abs(dx) > Math.abs(dy) * 2) {
					if (dx > 0 && prevLink) navigate(prevLink.href);
					else if (dx < 0 && nextLink) navigate(nextLink.href);
				}
			}, { passive: true, signal: ctrl.signal });
		}

		// Footnote popovers — hover on desktop, click on touch
		const popover = document.createElement("div");
		popover.className = "fn-popover";
		popover.setAttribute("role", "tooltip");
		document.body.appendChild(popover);
		let hideTimer: ReturnType<typeof setTimeout> | null = null;
		const isTouch = window.matchMedia("(hover: none) and (pointer: coarse)").matches;

		function positionPopover(anchor: Element) {
			const rect = anchor.getBoundingClientRect();
			popover.classList.add("fn-popover--visible");
			const popW = popover.offsetWidth;
			const popH = popover.offsetHeight;
			const pad = 12;
			const gap = 8;
			let left = rect.left + window.scrollX + rect.width / 2 - popW / 2;
			left = Math.max(pad, Math.min(left, window.innerWidth - popW - pad));
			// Prefer above; fall back to below if not enough room
			const above = rect.top - gap - popH;
			if (above >= pad) {
				popover.style.top = `${rect.top + window.scrollY - gap - popH}px`;
			} else {
				popover.style.top = `${rect.bottom + window.scrollY + gap}px`;
			}
			popover.style.left = `${left}px`;
		}

		function showPopover(ref: HTMLAnchorElement) {
			const fnId = ref.getAttribute("href")?.replace("#", "");
			if (!fnId) return;
			const fnLi = document.getElementById(fnId);
			if (!fnLi) return;

			if (hideTimer) { clearTimeout(hideTimer); hideTimer = null; }

			const clone = fnLi.cloneNode(true) as HTMLElement;
			for (const backref of clone.querySelectorAll(".data-footnote-backref")) backref.remove();
			popover.innerHTML = clone.innerHTML;
			popover.setAttribute("data-fn-id", fnId);
			positionPopover(ref.closest("sup") ?? ref);
		}

		const honorificTitles: Record<string, string> = {
			swt: "Jalla jalāluhu — upphöjd är Hans majestät",
			saw: "Ṣallallāhu ʿalayhi wa-sallam — Guds frid och välsignelser vare med honom",
		};

		function showHonorificPopover(el: HTMLElement) {
			const code = el.classList.contains("honorific--swt") ? "swt" : el.classList.contains("honorific--saw") ? "saw" : null;
			const title = code ? honorificTitles[code] : null;
			if (!title) return;
			if (hideTimer) { clearTimeout(hideTimer); hideTimer = null; }
			popover.textContent = title;
			popover.setAttribute("data-fn-id", "honorific");
			positionPopover(el);
		}

		function dismissPopover() {
			popover.classList.remove("fn-popover--visible");
			popover.removeAttribute("data-fn-id");
		}

		function scheduleDismiss() {
			hideTimer = setTimeout(dismissPopover, 200);
		}

		// Prevent footnote links from navigating — capture phase runs before Astro's router
		document.addEventListener("click", (e) => {
			if ((e.target as HTMLElement).closest("a[data-footnote-ref]")) e.preventDefault();
		}, { capture: true, signal: ctrl.signal });

		// Hover: show on mouseenter, hide on mouseleave (with grace period)
		document.addEventListener("mouseenter", (e) => {
			if (isTouch) return;
			const target = e.target as HTMLElement;
			const ref = target.closest<HTMLAnchorElement>("a[data-footnote-ref]");
			if (ref) { showPopover(ref); return; }
			const hon = target.closest<HTMLElement>(".honorific");
			if (hon) showHonorificPopover(hon);
		}, { capture: true, signal: ctrl.signal });

		document.addEventListener("mouseleave", (e) => {
			if (isTouch) return;
			const target = e.target as HTMLElement;
			if (target.closest("a[data-footnote-ref]") || target.closest(".honorific")) scheduleDismiss();
		}, { capture: true, signal: ctrl.signal });

		// Keep popover visible while hovering over it
		popover.addEventListener("mouseenter", () => {
			if (hideTimer) { clearTimeout(hideTimer); hideTimer = null; }
		});
		popover.addEventListener("mouseleave", scheduleDismiss);

		// Click: prevent default jump; on touch devices toggle popover
		document.addEventListener("click", (e) => {
			const target = e.target as HTMLElement;
			const ref = target.closest<HTMLAnchorElement>("a[data-footnote-ref]");
			if (ref) {
				e.preventDefault();
				if (isTouch) {
					const fnId = ref.getAttribute("href")?.replace("#", "");
					if (popover.getAttribute("data-fn-id") === fnId && popover.classList.contains("fn-popover--visible")) {
						dismissPopover();
					} else {
						showPopover(ref);
					}
				}
				return;
			}
			const hon = target.closest<HTMLElement>(".honorific");
			if (hon && isTouch) {
				if (popover.getAttribute("data-fn-id") === "honorific" && popover.classList.contains("fn-popover--visible")) {
					dismissPopover();
				} else {
					showHonorificPopover(hon);
				}
				return;
			}
			if (!popover.contains(target)) {
				dismissPopover();
			}
		}, { signal: ctrl.signal });

		document.addEventListener("keydown", (e) => {
			if (e.key === "Escape" && popover.classList.contains("fn-popover--visible")) {
				e.stopPropagation();
				dismissPopover();
			}
		}, { capture: true, signal: ctrl.signal });

		document.addEventListener("astro:before-swap", () => { ctrl.abort(); popover.remove(); }, { once: true });
	});
</script>

<script>
	// Wire any Quran recitation players injected into the essay body
	// (rehype-quran-verse). They exist only on essay pages, so init lives here.
	import { initQuranPlayers } from "../scripts/quran-player";
	document.addEventListener("astro:page-load", () => initQuranPlayers());
</script>
