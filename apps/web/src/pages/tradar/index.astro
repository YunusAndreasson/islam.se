---
import { getCollection } from "astro:content";
import Base from "../../layouts/Base.astro";
import { breadcrumbList } from "../../lib/jsonld";

const threads = await getCollection("tradar");
---

<Base
	title="Trådar — islam.se"
	description="Kuraterade läsningar genom essäerna: hjärtats anatomi, tungan och sanningen, natten, maskinen och människan, Strindbergs kris."
	jsonLd={[
		{
			"@context": "https://schema.org",
			"@type": "CollectionPage",
			name: "Trådar",
			url: "https://islam.se/tradar",
			inLanguage: "sv",
		},
		breadcrumbList([
			{ name: "Hem", url: "/" },
			{ name: "Trådar", url: "/tradar" },
		]),
	]}
>
	<main id="main" class="content-column">
		<header class="article-header">
			<h1>Trådar</h1>
			<p class="collection-lead">Kuraterade läsningar genom korpusen — några essäer som hör ihop, samlade och inramade.</p>
		</header>

		<ul class="collection-index">
			{threads.map((thread) => (
				<li class="collection-index-item">
					<a href={`/tradar/${thread.id}`}>
						<h2 class="collection-index-title">{thread.data.title}</h2>
						<p class="collection-index-framing">{thread.data.framing}</p>
						<p class="label collection-index-count">{thread.data.essays.length} essäer</p>
					</a>
				</li>
			))}
		</ul>
	</main>
</Base>

<style>
	.collection-index {
		margin: var(--space-unit) 0 var(--space-phi2);
		padding: 0;
		list-style: none;
	}

	.collection-index-item {
		border-top: 1px solid var(--color-divider);

		&:first-child {
			border-top: none;
		}
	}

	.collection-index-item a {
		display: block;
		padding-block: var(--space-unit);
		text-decoration: none;
		color: inherit;

		&:hover .collection-index-title {
			text-decoration: underline;
			text-underline-offset: 0.12em;
		}

		&:focus-visible {
			outline: 2px solid var(--color-accent);
			outline-offset: 0.4rem;
			border-radius: 2px;
		}
	}

	.collection-index-title {
		font-family: var(--font-heading);
		font-size: var(--step-2);
		font-weight: 620;
		line-height: 1.2;
		letter-spacing: -0.018em;
		color: var(--color-accent);
		margin: 0;
	}

	.collection-index-framing {
		font-family: var(--font-body);
		font-size: 1rem;
		line-height: 1.5;
		color: color-mix(in srgb, var(--color-text) 75%, var(--color-muted));
		margin: 0.5rem 0 0;
		max-width: 38rem;
	}

	.collection-index-count {
		margin: 0.5rem 0 0;
	}
</style>
