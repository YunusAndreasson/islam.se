---
import { getCollection } from "astro:content";
import PageHead from "../../components/PageHead.astro";
import Base from "../../layouts/Base.astro";
import { breadcrumbList } from "../../lib/jsonld";

const threads = await getCollection("tradar");
---

<Base
	title="Trådar — islam.se"
	description="Kuraterade läsningar genom essäerna: hjärtats anatomi, tungan och sanningen, natten, maskinen och människan, Strindbergs kris."
	jsonLd={[
		{
			"@context": "https://schema.org",
			"@type": "CollectionPage",
			name: "Trådar",
			url: "https://islam.se/tradar",
			inLanguage: "sv",
		},
		breadcrumbList([
			{ name: "Hem", url: "/" },
			{ name: "Trådar", url: "/tradar" },
		]),
	]}
>
	<main id="main" class="home">
		<PageHead title="Trådar">
			Kuraterade läsningar genom essäerna – några som hör ihop, samlade och inramade till en tråd att
			följa.
		</PageHead>

		<ul class="collection-index">
			{threads.map((thread) => (
				<li class="collection-index-item">
					<a href={`/tradar/${thread.id}`}>
						<h2 class="collection-index-title">{thread.data.title}</h2>
						<p class="collection-index-framing">{thread.data.framing}</p>
						<p class="label collection-index-count">{thread.data.essays.length} essäer</p>
					</a>
				</li>
			))}
		</ul>

		<p class="collection-back"><a href="/essaer">Hela arkivet →</a></p>
	</main>
</Base>

<style>
	/* Two-column index on the wide canvas (one column on a phone), matching the
	   Essäer / Fakta archive grid so every browse page fills its frame. */
	.collection-index {
		margin: var(--space-unit) 0 0;
		padding: 0;
		list-style: none;
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(min(100%, 26rem), 1fr));
		column-gap: clamp(1.75rem, 4vw, 3.5rem);
	}

	.collection-index-item {
		border-bottom: 1px solid var(--color-divider);
	}

	.collection-index-item a {
		display: block;
		padding-block: var(--space-unit);
		text-decoration: none;
		color: inherit;

		&:hover .collection-index-title {
			text-decoration: underline;
			text-underline-offset: 0.12em;
		}

		&:focus-visible {
			outline: 2px solid var(--color-accent);
			outline-offset: 0.4rem;
			border-radius: 2px;
		}
	}

	.collection-index-title {
		font-family: var(--font-heading);
		font-size: var(--step-2);
		font-weight: 620;
		line-height: 1.2;
		letter-spacing: 0;
		color: var(--color-accent);
		margin: 0;
	}

	.collection-index-framing {
		font-family: var(--font-body);
		font-size: 1rem;
		line-height: 1.5;
		color: color-mix(in srgb, var(--color-text) 75%, var(--color-muted));
		margin: 0.5rem 0 0;
		max-width: 38rem;
	}

	.collection-index-count {
		margin: 0.5rem 0 0;
	}
</style>
