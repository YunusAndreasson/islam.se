---
import Base from "../layouts/Base.astro";
import { breadcrumbList, dataset } from "../lib/jsonld";
import { directionsLinks, getMosques, lanSlug, locationLabel, mosqueUrl, mosquesByLan } from "../lib/moskeer";
import { MOSKEER_DATA_DATE } from "../lib/moskeer/meta";
import "maplibre-gl/dist/maplibre-gl.css";

const mosques = getMosques();
const groups = mosquesByLan();
const total = mosques.length;
const cityCount = new Set(mosques.map((m) => m.citySlug)).size;
// Län with the most mosques, for the FAQ answer.
const biggestLan = [...groups].sort((a, b) => b.mosques.length - a.mosques.length)[0];

// Founding-year growth: mosques with a known `opened` year, bucketed by decade. Drives the
// inline bar chart in the history section. Computed from the data so it tracks any refresh.
const openedYears = mosques
	.map((m) => m.opened)
	.filter((y): y is number => typeof y === "number");
const withYearCount = openedYears.length;
const growthDecades: { label: string; count: number }[] = [];
if (openedYears.length) {
	const start = Math.floor(Math.min(...openedYears) / 10) * 10;
	const end = Math.floor(Math.max(...openedYears) / 10) * 10;
	for (let d = start; d <= end; d += 10) {
		growthDecades.push({
			label: `${d}-tal`,
			count: openedYears.filter((y) => Math.floor(y / 10) * 10 === d).length,
		});
	}
}
const growthMax = Math.max(1, ...growthDecades.map((d) => d.count));

// Top-10 counties by mosque count, for the ranked distribution chart.
const lanRanked = [...groups].sort((a, b) => b.mosques.length - a.mosques.length).slice(0, 10);
const lanMax = Math.max(1, ...lanRanked.map((g) => g.mosques.length));

const updated = new Date(MOSKEER_DATA_DATE).toLocaleDateString("sv-SE", {
	year: "numeric",
	month: "long",
	day: "numeric",
});

// Diacritic-folding normaliser, mirrored in moskeer-map.ts so a server-rendered
// `data-search` string matches a client-typed query.
const norm = (s: string) =>
	s
		.toLowerCase()
		.normalize("NFD")
		.replace(/[̀-ͯ]/g, "");

// The per-mosque detail the map callout needs, looked up by id on click. Kept lean and
// embedded once as JSON; `<` is escaped so a name can never break out of the script tag.
const payload = mosques.map((m) => {
	const d = directionsLinks(m);
	return {
		id: m.id,
		name: m.name,
		lng: m.lng,
		lat: m.lat,
		location: locationLabel(m),
		opened: m.opened,
		organisation: m.organisation,
		google: d.google,
		apple: d.apple,
		geo: d.geo,
	};
});
const payloadJson = JSON.stringify(payload).replace(/</g, "\\u003c");

const description = `Karta och katalog över ${total} moskéer i Sverige i ${cityCount} orter, med adress och ordnade län för län. Sök, filtrera och få vägbeskrivning till närmaste moské. Senast uppdaterad ${updated}.`;

const faq = [
	{
		q: "Hur många moskéer finns i Sverige?",
		a: `Vår karta visar ${total} moskéer och muslimska församlingar i Sverige, fördelade på ${cityCount} orter och ${groups.length} län. Uppgifterna kan vara ofullständiga.`,
	},
	{
		q: "Hur hittar jag närmaste moské?",
		a: "Använd knappen ”Hitta moské nära mig” ovanför kartan för att utgå från din position, eller sök på ortens namn. Välj en moské för adress, öppningsår och vägbeskrivning via Apple Maps eller Google Maps.",
	},
	{
		q: "Vilket län har flest moskéer?",
		a: `${biggestLan.lanLabel} har flest registrerade moskéer (${biggestLan.mosques.length} stycken). Du kan bläddra alla moskéer län för län längre ner på sidan.`,
	},
	{
		q: "När kom de första muslimerna till Sverige?",
		a: "Den första bofasta muslimen brukar räknas vara den tatariske pälshandlaren Ebrahim Umerkajeff, som kom till Stockholm 1897. Sveriges första muslimska församling, som var sunnimuslimsk, bildades 1949. Kontakten mellan Sverige och den muslimska världen är äldre än så och går tillbaka till vikingatiden.",
	},
	{
		q: "Är alla moskéer byggda som moskéer?",
		a: "Nej. De flesta moskéer i Sverige är församlingar som inrymts i befintliga lokaler, till exempel föreningslokaler eller ombyggda byggnader. Bara ett mindre antal är uppförda som moskébyggnader med kupol och minaret. Stockholms stora moské ligger i ett före detta elverk ritat av Ferdinand Boberg, och Fittja moské har en kupol klädd i björkträ.",
	},
	{
		q: "Får man besöka en moské om man inte är muslim?",
		a: "Ja. Moskéer tar emot besökare, och många ordnar öppet hus eller bokade studiebesök. Som besökare tar man av sig skorna, klär sig täckande och är tyst om en bön pågår. Man behöver varken vara muslim eller delta i bönen.",
	},
	{
		q: "Vad finns inuti en moské?",
		a: "Framför allt en öppen, mattbelagd bönehall utan stolar eller bänkar, eftersom man ber på golvet. I väggen mot Mecka finns en nisch, mihrab, som visar böneriktningen, och bredvid den en predikstol, minbar. I stället för bilder och statyer pryds moskén av geometriska mönster och kalligrafi.",
	},
	{
		q: "Varför tar man av sig skorna i en moské?",
		a: "För att hålla golvet rent, eftersom bönen sker direkt på mattan med pannan mot golvet. Det är samma omtanke om rena golv som när man tar av sig skorna i ett svenskt hem.",
	},
	{
		q: "Vad betyder ordet moské?",
		a: "Det kommer från arabiskans masjid, som betyder ungefär plats där man böjer sig ner i bön. Via franskans mosquée är ordet belagt i svenskan sedan 1600-talet.",
	},
];
---

<Base
	title="Moskéer i Sverige — karta och adresser län för län — islam.se"
	description={description}
	jsonLd={[
		{
			"@context": "https://schema.org",
			"@type": "CollectionPage",
			name: "Moskéer i Sverige",
			description,
			url: "https://islam.se/moskeer/",
			inLanguage: "sv",
		},
		dataset({
			name: "Moskéer i Sverige",
			description:
				"Öppen karta över moskéer och muslimska församlingar i Sverige med plats (kommun och län), öppningsår och, där det är känt, huvudman eller finansiering.",
			url: "/moskeer",
			spatialCoverage: "Sverige",
		}),
		{
			"@context": "https://schema.org",
			"@type": "ItemList",
			name: "Moskéer i Sverige",
			numberOfItems: total,
			itemListElement: mosques.map((m, i) => ({
				"@type": "ListItem",
				position: i + 1,
				name: m.name,
				url: mosqueUrl(m),
			})),
		},
		{
			"@context": "https://schema.org",
			"@type": "FAQPage",
			mainEntity: faq.map((f) => ({
				"@type": "Question",
				name: f.q,
				acceptedAnswer: { "@type": "Answer", text: f.a },
			})),
		},
		breadcrumbList([
			{ name: "Hem", url: "/" },
			{ name: "Moskéer i Sverige", url: "/moskeer" },
		]),
	]}
>
	<main id="main" class="home moskeer">
		<header class="mk-header">
			<h1>Moskéer i Sverige</h1>
			<p class="mk-intro">
				En karta över moskéer och muslimska församlingar i hela Sverige – från källarmoskéer till
				stora bönehus. Zooma och panorera, sök på namn eller ort, eller bläddra län för län. Välj en
				moské för plats, öppningsår och vägbeskrivning.
			</p>
			<p class="mk-meta">
				Senast uppdaterad <time datetime={MOSKEER_DATA_DATE}>{updated}</time> · {total} moskéer
			</p>
		</header>

		<div class="mk-controls">
			<div class="mk-search-wrap">
				<svg class="mk-search-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="7"></circle><path d="m21 21-4.3-4.3"></path></svg>
				<input
					type="search"
					id="mk-search"
					class="mk-search"
					placeholder="Sök moské eller ort…"
					aria-label="Sök efter moské eller ort"
					autocomplete="off"
				/>
			</div>
			<label class="mk-lan-filter">
				<span class="visually-hidden">Filtrera efter län</span>
				<select id="mk-lan" aria-label="Filtrera efter län">
					<option value="">Alla län</option>
					{groups.map((g) => <option value={g.lan}>{g.lanLabel}</option>)}
				</select>
				<svg class="mk-lan-chevron" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m6 9 6 6 6-6"></path></svg>
			</label>
			<button type="button" id="mk-geo" class="mk-geo">
				<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="3"></circle><path d="M12 2v3M12 19v3M22 12h-3M5 12H2"></path></svg>
				<span>Hitta moské nära mig</span>
			</button>
			<p id="mk-count" class="mk-count" aria-live="polite">{total} moskéer</p>
		</div>
		<p id="mk-geo-status" class="mk-geo-status" role="status"></p>

		<div class="mk-stage">
			<div id="moskeer-map" class="mk-map" role="application" aria-label="Karta över moskéer i Sverige"></div>
			<aside id="mk-callout" class="mk-callout" aria-live="polite" hidden></aside>
		</div>
		<noscript>
			<p class="mk-noscript">Den interaktiva kartan kräver JavaScript. Alla moskéer finns i listan nedan, ordnade efter län.</p>
		</noscript>

		<section class="mk-section" aria-labelledby="mk-find">
			<h2 id="mk-find">Hitta moské</h2>
			<p class="mk-lead">{total} moskéer, ordnade efter län. Välj en för plats, öppningsår och vägbeskrivning. Se även <a href="/bonetider/">bönetider för din ort</a>.</p>
			<div class="mk-lan-groups">
				{groups.map((g) => (
					<details class="mk-lan" data-lan={g.lan}>
						<summary>
							<span class="mk-lan-name">{g.lanLabel}</span>
							<span class="mk-lan-count">{g.mosques.length}</span>
						</summary>
						<ul class="mk-lan-list">
							{g.mosques.map((m) => (
								<li>
									<button
										type="button"
										class="mk-item"
										data-id={m.id}
										data-lan={g.lan}
										data-search={norm(`${m.name} ${locationLabel(m)} ${m.address ?? ""}`)}
									>
										<span class="mk-item-name">{m.name}</span>
										{m.address && <span class="mk-item-addr">{m.address}</span>}
										<span class="mk-item-loc">
											{locationLabel(m)}{m.opened ? ` · öppnad ${m.opened}` : ""}
										</span>
									</button>
								</li>
							))}
						</ul>
						<a class="mk-lan-all" href={`/moskeer/lan/${lanSlug(g.lan)}/`}>
							Alla moskéer i {g.lanLabel} →
						</a>
					</details>
				))}
			</div>
			<div id="mk-empty" class="mk-empty" hidden>
				<p class="mk-empty-msg">Inga moskéer matchar din sökning.</p>
				<button type="button" id="mk-clear" class="mk-clear">Rensa filter</button>
			</div>
		</section>

		<section class="mk-section mk-history" aria-labelledby="mk-history-h">
			<h2 id="mk-history-h">Moskéernas långa historia i Sverige</h2>
			<p class="mk-history-lead">
				Frågan är inte om islam hör hemma i Sverige, utan hur länge den redan har gjort det.
			</p>

			<dl class="mk-stats">
				<div class="mk-stat">
					<dt>moskéer</dt>
					<dd>{total}</dd>
				</div>
				<div class="mk-stat">
					<dt>orter</dt>
					<dd>{cityCount}</dd>
				</div>
				<div class="mk-stat">
					<dt>län</dt>
					<dd>{groups.length}</dd>
				</div>
				<div class="mk-stat">
					<dt>första församlingen</dt>
					<dd>1949</dd>
				</div>
			</dl>

			<h3>Milstolpar</h3>
			<ol class="mk-timeline">
				<li class="mk-tl-item">
					<span class="mk-tl-year">Vikingatiden</span>
					<p class="mk-tl-label">
						Arabiska silvermynt och runstenar med namnet Särkland vittnar om kontakt med den
						muslimska världen.
					</p>
				</li>
				<li class="mk-tl-item">
					<span class="mk-tl-year">1897</span>
					<p class="mk-tl-label">
						Den tatariske pälshandlaren Ebrahim Umerkajeff bosätter sig i Stockholm och blir
						Sveriges förste muslim.
					</p>
				</li>
				<li class="mk-tl-item">
					<span class="mk-tl-year">1949</span>
					<p class="mk-tl-label">
						Sveriges första muslimska församling grundas i Stockholm, sunnimuslimsk, med Osman
						Soukkan som förste imam.
					</p>
				</li>
				<li class="mk-tl-item">
					<span class="mk-tl-year">1984</span>
					<p class="mk-tl-label">
						Malmö moské, en av landets första stora församlingsmoskéer, står klar.
					</p>
				</li>
				<li class="mk-tl-item">
					<span class="mk-tl-year">2000</span>
					<p class="mk-tl-label">
						Stockholms stora moské öppnar i Ferdinand Bobergs gamla elverk på Södermalm.
					</p>
				</li>
				<li class="mk-tl-item">
					<span class="mk-tl-year">I dag</span>
					<p class="mk-tl-label">
						Omkring {total} moskéer och församlingar finns runt om i Sverige.
					</p>
				</li>
			</ol>

			<h3>Uråldrig kontakt</h3>
			<p>
				Banden mellan Norden och den muslimska världen är gamla. Fler vikingatida arabiska silvermynt,
				så kallade dirhamer, har hittats i svensk jord än i något annat land, och på flera sörmländska
				runstenar nämns Särkland, det fornnordiska namnet på saracenernas land. På Gripsholmsstenen i
				Mariefred står att männen ”dogo söderut i Särkland”. Det handlade om handel och resor snarare
				än om religion, men kontakten är mycket gammal.
			</p>

			<h3>De första muslimerna</h3>
			<p>
				Den moderna muslimska närvaron i Sverige börjar med tatariska invandrare. Pälshandlaren
				Ebrahim Umerkajeff kom till Stockholm 1897 och blev en av landets första bofasta muslimer.
				Tatarerna är ett sunnimuslimskt turkfolk som funnits kring Östersjön sedan medeltiden, och
				under och efter andra världskriget kom fler tatariska muslimer från Estland och Ryssland.
			</p>
			<p>
				År 1949 grundades Sveriges första muslimska församling i Stockholm. Den var sunnimuslimsk,
				bildad av tatarer och turkar, med Osman Soukkan som landets förste imam. Soukkan hade vuxit
				upp i Izmir, tagit sig genom Europa på cykel och undervisat tatariska muslimer i Finland innan
				han kom till Stockholm. Därmed blev islam det första icke-kristna trossamfundet som etablerades
				i Sverige efter judendomen, och mycket av det som följde växte fram underifrån, lokal för lokal,
				ungefär som de svenska frikyrkorna.
			</p>

			<h3>Allt fler moskéer</h3>
			<p>
				Antalet moskéer har vuxit stadigt sedan 1970-talet, i takt med att församlingarna blivit fler
				och större.
			</p>
			<figure class="mk-growth">
				<div
					class="mk-growth-chart"
					role="img"
					aria-label={`Stapeldiagram över antal moskéer grundade per decennium, bland de ${withYearCount} med känt grundningsår.`}
				>
					{growthDecades.map((d) => (
						<div class="mk-growth-col">
							<div class="mk-growth-track">
								<span class="mk-growth-val">{d.count}</span>
								<div class="mk-growth-bar" style={`height:${Math.round((d.count / growthMax) * 100)}%`}></div>
							</div>
							<span class="mk-growth-lab">{d.label}</span>
						</div>
					))}
				</div>
				<figcaption class="mk-growth-cap">
					Antal moskéer och församlingar som grundats per decennium, bland de {withYearCount} med känt
					grundningsår. Underlaget är ofullständigt och det pågående decenniet ännu inte fullt.
				</figcaption>
			</figure>

			<h3>Var finns moskéerna?</h3>
			<figure class="mk-lanbars">
				<div class="mk-lanbars-chart">
					{lanRanked.map((g) => (
						<div class="mk-lanbar-row">
							<span class="mk-lanbar-name">{g.lan}</span>
							<span class="mk-lanbar-track">
								<span class="mk-lanbar-fill" style={`width:${Math.round((g.mosques.length / lanMax) * 100)}%`}></span>
							</span>
							<span class="mk-lanbar-val">{g.mosques.length}</span>
						</div>
					))}
				</div>
				<figcaption class="mk-growth-cap">
					De tio län som har flest registrerade moskéer. Övriga län finns längre ner på sidan.
				</figcaption>
			</figure>

			<h3>Moskén som svensk byggnad</h3>
			<p>
				De flesta moskéer i Sverige är inte uppförda som moskéer, utan inrymda i lokaler som byggts om.
				Stockholms stora moské på Södermalm finns i en byggnad som ritades av Ferdinand Boberg, samme
				arkitekt som gav Sverige Rosenbad och varuhuset NK. Den uppfördes kring sekelskiftet 1900 som
				en station i elverkets nät och hade redan då drag av orientalisk arkitektur.
			</p>
			<p>
				Där moskéer byggts från grunden möts ofta nordiskt och islamiskt. Fittja moské utanför
				Stockholm kröns av en mittkupol klädd i björkträ, en medveten förening av osmansk form och
				svenskt material som visades upp när kungaparet besökte moskén 2013. Kartan ovan visar var
				Sveriges moskéer finns i dag.
			</p>
		</section>

		<section class="mk-section" aria-labelledby="mk-faq">
			<h2 id="mk-faq">Vanliga frågor</h2>
			<dl class="mk-faq">
				{faq.map((f) => (
					<div class="mk-faq-item">
						<dt>{f.q}</dt>
						<dd>{f.a}</dd>
					</div>
				))}
			</dl>
		</section>

		<p class="mk-attrib">
			Underlaget kan vara ofullständigt – vissa moskéer saknas, och uppgifter om öppningsår
			eller huvudman är inte alltid kända. Adresser och positioner är ungefärliga.
		</p>
	</main>

	<script id="moskeer-data" type="application/json" is:inline set:html={payloadJson}></script>
</Base>

<script>
	import "../scripts/moskeer-map";
</script>

<style>
	.moskeer {
		margin-block: var(--space-phi);
		overflow-x: clip;
	}

	.mk-header h1 {
		margin: var(--space-half) 0 0;
	}

	.mk-intro {
		font-family: var(--font-body);
		font-size: 1.0625rem;
		line-height: 1.6;
		color: color-mix(in srgb, var(--color-text) 85%, var(--color-muted));
		margin: var(--space-half) 0 var(--space-half);
		text-wrap: pretty;
	}

	.mk-meta {
		font-family: var(--font-body);
		font-size: 0.8125rem;
		color: var(--color-muted);
		margin: 0 0 var(--space-unit);
		font-variant-numeric: lining-nums tabular-nums;
	}

	/* Controls row above the map — one cohesive toolbar: the search field, län filter and
	   the geolocation CTA share a pill shape, height and focus treatment. */
	.mk-controls {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: var(--space-half);
		margin-bottom: var(--space-half);
	}

	.mk-search-wrap {
		position: relative;
		flex: 1 1 16rem;
		max-width: 22rem;
		display: flex;
		align-items: center;
	}

	.mk-search-icon {
		position: absolute;
		left: 0.85rem;
		color: var(--color-muted);
		pointer-events: none;
	}

	.mk-search {
		width: 100%;
		font-family: var(--font-body);
		font-size: 1rem;
		color: var(--color-text);
		background: var(--color-bg);
		border: 1px solid var(--color-divider);
		border-radius: 999px;
		padding: 0.55rem 1rem 0.55rem 2.5rem;
	}

	.mk-search::placeholder {
		color: var(--color-muted);
	}

	.mk-lan-filter {
		position: relative;
		display: inline-flex;
		align-items: center;
	}

	.mk-lan-chevron {
		position: absolute;
		right: 0.8rem;
		color: var(--color-accent);
		pointer-events: none;
	}

	#mk-lan {
		appearance: none;
		font-family: var(--font-heading);
		font-size: 0.9375rem;
		color: var(--color-accent);
		background: var(--color-bg);
		border: 1px solid var(--color-divider);
		border-radius: 999px;
		padding: 0.55rem 2.4rem 0.55rem 1rem;
		cursor: pointer;
	}

	.mk-geo {
		display: inline-flex;
		align-items: center;
		gap: 0.4rem;
		font-family: var(--font-heading);
		font-size: 0.9375rem;
		font-weight: 600;
		color: var(--color-accent);
		background: var(--color-bg);
		border: 1px solid var(--color-divider);
		border-radius: 999px;
		padding: 0.5rem 1.1rem;
		cursor: pointer;
		transition: border-color 0.15s ease;
	}

	.mk-geo svg {
		color: var(--color-warm);
		flex: none;
	}

	.mk-geo:hover {
