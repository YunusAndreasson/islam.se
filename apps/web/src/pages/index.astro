---
import AmnenSections from "../components/AmnenSections.astro";
import BookPod from "../components/BookPod.astro";
import Citat from "../components/Citat.astro";
import DagensVers from "../components/DagensVers.astro";
import FeatureEssay from "../components/FeatureEssay.astro";
import Markesdagar from "../components/Markesdagar.astro";
import RecentEssays from "../components/RecentEssays.astro";
import TankareGroups from "../components/TankareGroups.astro";
import TradarHome from "../components/TradarHome.astro";
import Base from "../layouts/Base.astro";
import { getArticles } from "../lib/articles";
import { getVerseOfDay } from "../lib/verse";

const articles = await getArticles();
const verseOfDay = await getVerseOfDay();

// The signature spread needs art, so the feature is the most recent essay that
// carries a hero image; if none do, fall back to the most recent essay.
const feature = articles.find((a) => a.heroImage) ?? articles[0];
const recent = articles.filter((a) => a.slug !== feature?.slug).slice(0, 5);

const ogImage = feature?.heroImage;
---

<Base
	title="islam.se — Essäer om islamisk intellektuell tradition och svenskt kulturarv"
	description="Essäer om islamisk intellektuell tradition och svenskt kulturarv."
	ogImage={ogImage?.src}
	preloadImage={ogImage?.src}
	jsonLd={{
		"@context": "https://schema.org",
		"@type": "WebSite",
		name: "islam.se",
		url: "https://islam.se",
		description: "Essäer om islamisk intellektuell tradition och svenskt kulturarv.",
		inLanguage: "sv",
	}}
>
	<main id="main" class="home">
		<h1 class="sr-only">islam.se — essäer om islamisk intellektuell tradition och svenskt kulturarv</h1>

		<a class="continue-strip" id="continue-strip" hidden>
			<span class="label continue-label">Fortsätt läsa</span>
			<span class="continue-title"></span>
			<span class="continue-arrow" aria-hidden="true">→</span>
		</a>
		<script
			type="application/json"
			id="essay-index"
			is:inline
			set:html={JSON.stringify(Object.fromEntries(articles.map((a) => [a.slug, a.title])))}
		/>

		{feature && <FeatureEssay article={feature} />}

		{verseOfDay && <DagensVers verseOfDay={verseOfDay} />}

		<RecentEssays articles={recent} />

		<Citat />

		<AmnenSections />

		<TradarHome limit={4} />

		<section class="home-movement tankare-home" aria-labelledby="tankare-home-kicker">
			<div class="tankare-home-head">
				<p class="label home-kicker" id="tankare-home-kicker">Tänkare</p>
				<a class="label tankare-home-all arrow-link" href="/tankare">Alla tänkare</a>
			</div>
			<TankareGroups limit={6} />
		</section>

		<Markesdagar />

		<BookPod count={articles.length} variant="home" />

		<section class="om-teaser home-movement" aria-labelledby="om-teaser-kicker">
			<p class="label home-kicker" id="om-teaser-kicker">Om islam.se</p>
			<p class="om-teaser-text">
				Essäer där islamisk lärdomstradition möter svenskt kulturarv.
				<span class="om-teaser-coda">Samma samtal, fört i skilda rum.</span>
			</p>
			<a class="home-coda-link arrow-link" href="/om">Om idén bakom islam.se</a>
		</section>

		<section class="ai-connect home-movement" aria-labelledby="ai-connect-kicker">
			<p class="label home-kicker" id="ai-connect-kicker">AI</p>
			<p class="ai-connect-text">
				Hela arkivet går att nå direkt från din AI-assistent. Be Claude eller ChatGPT söka i essäerna och citera dem
				– med länk tillbaka hit. En öppen anslutning (MCP) gör kopplingen på en minut.
			</p>
			<a class="home-coda-link arrow-link" href="/ai">Koppla din assistent</a>
		</section>

		<nav class="archive-link home-movement" aria-label="Hela arkivet">
			<a class="arrow-link" href="/essaer">Hela arkivet</a>
		</nav>
	</main>
</Base>

<style>
	/* "Fortsätt läsa" — a quiet strip above the hero, shown only to a returning
	   reader who left an essay part-read (populated client-side from saved
	   progress). Hidden by default, so it adds nothing for first-time visitors
	   and causes no layout shift until it has something to offer. */
	.continue-strip {
		display: flex;
		align-items: baseline;
		gap: 0.6rem;
		margin-bottom: var(--space-unit);
		padding: 0.7rem 0.9rem;
		border: 1px solid var(--color-divider);
		border-radius: 0.5rem;
		text-decoration: none;
		color: var(--color-text);
		transition: border-color 0.15s ease;
	}

	.continue-strip[hidden] {
		display: none;
	}

	.continue-strip:hover {
		border-color: var(--color-warm);
	}

	.continue-strip:hover .continue-title {
		text-decoration: underline;
		text-underline-offset: 0.15em;
	}

	.continue-strip:focus-visible {
		outline: 2px solid var(--color-accent);
		outline-offset: 2px;
	}

	.continue-label {
		color: var(--color-muted);
		flex-shrink: 0;
	}

	.continue-title {
		font-family: var(--font-heading);
		font-weight: 500;
		color: var(--color-accent);
	}

	.continue-arrow {
		margin-left: auto;
		color: var(--color-muted);
	}

	/* Tänkare kicker row: the section label, with a quiet path to the full
	   directory on its baseline (the homepage shows a balanced glimpse). */
	.tankare-home-head {
		display: flex;
		justify-content: space-between;
		align-items: baseline;
		gap: 1rem;
		margin-bottom: var(--space-unit);
	}

	.tankare-home-head .home-kicker {
		margin-bottom: 0;
	}

	.tankare-home-all {
		flex-shrink: 0;
		text-decoration: none;
		transition: color 0.15s ease;
	}

	.tankare-home-all:hover {
		color: var(--color-accent);
	}

	.tankare-home-all:focus-visible {
		outline: 2px solid var(--color-accent);
		outline-offset: 3px;
		border-radius: 2px;
	}

	/* Closing pair — what islam.se is, and that it reaches a modern assistant.
	   Quiet text-led movements in the site voice; the link mirrors the arrow
	   convention used by Tänkare and the archive link. */
	.om-teaser-text,
	.ai-connect-text {
		font-family: var(--font-body);
		font-size: 1.0625rem;
		line-height: 1.55;
		color: color-mix(in srgb, var(--color-text) 80%, var(--color-muted));
		max-width: 38rem;
		margin: 0 0 var(--space-half);
		text-wrap: pretty;
	}

	.om-teaser-coda {
		font-style: italic;
	}

	/* Quiet heading-style links that grow a muted → (the arrow motion is .arrow-link).
	   Shared by the om/AI codas and the centered archive link, so the convention is
	   defined once. */
	.home-coda-link,
	.archive-link a {
		display: inline-block;
		font-family: var(--font-heading);
		font-size: 1.05rem;
		font-weight: 500;
		letter-spacing: 0.02em;
		color: var(--color-accent);
		text-decoration: none;
	}

	.home-coda-link::after,
	.archive-link a::after {
		color: var(--color-muted);
	}

	.home-coda-link:hover,
	.archive-link a:hover {
		text-decoration: underline;
		text-decoration-thickness: 1px;
		text-underline-offset: 0.15em;
	}

	.home-coda-link:focus-visible,
	.archive-link a:focus-visible {
		outline: 2px solid var(--color-accent);
		outline-offset: 3px;
		border-radius: 2px;
	}

	.archive-link {
		text-align: center;
	}

	/* Larger tap target for the standalone archive link. */
	.archive-link a {
		padding: 0.5rem 0;
	}
</style>

<script>
	document.addEventListener("astro:page-load", () => {
		const strip = document.getElementById("continue-strip") as HTMLAnchorElement | null;
		const index = document.getElementById("essay-index");
		if (!strip || !index) return;

		let titles: Record<string, string> = {};
		try {
			titles = JSON.parse(index.textContent || "{}");
		} catch {}

		// The most recently read essay still left part-finished (rt = last-read time,
		// rp = furthest scroll). Below 6% is "barely started", above 95% is "done".
		let best: string | null = null;
		let bestTime = -1;
		for (const slug in titles) {
			const pct = +(localStorage.getItem(`rp:${slug}`) || 0);
			if (pct <= 0.06 || pct >= 0.95) continue;
			const time = +(localStorage.getItem(`rt:${slug}`) || 0);
			if (time >= bestTime) {
				bestTime = time;
				best = slug;
			}
		}

		if (best) {
			strip.href = `/${best}`;
			const titleEl = strip.querySelector(".continue-title");
			if (titleEl) titleEl.textContent = titles[best];
			strip.hidden = false;
		}
	});
</script>
