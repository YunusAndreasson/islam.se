---
import AmnenSections from "../components/AmnenSections.astro";
import BonetiderHome from "../components/bonetider/BonetiderHome.astro";
import PrayerStrip from "../components/bonetider/PrayerStrip.astro";
import BookPod from "../components/BookPod.astro";
import Citat from "../components/Citat.astro";
import DagensVers from "../components/DagensVers.astro";
import FeatureEssay from "../components/FeatureEssay.astro";
import Markesdagar from "../components/Markesdagar.astro";
import RecentEssays from "../components/RecentEssays.astro";
import TankareGroups from "../components/TankareGroups.astro";
import TradarHome from "../components/TradarHome.astro";
import { getImage } from "astro:assets";
import Base from "../layouts/Base.astro";
import { getArticles } from "../lib/articles";
import { FEATURE_HERO_SIZES, FEATURE_HERO_WIDTHS } from "../lib/hero";
import { getVerseOfDay } from "../lib/verse";

const articles = await getArticles();
const verseOfDay = await getVerseOfDay();

// The signature spread needs art, so the feature is the most recent essay that
// carries a hero image; if none do, fall back to the most recent essay.
const feature = articles.find((a) => a.heroImage) ?? articles[0];
const recent = articles.filter((a) => a.slug !== feature?.slug).slice(0, 5);

// Hero images already spent at the top of the page — the feature plus any
// "Nyligen publicerat" row that carries one. Passed to AmnenSections so each
// topic leads with a different picture and no image repeats further down.
const usedImageSlugs = new Set<string>();
if (feature?.heroImage) usedImageSlugs.add(feature.slug);
for (const a of recent) if (a.heroImage) usedImageSlugs.add(a.slug);

const ogImage = feature?.heroImage;

// LCP preload: the feature hero renders through Astro's responsive <Image>, so a
// preload must carry the same srcset/sizes (not the raw original URL) for the
// browser to preload the exact candidate it will paint. getImage() with identical
// options yields the same optimized URLs the <Image> emits.
const heroPreload = feature?.heroImage
	? await getImage({
			src: feature.heroImage,
			widths: FEATURE_HERO_WIDTHS,
			sizes: FEATURE_HERO_SIZES,
			// Match what EssayImage paints: webp in dev (Astro's dev endpoint mislabels
			// AVIF as image/heif → Firefox rejects it), AVIF in the production build.
			format: import.meta.env.DEV ? "webp" : "avif",
		})
	: null;
---

<Base
	title="islam.se — Essäer om islamisk intellektuell tradition och svenskt kulturarv"
	description="Essäer om islamisk intellektuell tradition och svenskt kulturarv."
	ogImage={ogImage?.src}
	preloadImageSrcset={heroPreload?.srcSet.attribute}
	preloadImageSizes={FEATURE_HERO_SIZES}
	preloadImageType={heroPreload ? (import.meta.env.DEV ? "image/webp" : "image/avif") : undefined}
	jsonLd={{
		"@context": "https://schema.org",
		"@type": "WebSite",
		name: "islam.se",
		url: "https://islam.se",
		description: "Essäer om islamisk intellektuell tradition och svenskt kulturarv.",
		inLanguage: "sv",
	}}
>
	<main id="main" class="home">
		<h1 class="sr-only">islam.se — essäer om islamisk intellektuell tradition och svenskt kulturarv</h1>

		<PrayerStrip />

		{feature && <FeatureEssay article={feature} />}

		<RecentEssays articles={recent} />

		{verseOfDay && <DagensVers verseOfDay={verseOfDay} />}

		<Citat />

		<AmnenSections usedImageSlugs={usedImageSlugs} />

		<TradarHome limit={4} />

		<TankareGroups limit={6} />

		<Markesdagar />

		<BonetiderHome />

		<BookPod count={articles.length} variant="home" />

		<section class="om-teaser home-movement" aria-labelledby="om-teaser-kicker">
			<p class="label home-kicker" id="om-teaser-kicker">Om islam.se</p>
			<p class="om-teaser-text">
				Essäer där islamisk lärdomstradition möter svenskt kulturarv.
				<span class="om-teaser-coda">Samma samtal, fört i skilda rum.</span>
			</p>
			<a class="home-coda-link arrow-link" href="/om">Om idén bakom islam.se</a>
		</section>

		<section class="ai-connect home-movement" aria-labelledby="ai-connect-kicker">
			<p class="label home-kicker" id="ai-connect-kicker">AI</p>
			<p class="ai-connect-text">
				Hela arkivet går att nå direkt från din AI-assistent. Be Claude eller ChatGPT söka i essäerna och citera dem
				– med länk tillbaka hit. En öppen anslutning (MCP) gör kopplingen på en minut.
			</p>
			<a class="home-coda-link arrow-link" href="/ai">Koppla din assistent</a>
		</section>
	</main>
</Base>

<style>
	/* Closing pair — what islam.se is, and that it reaches a modern assistant.
	   Quiet text-led movements in the site voice; the link mirrors the arrow
	   convention used by Tänkare and the archive link. */
	.om-teaser-text,
	.ai-connect-text {
		font-family: var(--font-body);
		font-size: 1.0625rem;
		line-height: 1.55;
		color: color-mix(in srgb, var(--color-text) 80%, var(--color-muted));
		max-width: 38rem;
		margin: 0 0 var(--space-half);
		text-wrap: pretty;
	}

	.om-teaser-coda {
		font-style: italic;
	}

	/* Quiet heading-style links that grow a muted → (the arrow motion is .arrow-link).
	   Shared by the om/AI codas, so the convention is defined once. */
	.home-coda-link {
		display: inline-block;
		font-family: var(--font-heading);
		font-size: 1.05rem;
		font-weight: 500;
		letter-spacing: 0.02em;
		color: var(--color-accent);
		text-decoration: none;
	}

	.home-coda-link::after {
		color: var(--color-muted);
	}

	.home-coda-link:hover {
		text-decoration: underline;
		text-decoration-thickness: 1px;
		text-underline-offset: 0.15em;
	}

	.home-coda-link:focus-visible {
		outline: 2px solid var(--color-accent);
		outline-offset: 3px;
		border-radius: 2px;
	}
</style>
