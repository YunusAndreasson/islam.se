---
import BookPod from "../components/BookPod.astro";
import FeatureEssay from "../components/FeatureEssay.astro";
import Markesdagar from "../components/Markesdagar.astro";
import RecentEssays from "../components/RecentEssays.astro";
import { getImage } from "astro:assets";
import Base from "../layouts/Base.astro";
import { getArticles } from "../lib/articles";
import { FEATURE_HERO_SIZES, FEATURE_HERO_WIDTHS } from "../lib/hero";

const articles = await getArticles();

// The "Senast publicerat" feed shows only essays that carry a hero image — the
// feature (most recent with art) plus the next 8 — so every row reads as an image
// card and no text-only essay slips into the spread. Falls back to the most recent
// essay if somehow none carry an image.
const withImage = articles.filter((a) => a.heroImage);
const feature = withImage[0] ?? articles[0];
const recent = withImage.filter((a) => a.slug !== feature?.slug).slice(0, 8);

const ogImage = feature?.heroImage;

// LCP preload: the feature hero renders through Astro's responsive <Image>, so a
// preload must carry the same srcset/sizes (not the raw original URL) for the
// browser to preload the exact candidate it will paint. getImage() with identical
// options yields the same optimized URLs the <Image> emits.
const heroPreload = feature?.heroImage
	? await getImage({
			src: feature.heroImage,
			widths: FEATURE_HERO_WIDTHS,
			sizes: FEATURE_HERO_SIZES,
			// Match what EssayImage paints: webp in dev (Astro's dev endpoint mislabels
			// AVIF as image/heif → Firefox rejects it), AVIF in the production build.
			format: import.meta.env.DEV ? "webp" : "avif",
		})
	: null;
---

<Base
	title="islam.se — Vad är islam? Frågor & svar, bönetider & essäer på svenska"
	description="Vad är islam? Källbelagda svar på vanliga frågor, bönetider för hela Sverige, och essäer om islamisk intellektuell tradition i möte med svenskt kulturarv."
	ogImage={ogImage?.src}
	preloadImageSrcset={heroPreload?.srcSet.attribute}
	preloadImageSizes={FEATURE_HERO_SIZES}
	preloadImageType={heroPreload ? (import.meta.env.DEV ? "image/webp" : "image/avif") : undefined}
>
	<main id="main" class="home">
		<h1 class="sr-only">islam.se — kunskap om islam på svenska</h1>

		{/* Primary doorways — the high-intent destinations a visitor most often arrives
		    for, made reachable the moment the page loads. These mirror the standing mast
		    links; here they carry a line of orientation. */}
		<nav class="home-pillars" aria-label="Sajtens huvudingångar">
			<a class="home-pillar" href="/vad-ar-islam/">
				<span class="home-pillar-title">Pelare &amp; tro</span>
				<span class="home-pillar-desc">Vad är islam – tron och de fem pelarna</span>
			</a>
			<a class="home-pillar" href="/svar/">
				<span class="home-pillar-title">Frågor &amp; svar</span>
				<span class="home-pillar-desc">Svar på vanliga frågor om islam</span>
			</a>
			<a class="home-pillar" href="/essaer">
				<span class="home-pillar-title">Essäer</span>
				<span class="home-pillar-desc">Islamisk tradition och svenskt kulturarv</span>
			</a>
			<a class="home-pillar" href="/bonetider/">
				<span class="home-pillar-title">Bönetider</span>
				<span class="home-pillar-desc">Dagens tider för hela Sverige</span>
			</a>
			<a class="home-pillar" href="/moskeer">
				<span class="home-pillar-title">Moskéer</span>
				<span class="home-pillar-desc">Karta över Sveriges moskéer</span>
			</a>
		</nav>

		{/* The homepage body opens on the latest published — the feature + recent feed —
		    then the Islamic calendar and the book/podcast. The other sections are reached
		    from the intro links, the doorways and the mast. */}
		{feature && <FeatureEssay article={feature} />}

		<RecentEssays articles={recent} />

		<Markesdagar />

		<BookPod count={articles.length} variant="home" />
	</main>
</Base>

<style>
	/* Primary doorways — a calm four-up of the site's highest-intent destinations,
	   set in the site voice (heading link + a muted line), whitespace-grouped rather
	   than boxed. The feature's own φ² top margin carries the gap down to it.

	   Shown ONLY where the mast's inline links are hidden — on touch/coarse pointers
	   and below 900px, the same conditions the header uses to collapse its nav into
	   the "Meny" trigger. On a wide pointer screen those links are already visible in
	   the mast, so this row would just echo the menu directly beneath it; there it is
	   hidden. (The links stay in the DOM either way, so crawlers still see them.) */
	.home-pillars {
		display: none;
		grid-template-columns: repeat(auto-fit, minmax(min(100%, 11rem), 1fr));
		gap: var(--space-unit) clamp(1.25rem, 3vw, 2.75rem);
		margin: 0;
	}

	@media (hover: none), (pointer: coarse) {
		.home-pillars {
			display: grid;
		}
	}

	@media (width <= 900px) {
		.home-pillars {
			display: grid;
			gap: var(--space-half) clamp(1rem, 3vw, 2rem);
		}

		.home-pillar-desc {
			display: none;
		}
	}

	.home-pillar {
		display: flex;
		flex-direction: column;
		gap: 0.25rem;
		text-decoration: none;
		/* A touch of block padding so the tap target clears WCAG 2.5.8 comfortably. */
		padding-block: 0.2rem;
	}

	.home-pillar-title {
		font-family: var(--font-heading);
		font-size: 1.0625rem;
		font-weight: 600;
		letter-spacing: 0;
		color: var(--color-accent);
	}

	.home-pillar:hover .home-pillar-title {
		text-decoration: underline;
		text-decoration-thickness: 1px;
		text-underline-offset: 0.15em;
	}

	.home-pillar-desc {
		font-family: var(--font-body);
		font-size: 0.9rem;
		line-height: 1.4;
		color: var(--color-muted);
		text-wrap: pretty;
	}

	.home-pillar:focus-visible {
		outline: 2px solid var(--color-accent);
		outline-offset: 3px;
		border-radius: 2px;
	}

	/* Two-up on tablets, single column on the narrowest phones. */
	@media (width <= 760px) {
		.home-pillars {
			grid-template-columns: repeat(2, 1fr);
		}
	}

	@media (width <= 26rem) {
		.home-pillars {
			grid-template-columns: 1fr;
		}
	}

</style>
