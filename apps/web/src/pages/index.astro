---
import { Image } from "astro:assets";
import Base from "../layouts/Base.astro";
import { formatDate, getArticles, inlineMarkdown } from "../lib/articles";

const HERO_SLUGS = [
	"nattbonens-ansikte",
	"det-han-letade-efter",
	"vikingarna-hade-inte-angest",
	"somnens-lilla-dod",
	"den-insparrade-sjalen",
	"skapad-ur-ingenting",
	"silvertarnans-hijra",
];

const articles = await getArticles();
const slides = HERO_SLUGS
	.map((slug) => articles.find((a) => a.slug === slug))
	.filter((a): a is (typeof articles)[number] => a !== undefined);
const latest = slides[0];
const ogImage = latest?.heroImage;
---

<Base
	title="islam.se — Essäer om islamisk intellektuell tradition och svenskt kulturarv"
	description="Essäer om islamisk intellektuell tradition och svenskt kulturarv."
	hero={true}
	ogImage={ogImage?.src}
	preloadImage={ogImage?.src}
	jsonLd={{
		"@context": "https://schema.org",
		"@type": "WebSite",
		name: "islam.se",
		url: "https://islam.se",
		description: "Essäer om islamisk intellektuell tradition och svenskt kulturarv.",
		inLanguage: "sv",
	}}
>
	<main id="main">
		<section class="hero-cover" aria-roledescription="bildspel" aria-label="Utvalda essäer">
			{slides.map((article, i) => (
				<div class:list={["hero-slide", { active: i === 0 }]} aria-hidden={i !== 0 ? "true" : undefined} role="group" aria-roledescription="bild" aria-label={`${i + 1} av ${slides.length}`}>
					{article.mobileHeroImage ? (
						<picture>
							<source
								srcset={`${article.mobileHeroImage.src}`}
								media="(max-width: 768px) and (orientation: portrait)"
								type="image/webp"
								width={article.mobileHeroImage.width}
								height={article.mobileHeroImage.height}
							/>
							<Image
								src={article.heroImage!}
								alt={article.title}
								widths={[768, 1200, 1920]}
								sizes="100vw"
								loading={i === 0 ? "eager" : "lazy"}
								fetchpriority={i === 0 ? "high" : "low"}
								decoding="async"
								class="hero-cover-img"
							/>
						</picture>
					) : (
						<Image
							src={article.heroImage!}
							alt={article.title}
							widths={[768, 1200, 1920]}
							sizes="100vw"
							loading={i === 0 ? "eager" : "lazy"}
							fetchpriority={i === 0 ? "high" : "low"}
							decoding="async"
							class="hero-cover-img"
						/>
					)}
					<div class="hero-cover-overlay">
						<a href={`/${article.slug}`} class="hero-cover-content" data-astro-prefetch="viewport">
							{i === 0
							? <h1 class="hero-cover-title">{article.title}</h1>
							: <p class="hero-cover-title">{article.title}</p>
						}
							{article.description && <p class="hero-cover-deck" set:html={inlineMarkdown(article.description)} />}
							<p class="label hero-cover-date"><time datetime={article.publishedAt}>{formatDate(article.publishedAt)}</time> &middot; {article.readingTime} min läsning</p>
						<span class="hero-cta" aria-hidden="true">Läs</span>
						</a>
					</div>
				</div>
			))}
			{slides.length > 1 && (
				<div class="hero-nav">
					<button class="btn-circle hero-nav-prev" type="button" aria-label="Föregående essä" disabled>
						<svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
							<path d="M12.5 5l-5 5 5 5" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round" />
						</svg>
					</button>
					<button class="btn-circle hero-nav-next" type="button" aria-label="Nästa essä">
						<svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
							<path d="M7.5 5l5 5-5 5" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round" />
						</svg>
					</button>
				</div>
			)}
		</section>
	</main>
</Base>

<script>
	document.addEventListener("astro:page-load", () => {
		const slides = document.querySelectorAll<HTMLElement>(".hero-slide");
		const prevBtn = document.querySelector<HTMLButtonElement>(".hero-nav-prev");
		const nextBtn = document.querySelector<HTMLButtonElement>(".hero-nav-next");
		if (nextBtn && prevBtn && slides.length >= 2) {
			let current = 0;
			const last = slides.length - 1;

			function update() {
				prevBtn.disabled = current === 0;
				nextBtn.disabled = current === last;
			}

			function go(delta: number) {
				const next = current + delta;
				if (next < 0 || next > last) return;
				slides[current].classList.remove("active");
				slides[current].setAttribute("aria-hidden", "true");
				current = next;
				const img = slides[current].querySelector("img");
				// Clear animation, force reflow, restore — restarts the zoom from the beginning
				if (img) { img.style.animation = "none"; img.offsetHeight; img.style.animation = ""; }
				slides[current].classList.add("active");
				slides[current].removeAttribute("aria-hidden");
				update();
			}

			prevBtn.addEventListener("click", () => go(-1));
			nextBtn.addEventListener("click", () => go(1));

			const ctrl = new AbortController();

			// Touch swipe
			const hero = document.querySelector<HTMLElement>(".hero-cover");
			if (hero) {
				let startX = 0;
				let startY = 0;
				hero.addEventListener("touchstart", (e) => {
					startX = e.touches[0].clientX;
					startY = e.touches[0].clientY;
				}, { passive: true, signal: ctrl.signal });
				hero.addEventListener("touchend", (e) => {
					const dx = e.changedTouches[0].clientX - startX;
					const dy = e.changedTouches[0].clientY - startY;
					if (Math.abs(dx) > 50 && Math.abs(dx) > Math.abs(dy) * 1.5) {
						go(dx < 0 ? 1 : -1);
					}
				}, { passive: true, signal: ctrl.signal });
			}

			document.addEventListener("keydown", (e) => {
				if (e.target instanceof HTMLElement && e.target.matches("input, textarea, select")) return;
				if (e.key === "ArrowLeft") go(-1);
				else if (e.key === "ArrowRight") go(1);
			}, { signal: ctrl.signal });
			document.addEventListener("astro:before-swap", () => ctrl.abort(), { once: true });
		}
	});
</script>
