{
  "expo": {
    "name": "islam.se",
    "slug": "islam-se-mobile",
    "version": "1.0.1",
    "orientation": "portrait",
    "scheme": "islamse",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "se.islam.mobile",
      "buildNumber": "3",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "se.islam.mobile",
      "userInterfaceStyle": "automatic",
      "versionCode": 2,
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "@maplibre/maplibre-react-native",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Platsåtkomst används för att beräkna bönetider för var du befinner dig."
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#3a4684"
        }
      ],
      "expo-web-browser",
      "expo-mail-composer"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "updates": {
      "url": "https://u.expo.dev/ae3f5ac8-8773-4205-b590-ecb11f9a097e",
      "fallbackToCacheTimeout": 0
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "ae3f5ac8-8773-4205-b590-ecb11f9a097e"
      }
    },
    "owner": "edenmind"
  }
}
