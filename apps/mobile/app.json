{
  "expo": {
    "name": "islam.se",
    "slug": "islam-se-mobile",
    "version": "1.0.2",
    "orientation": "portrait",
    "scheme": "islamse",
    "userInterfaceStyle": "automatic",
    "icon": "./assets/images/icon.png",
    "ios": {
      "supportsTablet": true,
      "icon": {
        "light": "./assets/images/icon.png",
        "dark": "./assets/images/ios-dark.png",
        "tinted": "./assets/images/ios-tinted.png"
      },
      "bundleIdentifier": "se.islam.mobile",
      "buildNumber": "10",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "CFBundleDevelopmentRegion": "sv"
      }
    },
    "android": {
      "package": "se.islam.mobile",
      "userInterfaceStyle": "automatic",
      "versionCode": 4,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "monochromeImage": "./assets/images/adaptive-icon-monochrome.png",
        "backgroundColor": "#161a26"
      },
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "@maplibre/maplibre-react-native",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Platsåtkomst används för att beräkna bönetider där du befinner dig."
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#33437a",
          "icon": "./assets/images/notification-icon.png"
        }
      ],
      "expo-web-browser",
      "expo-mail-composer",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#000000"
        }
      ],
      [
        "expo-widgets",
        {
          "groupIdentifier": "group.se.islam.mobile",
          "widgets": [
            {
              "name": "PrayerTimesWidget",
              "displayName": "Bönetider",
              "description": "Nästa bön och dagens bönetider",
              "ios": {
                "supportedFamilies": [
                  "systemSmall",
                  "systemMedium",
                  "accessoryInline",
                  "accessoryRectangular",
                  "accessoryCircular"
                ]
              },
              "android": null
            }
          ]
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "updates": {
      "url": "https://u.expo.dev/ae3f5ac8-8773-4205-b590-ecb11f9a097e",
      "fallbackToCacheTimeout": 0
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "ae3f5ac8-8773-4205-b590-ecb11f9a097e"
      }
    },
    "owner": "edenmind"
  }
}
