{
	"name": "islam-se",
	"private": true,
	"type": "module",
	"scripts": {
		"build": "pnpm -r build",
		"check": "biome check .",
		"check:fix": "biome check --write .",
		"lint:articles": "markdownlint-cli2 'data/articles/*.md'",
		"knip": "knip",
		"test": "vitest run",
		"test:watch": "vitest",
		"cli": "pnpm --filter @islam-se/cli run cli",
		"produce": "pnpm --filter @islam-se/content-producer run produce",
		"tui": "ISLAM_OUTPUT_DIR=$(pwd)/apps/content-producer/output pnpm --filter @islam-se/tui run dev"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.3.15",
		"@types/node": "^25.2.3",
		"knip": "^5.83.1",
		"markdownlint-cli2": "^0.20.0",
		"typescript": "^5.9.3",
		"vitest": "^4.0.18"
	},
	"packageManager": "pnpm@9.15.0"
}
