{
	"name": "islam-se",
	"private": true,
	"type": "module",
	"scripts": {
		"build": "pnpm -r build",
		"check": "biome check .",
		"check:fix": "biome check --write .",
		"lint:articles": "markdownlint-cli2 'data/articles/*.md'",
		"knip": "knip",
		"test": "vitest run",
		"test:watch": "vitest",
		"cli": "pnpm --filter @islam-se/cli run cli",
		"produce": "pnpm --filter @islam-se/content-producer run produce",
		"tui": "ISLAM_OUTPUT_DIR=$(pwd)/apps/content-producer/output pnpm --filter @islam-se/tui run dev",
		"pdf": "pnpm --filter @islam-se/web run pdf",
		"ship": "pnpm build && pnpm pdf && wrangler pages deploy apps/web/dist --project-name islam-se"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.16",
		"@types/node": "^25.9.1",
		"knip": "^5.88.1",
		"markdownlint-cli2": "^0.22.1",
		"typescript": "^5.9.3",
		"vitest": "^4.1.7",
		"wrangler": "^4.95.0"
	},
	"packageManager": "pnpm@11.1.3+sha512.c85357fe17ca12dd23dd7071822666dfd7e3cb76fe214e3370b5ea2fb34f2a231185509b63e717f3cd0acb38dd3f8d82bcd5e8172400ae678b70ea4fbed0896d"
}
