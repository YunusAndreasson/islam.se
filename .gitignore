node_modules/

# Build output
dist/
.astro/

# Environment
.env
.env.local

# Data files (keep structure, ignore content)
data/sources/*
data/extracted/*
data/*.db
data/*.db-*
!data/.gitkeep

# Generated output
output/

# IDE
.idea/
.vscode/
*.swp
*.swo

# Local bin symlinks
bin/

# OS
.DS_Store
Thumbs.db

